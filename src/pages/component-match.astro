    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=swap"
      />
      <style>
        .noscript-warning {
          position: fixed; inset: 0; z-index: 9999;
          display: flex; align-items: center; justify-content: center;
          padding: 2rem; background: #050214; color: #fff;
          font-family: 'Inter Tight', system-ui, sans-serif; text-align: center;
        }
        .noscript-warning a { color: #67e8f9; }
      </style>
      <div class="noscript-warning" role="alert">
        <div>
          <h1 style="font-family: 'Monoton', sans-serif; font-size: 2rem; color: #fde68a; margin-bottom: 1rem;">JavaScript Required</h1>
          <p>This game needs JavaScript to run. Please enable it and refresh the page.</p>
          <p style="margin-top: 1rem;"><a href="https://jakefixestech.com">Return to Jake Fixes Tech</a></p>
        </div>
