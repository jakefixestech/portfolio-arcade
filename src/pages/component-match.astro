            <rect x="43" y="14" width="3" height="3" fill="#475569"/>
            <rect x="14" y="43" width="3" height="3" fill="#475569"/>
            <rect x="43" y="43" width="3" height="3" fill="#475569"/>
          </svg>`,
        },
        {
          key: 'usb',
          label: 'USB',
          svg: `<svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="22" width="32" height="16" rx="1" fill="#94a3b8" stroke="#475569" stroke-width="1.5"/>
