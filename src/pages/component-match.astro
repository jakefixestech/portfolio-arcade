  <body>
    <script src="/arcade-sound.js" is:inline></script>
    <script is:inline>
      // Arcade sound — universal hooks (toggle button, ambient hum, common events)
      window.addEventListener('DOMContentLoaded', () => {
        if (!window.ArcadeSound) return;
        window.ArcadeSound.injectToggleButton();

// Common UI sounds
        const startBtn = document.getElementById('start-btn');
        if (startBtn) startBtn.addEventListener('click', () => {
          window.ArcadeSound.play('insert_coin');
          window.ArcadeSound.startMusic('component-match');
        });

        const submitBtn = document.getElementById('submit-btn');
        if (submitBtn) submitBtn.addEventListener('click', () => window.ArcadeSound.play('button_click'));

        const playAgainBtn = document.getElementById('play-again-btn');
        if (playAgainBtn) playAgainBtn.addEventListener('click', () => {
          window.ArcadeSound.play('coin');
          window.ArcadeSound.startMusic('component-match');
        });
      });
    </script>
    <main class="page">

      <button id="exit-btn" type="button" class="exit-btn" aria-label="Back to Repair Bay">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 9 6 L 4 12 L 9 18 M 4 12 L 19 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="exit-btn-label">REPAIR BAY</span>
      </button>

      <a href="/" class="portal-return" aria-label="Return to the portal">
        <span class="portal-return-icon" aria-hidden="true">↻</span>
        <span class="portal-return-label">PORTAL</span>
      </a>

      <div class="sparkles" aria-hidden="true">
        {Array.from({ length: 18 }).map((_, i) => (
          <span class={`spark sp-${i + 1}`}></span>
        ))}
      </div>

      <section class="game-section">

        <!-- ARCADE CABINET WRAPPER (desktop only via CSS) -->
        <div class="cabinet-shell">

          <!-- Cabinet marquee (top sign) -->
          <div class="shell-marquee" aria-hidden="true">
            <div class="shell-marquee-bulbs">
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span>
            </div>
            <span class="shell-marquee-title">COMPONENT MATCH</span>
          </div>

          <!-- Cabinet body wraps the screen + controls + coin -->
          <div class="cabinet-body">

            <!-- Side art panels -->
            <div class="shell-side shell-side-l" aria-hidden="true">
              <div class="shell-side-art">
                <span class="side-decor side-d1"></span>
                <span class="side-decor side-d2"></span>
                <span class="side-decor side-d3"></span>
              </div>
            </div>
            <div class="shell-side shell-side-r" aria-hidden="true">
              <div class="shell-side-art">
                <span class="side-decor side-d1"></span>
                <span class="side-decor side-d2"></span>
                <span class="side-decor side-d3"></span>
              </div>
            </div>

            <!-- Screen bezel — wraps the existing game-wrap exactly -->
            <div class="shell-bezel">

              <!-- ============================== -->
              <!-- ORIGINAL GAME — UNTOUCHED       -->
              <!-- ============================== -->
              <div class="game-wrap">
                <div class="game-header" aria-hidden="true">
                  <div class="game-dots">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                  </div>
                  <div class="game-title">jake@arcade: ~/component-match</div>
                </div>

                <div class="game-body">

                  <div id="state-intro" class="state state--active">
                    <div class="intro-icon" aria-hidden="true">
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <rect x="8" y="14" width="28" height="38" rx="3" fill="#3b82f6" stroke="#1e3a8a" stroke-width="2" />
                        <rect x="44" y="14" width="28" height="38" rx="3" fill="#3b82f6" stroke="#1e3a8a" stroke-width="2" />
                        <rect x="14" y="22" width="16" height="22" rx="1" fill="#1e40af" />
                        <rect x="50" y="22" width="16" height="22" rx="1" fill="#1e40af" />
                        <rect x="17" y="26" width="10" height="3" fill="#fbbf24" />
                        <rect x="17" y="32" width="10" height="3" fill="#fbbf24" />
                        <rect x="17" y="38" width="6" height="3" fill="#fbbf24" />
                        <rect x="53" y="26" width="10" height="3" fill="#fbbf24" />
                        <rect x="53" y="32" width="10" height="3" fill="#fbbf24" />
                        <rect x="53" y="38" width="6" height="3" fill="#fbbf24" />
                        <line x1="36" y1="58" x2="44" y2="58" stroke="#10b981" stroke-width="3" stroke-linecap="round" />
                        <line x1="36" y1="64" x2="44" y2="64" stroke="#10b981" stroke-width="3" stroke-linecap="round" />
                      </svg>
                    </div>

                    <h1 class="intro-title">Component Match</h1>
                    <p class="intro-text">
                      Match all 6 pairs of <strong class="green-strong">motherboard parts</strong>.
                    </p>
                    <p class="intro-hint">
                      <strong>90 seconds.</strong> Faster finish = higher score. Mismatches don't cost points, just time.
                    </p>

                    <button id="start-btn" class="primary-btn" type="button">
                      <span>PLAY</span>
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M 7 5 L 7 19 L 19 12 Z" fill="currentColor" />
                      </svg>
                    </button>
                  </div>

                  <div id="state-playing" class="state">
                    <div class="hud">
                      <div class="hud-item">
                        <span class="hud-label">TIME</span>
                        <span class="hud-value" id="time-display">90.0s</span>
                      </div>
                      <div class="hud-item">
                        <span class="hud-label">MATCHED</span>
                        <span class="hud-value" id="matched-display">0/6</span>
                      </div>
                      <div class="hud-item">
                        <span class="hud-label">FLIPS</span>
                        <span class="hud-value" id="flips-display">0</span>
                      </div>
                    </div>

                    <div id="card-grid" class="card-grid" role="grid" aria-label="Memory matching grid"></div>
                  </div>

                  <div id="state-result" class="state">
                    <div class="result-icon" id="result-icon" aria-hidden="true">
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="40" cy="40" r="36" fill="#10b981" />
                        <path d="M 22 40 L 36 54 L 58 28" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>

                    <h2 class="result-title" id="result-title">All matched!</h2>
                    <p class="result-text">
                      Time: <strong id="result-time">0.0</strong>s<br>
                      Flips: <strong id="result-flips">0</strong><br>
                      Final score: <strong id="result-score">0</strong>
                    </p>

                    <div class="initials-section">
                      <p class="initials-label">ENTER YOUR INITIALS</p>
                      <div class="initials-inputs" role="group" aria-label="Three letter initials">
                        <input type="text" class="initial-box" id="init-1" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="First letter" />
                        <input type="text" class="initial-box" id="init-2" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Second letter" />
                        <input type="text" class="initial-box" id="init-3" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Third letter" />
                      </div>

                      <p class="initials-error" id="initials-error" aria-live="polite"></p>

                      <button id="submit-btn" class="primary-btn" type="button" disabled>
                        <span id="submit-btn-text">SUBMIT SCORE</span>
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>

                      <button id="skip-btn" class="ghost-btn" type="button">Skip — don't save my score</button>
                    </div>
                  </div>

                  <div id="state-leaderboard" class="state">
                    <div id="rank-reveal" class="rank-reveal">
                      <p class="rank-eyebrow" id="rank-eyebrow">YOU RANKED</p>
                      <span class="rank-number" id="rank-number">#1</span>
                      <p class="rank-detail" id="rank-detail">on the leaderboard</p>
                    </div>

                    <div class="leaderboard-wrap">
                      <span class="leaderboard-title">TOP 10 — COMPONENT MATCH</span>
                      <ol id="leaderboard-list" class="leaderboard"></ol>
                    </div>

                    <div class="share-section">
                      <p class="share-eyebrow">SHARE YOUR SCORE</p>
                      <div class="share-buttons">
                        <a id="share-fb" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to Facebook">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 12 2 C 6.477 2 2 6.477 2 12 C 2 17 5.66 21.13 10.44 21.88 L 10.44 14.89 L 7.9 14.89 L 7.9 12 L 10.44 12 L 10.44 9.8 C 10.44 7.29 11.93 5.91 14.22 5.91 C 15.31 5.91 16.45 6.1 16.45 6.1 L 16.45 8.56 L 15.19 8.56 C 13.95 8.56 13.56 9.33 13.56 10.12 L 13.56 12 L 16.34 12 L 15.89 14.89 L 13.56 14.89 L 13.56 21.88 C 18.34 21.13 22 17 22 12 C 22 6.477 17.523 2 12 2 Z" fill="currentColor" />
                          </svg>
                        </a>
                        <a id="share-x" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to X">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 18.244 2.25 L 21.552 2.25 L 14.325 10.51 L 22.827 21.75 L 16.17 21.75 L 10.956 14.933 L 4.99 21.75 L 1.68 21.75 L 9.41 12.915 L 1.254 2.25 L 8.08 2.25 L 12.793 8.481 L 18.244 2.25 Z M 17.083 19.77 L 18.916 19.77 L 7.084 4.126 L 5.117 4.126 L 17.083 19.77 Z" fill="currentColor" />
                          </svg>
                        </a>
                        <button id="share-native" type="button" class="share-btn" aria-label="Share via system share menu" style="display:none">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 12 3 L 12 16 M 7 8 L 12 3 L 17 8 M 4 14 L 4 20 a 1 1 0 0 0 1 1 L 19 21 a 1 1 0 0 0 1 -1 L 20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </button>
                        <button id="share-copy" type="button" class="share-btn" aria-label="Copy link to clipboard">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="8" y="8" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
                            <path d="M 5 15 L 4 15 a 1 1 0 0 1 -1 -1 L 3 4 a 1 1 0 0 1 1 -1 L 14 3 a 1 1 0 0 1 1 1 L 15 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                          </svg>
                        </button>
                      </div>
                      <p class="copy-toast" id="copy-toast" aria-live="polite">Link copied!</p>
                    </div>

                    <div class="action-buttons">
                      <button id="play-again-btn" type="button" class="primary-btn">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M 4 12 a 8 8 0 1 1 2.5 5.7 M 4 12 V 6 M 4 12 H 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>PLAY AGAIN</span>
                      </button>
                      <a href="/repair-bay" class="ghost-btn ghost-btn--link">← Back to Repair Bay</a>
                    </div>
                  </div>

                </div>
              </div>
              <!-- ============================== -->
              <!-- END ORIGINAL GAME               -->
              <!-- ============================== -->

            </div>

            <!-- Cabinet control panel (decorative, below screen on desktop) -->
            <div class="shell-controls" aria-hidden="true">
              <span class="shell-joystick">
                <span class="shell-joystick-base"></span>
                <span class="shell-joystick-stick"></span>
                <span class="shell-joystick-ball"></span>
              </span>
              <span class="shell-buttons">
                <span class="shell-btn shell-btn-red"></span>
                <span class="shell-btn shell-btn-yellow"></span>
                <span class="shell-btn shell-btn-green"></span>
                <span class="shell-btn shell-btn-blue"></span>
              </span>
            </div>

            <!-- Coin slot base -->
            <div class="shell-coin" aria-hidden="true">
              <span class="shell-coin-slot"></span>
              <span class="shell-coin-label">25¢ INSERT COIN</span>
            </div>

          </div>

          <!-- Cabinet floor shadow -->
          <span class="shell-floor-shadow" aria-hidden="true"></span>

        </div>

      </section>

      <div id="exit-dialog" class="dialog" role="dialog" aria-modal="true" aria-labelledby="exit-dialog-title" hidden>
        <div class="dialog-backdrop"></div>
        <div class="dialog-content">
          <h2 id="exit-dialog-title" class="dialog-title">Exit mid-game?</h2>
          <p class="dialog-text">Your score won't be saved if you leave now.</p>
          <div class="dialog-buttons">
            <button id="exit-cancel" type="button" class="ghost-btn">Keep playing</button>
            <button id="exit-confirm" type="button" class="danger-btn">Exit anyway</button>
          </div>
        </div>
      </div>
    </main>

    <script>
      // @ts-nocheck

      // === Config ===
      const TIME_LIMIT_MS = 90000;
      const PAIRS = 6;
      const FLIP_BACK_DELAY = 800;
      const GAME_SLUG = 'component-match';
      const GAME_NAME = 'Component Match';
