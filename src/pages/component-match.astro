      .exit-btn {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        z-index: 100;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.1rem;
        background: rgba(0, 0, 0, 0.5);
        border: 1.5px solid rgba(96, 165, 250, 0.5);
        border-radius: 4px;
        color: #60a5fa;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        cursor: pointer;
        text-shadow: 0 0 6px rgba(96, 165, 250, 0.7);
        box-shadow: 0 0 14px rgba(59, 130, 246, 0.3);
        transition: all 0.2s ease;
      }

      .exit-btn:hover, .exit-btn:focus-visible {
        transform: translateY(-2px);
        border-color: #60a5fa;
        box-shadow: 0 0 24px rgba(59, 130, 246, 0.6);
