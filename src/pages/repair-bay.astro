---
const CABINETS = [
  {
    name: 'Component Match',
    slug: 'component-match',
    tagline: 'Pair motherboard parts from memory',
    iconKey: 'match',
  },
  {
    name: 'USB Defender',
    slug: 'usb-defender',
    tagline: 'Bounce bugs back with a USB paddle',
    iconKey: 'usb',
  },
  {
    name: 'Tower Stack',
    slug: 'tower-stack',
    tagline: 'Build a working tower from falling parts',
    iconKey: 'tower',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Repair Bay — Jake's Arcade</title>
    <meta name="description" content="The Repair Bay. Hands-on tech games at Jake's Arcade." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800;900&family=Monoton&family=JetBrains+Mono:wght@400;600;700&family=Inter+Tight:wght@400;600;700;900&display=swap"
    />
  </head>

  <body>
    <main class="bay">

      <div class="ambient" aria-hidden="true">
        <span class="spark sp1"></span><span class="spark sp2"></span>
        <span class="spark sp3"></span><span class="spark sp4"></span>
        <span class="spark sp5"></span><span class="spark sp6"></span>
      </div>

      <div class="pegboard" aria-hidden="true"></div>

      <div class="tools" aria-hidden="true">
        <svg class="tool tool-1" viewBox="0 0 40 80" xmlns="http://www.w3.org/2000/svg">
          <line x1="20" y1="0" x2="20" y2="6" stroke="#1e293b" stroke-width="1"/>
          <circle cx="20" cy="6" r="2" fill="#475569"/>
          <rect x="14" y="10" width="12" height="32" rx="2" fill="#475569" stroke="#1e293b" stroke-width="1"/>
          <rect x="16" y="42" width="8" height="28" fill="#fbbf24" stroke="#92400e" stroke-width="1"/>
        </svg>
        <svg class="tool tool-2" viewBox="0 0 40 80" xmlns="http://www.w3.org/2000/svg">
          <line x1="20" y1="0" x2="20" y2="8" stroke="#1e293b" stroke-width="1"/>
          <circle cx="20" cy="8" r="2" fill="#475569"/>
          <rect x="12" y="12" width="16" height="6" rx="1" fill="#94a3b8" stroke="#1e293b" stroke-width="1"/>
          <rect x="16" y="18" width="8" height="38" fill="#475569" stroke="#1e293b" stroke-width="1"/>
          <rect x="14" y="56" width="12" height="14" rx="2" fill="#1e293b"/>
        </svg>
        <svg class="tool tool-3" viewBox="0 0 40 80" xmlns="http://www.w3.org/2000/svg">
          <line x1="20" y1="0" x2="20" y2="6" stroke="#1e293b" stroke-width="1"/>
          <circle cx="20" cy="6" r="2" fill="#475569"/>
          <rect x="16" y="10" width="8" height="40" rx="1" fill="#94a3b8" stroke="#1e293b" stroke-width="1"/>
          <path d="M 12 50 L 28 50 L 24 70 L 16 70 Z" fill="#fbbf24" stroke="#92400e" stroke-width="1"/>
        </svg>
      </div>

      <a href="https://jakefixestech.com" class="exit-sign" aria-label="Exit the arcade and return to Jake Fixes Tech">
        <span class="exit-arrow" aria-hidden="true">←</span>
        <span class="exit-label">EXIT</span>
      </a>

      <a href="/lobby" class="back-to-lobby" aria-label="Back to the lobby">
        <span class="back-arrow" aria-hidden="true">←</span>
        <span class="back-label">LOBBY</span>
      </a>

      <a href="/" class="portal-return" aria-label="Return to the portal">
        <span class="portal-return-icon" aria-hidden="true">↻</span>
        <span class="portal-return-label">PORTAL</span>
      </a>

      <header class="bay-marquee">
        <p class="marquee-eyebrow">YOU HAVE ENTERED</p>
        <h1 class="marquee-title">REPAIR BAY</h1>
        <p class="marquee-tagline">Hands-on tech. Match parts, defend ports, fix things.</p>
      </header>

      <section class="workshop" aria-label="Arcade cabinets">
        <div class="floor" aria-hidden="true"></div>

        <div class="cabinets">
          {CABINETS.map((cab, idx) => (
            <a
              href={`/${cab.slug}`}
              class="cabinet"
              style={`--cab-delay: ${0.5 + idx * 0.25}s;`}
              aria-label={`Play ${cab.name}: ${cab.tagline}`}
            >
              <span class="cabinet-spotlight" aria-hidden="true"></span>

              <div class="cab-marquee" aria-hidden="true">
                <div class="cab-marquee-bulbs">
                  <span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span>
                </div>
                <p class="cab-marquee-title">{cab.name}</p>
              </div>

              <div class="cab-screen" aria-hidden="true">
                <div class="cab-screen-glow"></div>
                <div class="cab-screen-content">
                  <span class="cab-screen-icon">
                    {cab.iconKey === 'match' && (
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <rect x="8" y="14" width="28" height="38" rx="3" fill="#3b82f6" stroke="#1e3a8a" stroke-width="2"/>
                        <rect x="44" y="14" width="28" height="38" rx="3" fill="#3b82f6" stroke="#1e3a8a" stroke-width="2"/>
                        <rect x="14" y="22" width="16" height="22" rx="1" fill="#1e40af"/>
                        <rect x="50" y="22" width="16" height="22" rx="1" fill="#1e40af"/>
                        <rect x="17" y="26" width="10" height="3" fill="#fbbf24"/>
                        <rect x="17" y="32" width="10" height="3" fill="#fbbf24"/>
                        <rect x="53" y="26" width="10" height="3" fill="#fbbf24"/>
                        <rect x="53" y="32" width="10" height="3" fill="#fbbf24"/>
                        <line x1="36" y1="58" x2="44" y2="58" stroke="#10b981" stroke-width="3" stroke-linecap="round"/>
                        <line x1="36" y1="64" x2="44" y2="64" stroke="#10b981" stroke-width="3" stroke-linecap="round"/>
                      </svg>
                    )}
                    {cab.iconKey === 'usb' && (
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <rect x="14" y="34" width="36" height="14" rx="2" fill="#94a3b8" stroke="#475569" stroke-width="2"/>
                        <rect x="50" y="36" width="14" height="10" rx="1" fill="#cbd5e1" stroke="#64748b" stroke-width="1.5"/>
                        <rect x="18" y="38" width="6" height="6" fill="#fbbf24"/>
                        <rect x="26" y="38" width="6" height="6" fill="#fbbf24"/>
                        <rect x="34" y="38" width="6" height="6" fill="#fbbf24"/>
                        <rect x="42" y="38" width="6" height="6" fill="#fbbf24"/>
                        <circle cx="20" cy="60" r="4" fill="#ef4444" stroke="#7f1d1d" stroke-width="1.5"/>
                        <circle cx="60" cy="22" r="4" fill="#ef4444" stroke="#7f1d1d" stroke-width="1.5"/>
                      </svg>
                    )}
                    {cab.iconKey === 'tower' && (
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <!-- Stack base/floor -->
                        <line x1="8" y1="72" x2="72" y2="72" stroke="#1e3a8a" stroke-width="2" stroke-linecap="round"/>
                        <!-- Bottom row: motherboard square (green) -->
                        <rect x="20" y="56" width="14" height="14" rx="1" fill="#10b981" stroke="#065f46" stroke-width="1.5"/>
                        <rect x="34" y="56" width="14" height="14" rx="1" fill="#10b981" stroke="#065f46" stroke-width="1.5"/>
                        <rect x="48" y="56" width="14" height="14" rx="1" fill="#10b981" stroke="#065f46" stroke-width="1.5"/>
                        <!-- Mid row: GPU L-piece (orange) -->
                        <rect x="20" y="42" width="14" height="14" rx="1" fill="#f97316" stroke="#9a3412" stroke-width="1.5"/>
                        <rect x="34" y="42" width="14" height="14" rx="1" fill="#f97316" stroke="#9a3412" stroke-width="1.5"/>
                        <!-- CPU heatsink T (red) -->
                        <rect x="48" y="42" width="14" height="14" rx="1" fill="#ef4444" stroke="#7f1d1d" stroke-width="1.5"/>
                        <rect x="34" y="28" width="14" height="14" rx="1" fill="#ef4444" stroke="#7f1d1d" stroke-width="1.5"/>
                        <!-- Top row: RAM stick I-piece (blue) currently falling -->
                        <rect x="20" y="14" width="14" height="14" rx="1" fill="#3b82f6" stroke="#1e3a8a" stroke-width="1.5"/>
                        <rect x="20" y="14" width="14" height="3" fill="#fbbf24"/>
                        <!-- Falling indicator arrow -->
                        <path d="M 27 8 L 27 13 M 24 11 L 27 14 L 30 11" fill="none" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </span>
                  <span class="cab-screen-tagline">{cab.tagline}</span>
                  <span class="cab-screen-press">▸ PRESS START</span>
                </div>
              </div>

              <div class="cab-controls" aria-hidden="true">
                <span class="cab-joystick">
                  <span class="cab-joystick-base"></span>
                  <span class="cab-joystick-stick"></span>
                  <span class="cab-joystick-ball"></span>
                </span>
                <span class="cab-buttons">
                  <span class="cab-btn cab-btn-red"></span>
                  <span class="cab-btn cab-btn-yellow"></span>
                  <span class="cab-btn cab-btn-green"></span>
                </span>
              </div>

              <div class="cab-coin" aria-hidden="true">
                <span class="cab-coin-slot"></span>
                <span class="cab-coin-label">25¢ INSERT COIN</span>
              </div>

              <span class="cab-shadow" aria-hidden="true"></span>
            </a>
          ))}
        </div>
      </section>

    </main>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; tap-highlight-color: transparent; }

      :root {
        --c-bg: #0a0e1a;
        --c-blue: #3b82f6;
        --c-blue-light: #60a5fa;
        --c-blue-glow: rgba(59, 130, 246, 0.7);
      }

      html, body {
        background: var(--c-bg);
        color: #fff;
        font-family: 'Inter Tight', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
      }

      html { overflow-x: hidden; }
      body { overflow-x: hidden; max-width: 100vw; }

      .bay {
        position: relative;
        min-height: 100vh;
        padding: 0 1.5rem 5rem;
        background:
          radial-gradient(ellipse at 50% 5%, rgba(251, 191, 36, 0.12) 0%, transparent 40%),
          radial-gradient(ellipse at 20% 80%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 80%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
          linear-gradient(180deg, #1a1410 0%, #0e0c1a 50%, #050214 100%);
      }

      .pegboard {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image: radial-gradient(circle at 1px 1px, rgba(96, 165, 250, 0.06) 1px, transparent 1px);
        background-size: 22px 22px;
        opacity: 0.6;
      }

      .tools {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 80px;
        pointer-events: none;
        z-index: 1;
      }

      .tool {
        position: absolute;
        top: 0;
        width: 30px;
        height: 70px;
        opacity: 0.4;
      }

      .tool-1 { left: 12%; }
      .tool-2 { left: 35%; transform: rotate(8deg); }
      .tool-3 { right: 18%; transform: rotate(-5deg); }

      @media (max-width: 900px) {
        .tools { display: none; }
      }

      .ambient {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
      }

      .spark {
        position: absolute;
        width: 2px;
        height: 2px;
        background: #fbbf24;
        border-radius: 50%;
        box-shadow: 0 0 6px #fbbf24, 0 0 12px rgba(251, 191, 36, 0.6);
        opacity: 0;
      }

      .sp1 { left: 25%; bottom: 40%; animation: spark-rise 5s ease-out 0.5s infinite; }
      .sp2 { left: 70%; bottom: 35%; animation: spark-rise 6s ease-out 2s infinite; }
      .sp3 { left: 45%; bottom: 50%; animation: spark-rise 5s ease-out 3.5s infinite; }
      .sp4 { left: 15%; bottom: 30%; animation: spark-rise 7s ease-out 1s infinite; }
      .sp5 { left: 85%; bottom: 45%; animation: spark-rise 5s ease-out 4s infinite; }
      .sp6 { left: 55%; bottom: 25%; animation: spark-rise 6s ease-out 2.5s infinite; }

      @keyframes spark-rise {
        0%   { transform: translateY(0); opacity: 0; }
        15%  { opacity: 1; }
        100% { transform: translateY(-180px) translateX(8px); opacity: 0; }
      }

      .exit-sign {
        position: fixed;
        top: 1.25rem;
        left: 1.25rem;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 1.1rem;
        background: rgba(0, 0, 0, 0.5);
        border: 2px solid #22c55e;
        border-radius: 4px;
        color: #4ade80;
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.25em;
        text-decoration: none;
        text-shadow: 0 0 6px rgba(74, 222, 128, 0.9), 0 0 14px rgba(74, 222, 128, 0.5);
        box-shadow: 0 0 0 1px rgba(74, 222, 128, 0.2), 0 0 18px rgba(74, 222, 128, 0.45), inset 0 0 12px rgba(74, 222, 128, 0.18);
        transition: transform 0.2s, box-shadow 0.2s;
        animation: exit-flicker 6s steps(60) infinite;
      }

      .exit-arrow { font-size: 1rem; font-weight: 800; }

      .exit-sign:hover, .exit-sign:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 0 0 1px rgba(74, 222, 128, 0.4), 0 0 30px rgba(74, 222, 128, 0.7), inset 0 0 16px rgba(74, 222, 128, 0.3);
        outline: none;
      }

      @keyframes exit-flicker {
        0%, 100% { opacity: 1; }
        96%, 96.5% { opacity: 0.4; }
        97%, 97.4% { opacity: 1; }
        97.5%, 97.8% { opacity: 0.5; }
        98% { opacity: 1; }
      }

      .back-to-lobby {
        position: fixed;
        top: 1.25rem;
        right: 1.25rem;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: rgba(0, 0, 0, 0.5);
        border: 1.5px solid rgba(96, 165, 250, 0.5);
        border-radius: 4px;
        color: var(--c-blue-light);
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-decoration: none;
        text-shadow: 0 0 6px var(--c-blue-glow);
        box-shadow: 0 0 14px rgba(59, 130, 246, 0.3);
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      }

      .back-to-lobby:hover, .back-to-lobby:focus-visible {
        transform: translateY(-2px);
        border-color: var(--c-blue-light);
        box-shadow: 0 0 24px rgba(59, 130, 246, 0.6);
        outline: none;
      }

      .portal-return {
        position: fixed;
        bottom: 1.25rem;
        right: 1.25rem;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 0.95rem;
        background: rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(168, 85, 247, 0.4);
        border-radius: 999px;
        color: rgba(196, 181, 253, 0.85);
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-decoration: none;
        text-shadow: 0 0 6px rgba(168, 85, 247, 0.5);
        box-shadow: 0 0 12px rgba(168, 85, 247, 0.2);
        transition: color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }

      .portal-return-icon {
        font-size: 0.85rem;
        animation: portal-return-spin 6s linear infinite;
        display: inline-block;
      }

      @keyframes portal-return-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      .portal-return:hover, .portal-return:focus-visible {
        color: #fff;
        border-color: rgba(168, 85, 247, 0.8);
        box-shadow: 0 0 20px rgba(168, 85, 247, 0.5);
        transform: translateY(-2px);
        outline: none;
      }

      .bay-marquee {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 5rem 1rem 2.5rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .marquee-eyebrow {
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.45em;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 1rem;
      }

      .marquee-title {
        font-family: 'Monoton', 'Orbitron', system-ui, sans-serif;
        font-size: clamp(2.5rem, 9vw, 6rem);
        font-weight: 400;
        line-height: 1;
        letter-spacing: 0.06em;
        color: #93c5fd;
        text-shadow:
          0 0 6px rgba(59, 130, 246, 1),
          0 0 14px rgba(59, 130, 246, 0.9),
          0 0 28px rgba(59, 130, 246, 0.7),
          0 0 56px rgba(59, 130, 246, 0.4);
        animation: marquee-flicker 8s steps(80) infinite;
      }

      @keyframes marquee-flicker {
        0%, 100% { opacity: 1; }
        45%, 45.4% { opacity: 0.6; }
        45.6%, 46% { opacity: 1; }
        78%, 78.3% { opacity: 0.45; }
        78.6%, 79% { opacity: 1; }
      }

      .marquee-tagline {
        margin-top: 1.5rem;
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
      }

      .workshop {
        position: relative;
        z-index: 2;
        max-width: 1400px;
        margin: 2rem auto 0;
      }

      .floor {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 35%;
        background:
          linear-gradient(180deg, transparent 0%, rgba(59, 130, 246, 0.06) 40%, rgba(59, 130, 246, 0.10) 100%),
          repeating-linear-gradient(90deg, transparent 0, transparent 60px, rgba(59, 130, 246, 0.04) 60px, rgba(59, 130, 246, 0.04) 61px);
        border-top: 1px solid rgba(59, 130, 246, 0.2);
        pointer-events: none;
      }

      .cabinets {
        position: relative;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
        align-items: end;
      }

      .cabinet {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: #fff;
        max-width: 320px;
        width: 100%;
        margin: 0 auto;
        opacity: 0;
        animation: cabinet-arrive 0.8s ease-out var(--cab-delay, 0.5s) forwards;
        transition: transform 0.3s;
      }

      @keyframes cabinet-arrive {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .cabinet:hover, .cabinet:focus-visible {
        transform: translateY(-8px);
        outline: none;
      }

      .cabinet-spotlight {
        position: absolute;
        top: -8%;
        left: 50%;
        transform: translateX(-50%);
        width: 140%;
        height: 110%;
        background: radial-gradient(ellipse at 50% 0%, rgba(251, 191, 36, 0.18) 0%, transparent 55%);
        pointer-events: none;
        z-index: 0;
      }

      .cab-marquee {
        position: relative;
        z-index: 2;
        width: 92%;
        padding: 0.85rem 1rem 0.7rem;
        background: linear-gradient(180deg, #1e3a8a 0%, #1e293b 100%);
        border: 2px solid #1e3a8a;
        border-bottom: none;
        border-radius: 8px 8px 0 0;
        text-align: center;
        box-shadow:
          inset 0 0 14px rgba(59, 130, 246, 0.4),
          0 0 18px rgba(59, 130, 246, 0.4);
      }

      .cab-marquee-bulbs {
        display: flex;
        justify-content: center;
        gap: 0.35rem;
        margin-bottom: 0.4rem;
      }

      .cab-marquee-bulbs span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fbbf24;
        box-shadow: 0 0 4px #fbbf24, 0 0 8px rgba(251, 191, 36, 0.7);
        animation: bulb-blink 1.6s ease-in-out infinite;
      }

      .cab-marquee-bulbs span:nth-child(2n) { animation-delay: 0.3s; }
      .cab-marquee-bulbs span:nth-child(3n) { animation-delay: 0.6s; }

      @keyframes bulb-blink {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.4; transform: scale(0.85); }
      }

      .cab-marquee-title {
        font-family: 'Monoton', 'Orbitron', system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(0.9rem, 1.4vw, 1.2rem);
        letter-spacing: 0.08em;
        color: #fde68a;
        text-shadow:
          0 0 4px rgba(251, 191, 36, 0.9),
          0 0 10px rgba(251, 191, 36, 0.6);
      }

      .cab-screen {
        position: relative;
        z-index: 2;
        width: 92%;
        aspect-ratio: 1.05;
        background: #050214;
        border: 8px solid #1e293b;
        border-top: none;
        overflow: hidden;
        box-shadow:
          inset 0 0 0 2px #0a0e1a,
          inset 0 0 30px rgba(59, 130, 246, 0.25),
          0 0 24px rgba(59, 130, 246, 0.4);
      }

      .cab-screen-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.18) 0%, transparent 60%);
        pointer-events: none;
      }

      .cab-screen-content {
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.85rem;
        padding: 1.25rem;
        background:
          repeating-linear-gradient(0deg, transparent 0, transparent 3px, rgba(0, 0, 0, 0.15) 3px, rgba(0, 0, 0, 0.15) 4px);
      }

      .cab-screen-icon {
        width: clamp(60px, 14vw, 96px);
        height: clamp(60px, 14vw, 96px);
        filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.6));
      }

      .cab-screen-icon svg { width: 100%; height: 100%; }

      .cab-screen-tagline {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(0.7rem, 1vw, 0.85rem);
        color: #93c5fd;
        text-align: center;
        line-height: 1.4;
        max-width: 220px;
        opacity: 0.85;
      }

      .cab-screen-press {
        font-family: 'Orbitron', system-ui, sans-serif;
        font-weight: 800;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        letter-spacing: 0.2em;
        color: #fbbf24;
        text-shadow: 0 0 6px rgba(251, 191, 36, 0.8);
        animation: press-blink 1.4s steps(2) infinite;
      }

      @keyframes press-blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0.35; }
      }

      .cab-controls {
        position: relative;
        z-index: 2;
        width: 92%;
        padding: 0.85rem 1.25rem;
        background: linear-gradient(180deg, #475569 0%, #334155 100%);
        border: 2px solid #1e293b;
        border-top: none;
        border-bottom: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: inset 0 4px 6px rgba(0, 0, 0, 0.3);
      }

      .cab-joystick {
        position: relative;
        width: 30px;
        height: 30px;
        flex-shrink: 0;
      }

      .cab-joystick-base {
        position: absolute;
        bottom: 0; left: 50%;
        transform: translateX(-50%);
        width: 22px;
        height: 8px;
        background: #0f172a;
        border-radius: 50%;
      }

      .cab-joystick-stick {
        position: absolute;
        bottom: 4px; left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 18px;
        background: linear-gradient(90deg, #1e293b, #475569, #1e293b);
        border-radius: 2px;
      }

      .cab-joystick-ball {
        position: absolute;
        top: 0; left: 50%;
        transform: translateX(-50%);
        width: 12px;
        height: 12px;
        background: radial-gradient(circle at 30% 30%, #ef4444, #7f1d1d);
        border-radius: 50%;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
      }

      .cab-buttons {
        display: flex;
        gap: 0.4rem;
        align-items: center;
      }

      .cab-btn {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1.5px solid #0f172a;
        box-shadow:
          inset 0 -2px 3px rgba(0, 0, 0, 0.4),
          inset 0 1px 1px rgba(255, 255, 255, 0.3);
      }

      .cab-btn-red    { background: radial-gradient(circle at 30% 30%, #ef4444, #b91c1c); }
      .cab-btn-yellow { background: radial-gradient(circle at 30% 30%, #fbbf24, #b45309); }
      .cab-btn-green  { background: radial-gradient(circle at 30% 30%, #22c55e, #15803d); }

      .cab-coin {
        position: relative;
        z-index: 2;
        width: 92%;
        padding: 1rem 1rem 1.25rem;
        background: linear-gradient(180deg, #1e293b 0%, #0a0e1a 100%);
        border: 2px solid #0a0e1a;
        border-top: none;
        border-radius: 0 0 6px 6px;
        text-align: center;
        box-shadow:
          inset 0 0 14px rgba(0, 0, 0, 0.6),
          0 6px 20px rgba(0, 0, 0, 0.5);
      }

      .cab-coin-slot {
        display: block;
        width: 50px;
        height: 4px;
        margin: 0 auto 0.5rem;
        background: #050214;
        border-radius: 1px;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.9);
      }

      .cab-coin-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        color: #94a3b8;
      }

      .cab-shadow {
        position: absolute;
        bottom: -12px;
        left: 8%; right: 8%;
        height: 18px;
        background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7) 0%, transparent 70%);
        filter: blur(6px);
        z-index: 0;
      }

      @media (max-width: 900px) {
        .cabinets {
          grid-template-columns: 1fr;
          gap: 3rem;
          max-width: 360px;
        }
        .cabinet { max-width: 320px; }
      }

      @media (min-width: 901px) and (max-width: 1100px) {
        .cabinets { gap: 1.5rem; }
        .cabinet { max-width: 280px; }
      }

      @media (max-width: 600px) {
        .bay { padding: 0 1rem 4rem; }
        .bay-marquee { padding: 4rem 0.5rem 1.5rem; }

        .exit-sign, .back-to-lobby {
          padding: 0.5rem 0.75rem;
          font-size: 0.65rem;
          letter-spacing: 0.18em;
        }
        .exit-sign { top: 0.75rem; left: 0.75rem; }
        .back-to-lobby { top: 0.75rem; right: 0.75rem; }
        .portal-return {
          bottom: 0.6rem;
          right: 0.6rem;
          padding: 0.4rem 0.7rem;
          font-size: 0.55rem;
          letter-spacing: 0.12em;
          gap: 0.35rem;
          max-width: calc(100vw - 1.2rem);
        }
        .portal-return-icon { font-size: 0.7rem; }

        .cabinets { padding: 1rem 0 3rem; }
        .cabinet { max-width: 280px; }
      }

      @media (min-width: 1500px) {
        .cabinets { gap: 3rem; max-width: 1300px; }
        .cabinet { max-width: 360px; }
      }

      @media (prefers-reduced-motion: reduce) {
        .marquee-title, .exit-sign, .spark, .cab-marquee-bulbs span,
        .cab-screen-press, .portal-return-icon, .cabinet {
          animation: none !important;
        }
        .cabinet { opacity: 1; }
      }
    </style>
  </body>
</html>