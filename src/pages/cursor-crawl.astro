    <script>
      // @ts-nocheck

      const GRID_SIZE = 20;
      const CANVAS_SIZE = 400;
      const CELL = CANVAS_SIZE / GRID_SIZE;
      const START_LEN = 3;
      const TICK_BASE_MS = 160;
      const TICK_MIN_MS = 80;
      const SPEED_RAMP_PER_BUG = 4;
      const GAME_SLUG = 'cursor-crawl';
      const GAME_NAME = 'Cursor Crawl';
      const EXIT_TO = '/code-maze';

      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const stateLeaderboard = document.getElementById('state-leaderboard');
      const startBtn = document.getElementById('start-btn');
      const exitBtn = document.getElementById('exit-btn');
      const scoreDisplay = document.getElementById('score-display');
      const lengthDisplay = document.getElementById('length-display');
      const speedDisplay = document.getElementById('speed-display');
      const canvas = document.getElementById('game-canvas');
      const ctx = canvas.getContext('2d');
      const boardOverlay = document.getElementById('board-overlay');
      const resultScore = document.getElementById('result-score');
      const resultLength = document.getElementById('result-length');
      const initBoxes = [
        document.getElementById('init-1'),
        document.getElementById('init-2'),
        document.getElementById('init-3'),
      ];
      const initialsError = document.getElementById('initials-error');
      const submitBtn = document.getElementById('submit-btn');
      const submitBtnText = document.getElementById('submit-btn-text');
      const skipBtn = document.getElementById('skip-btn');
      const rankNumber = document.getElementById('rank-number');
      const rankEyebrow = document.getElementById('rank-eyebrow');
      const rankDetail = document.getElementById('rank-detail');
      const leaderboardList = document.getElementById('leaderboard-list');
      const playAgainBtn = document.getElementById('play-again-btn');
      const exitDialog = document.getElementById('exit-dialog');
      const exitCancel = document.getElementById('exit-cancel');
      const exitConfirm = document.getElementById('exit-confirm');
      const shareFb = document.getElementById('share-fb');
      const shareX = document.getElementById('share-x');
      const shareNative = document.getElementById('share-native');
      const shareCopy = document.getElementById('share-copy');
      const copyToast = document.getElementById('copy-toast');

      let snake = [];
      let dir = { x: 1, y: 0 };
      let nextDir = { x: 1, y: 0 };
      let bug = null;
      let score = 0;
      let tickMs = TICK_BASE_MS;
      let tickHandle = null;
      let gameRunning = false;
      let gameStarted = false;
      let finalScore = 0;
      let lastSubmittedRank = null;
      let lastSubmittedInitials = null;

      function showState(name) {
        [stateIntro, statePlaying, stateResult, stateLeaderboard].forEach(s => s.classList.remove('state--active'));
        if (name === 'intro')       stateIntro.classList.add('state--active');
        if (name === 'playing')     statePlaying.classList.add('state--active');
        if (name === 'result')      stateResult.classList.add('state--active');
        if (name === 'leaderboard') stateLeaderboard.classList.add('state--active');
      }

      function spawnBug() {
        const occupied = new Set(snake.map(s => `${s.x},${s.y}`));
        const free = [];
        for (let y = 0; y < GRID_SIZE; y++) {
          for (let x = 0; x < GRID_SIZE; x++) {
            if (!occupied.has(`${x},${y}`)) free.push({ x, y });
          }
        }
        if (free.length === 0) return null;
        return free[Math.floor(Math.random() * free.length)];
      }

      function startGame() {
        snake = [
          { x: 10, y: 10 },
          { x: 9, y: 10 },
          { x: 8, y: 10 },
        ];
        dir = { x: 1, y: 0 };
        nextDir = { x: 1, y: 0 };
        score = 0;
        tickMs = TICK_BASE_MS;
        gameRunning = true;
        gameStarted = false;

        scoreDisplay.textContent = '0';
        lengthDisplay.textContent = String(START_LEN);
        speedDisplay.textContent = '1x';

        bug = spawnBug();

        showState('playing');
        boardOverlay.classList.remove('board-overlay--hidden');
        draw();
      }

      function beginMovement() {
        if (gameStarted || !gameRunning) return;
        gameStarted = true;
        boardOverlay.classList.add('board-overlay--hidden');
        scheduleTick();
      }

      function scheduleTick() {
        clearTimeout(tickHandle);
        tickHandle = setTimeout(tick, tickMs);
      }

      function tick() {
        if (!gameRunning || !gameStarted) return;

        dir = nextDir;

        const head = snake[0];
        const newHead = { x: head.x + dir.x, y: head.y + dir.y };

        if (newHead.x < 0 || newHead.x >= GRID_SIZE || newHead.y < 0 || newHead.y >= GRID_SIZE) {
          endGame();
          return;
        }

        for (let i = 0; i < snake.length; i++) {
          if (snake[i].x === newHead.x && snake[i].y === newHead.y) {
            if (i === snake.length - 1 && !(bug && newHead.x === bug.x && newHead.y === bug.y)) {
              continue;
            }
            endGame();
            return;
          }
        }

        snake.unshift(newHead);

        if (bug && newHead.x === bug.x && newHead.y === bug.y) {
          score++;
          scoreDisplay.textContent = String(score);
          lengthDisplay.textContent = String(snake.length);
          tickMs = Math.max(TICK_MIN_MS, TICK_BASE_MS - score * SPEED_RAMP_PER_BUG);
          const speedMult = (TICK_BASE_MS / tickMs).toFixed(1);
          speedDisplay.textContent = `${speedMult}x`;
          if (window.ArcadeSound) window.ArcadeSound.play('cursor_eat');
          bug = spawnBug();
        } else {
          snake.pop();
        }

        draw();
        scheduleTick();
      }

      function draw() {
        ctx.fillStyle = '#0a0e1a';
        ctx.fillRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);

        ctx.strokeStyle = 'rgba(96, 165, 250, 0.08)';
        ctx.lineWidth = 1;
        for (let i = 1; i < GRID_SIZE; i++) {
          ctx.beginPath();
          ctx.moveTo(i * CELL, 0);
          ctx.lineTo(i * CELL, CANVAS_SIZE);
          ctx.stroke();
          ctx.beginPath();
          ctx.moveTo(0, i * CELL);
          ctx.lineTo(CANVAS_SIZE, i * CELL);
          ctx.stroke();
        }

        if (bug) {
          drawBug(bug.x, bug.y);
        }

        for (let i = snake.length - 1; i >= 0; i--) {
          const s = snake[i];
          if (i === 0) {
            drawHead(s.x, s.y, dir);
          } else {
            drawSegment(s.x, s.y, i, snake.length);
          }
        }
      }

      function drawSegment(gx, gy, idx, total) {
        const x = gx * CELL;
        const y = gy * CELL;
        const inset = 2;
        const t = idx / Math.max(1, total - 1);
        const r = Math.round(251 + (217 - 251) * t);
        const g = Math.round(191 + (119 - 191) * t);
        const b = Math.round(36 + (6 - 36) * t);
        ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
        ctx.fillRect(x + inset, y + inset, CELL - inset * 2, CELL - inset * 2);
      }

      function drawHead(gx, gy, d) {
        const x = gx * CELL;
        const y = gy * CELL;
        ctx.save();
        ctx.translate(x + CELL / 2, y + CELL / 2);
        let rot = 0;
        if (d.x === 1 && d.y === 0) rot = Math.PI / 2;
        else if (d.x === -1 && d.y === 0) rot = -Math.PI / 2;
        else if (d.x === 0 && d.y === 1) rot = Math.PI;
        else if (d.x === 0 && d.y === -1) rot = 0;
        ctx.rotate(rot);

        const s = CELL * 0.5;
        ctx.fillStyle = '#fbbf24';
        ctx.strokeStyle = '#92400e';
        ctx.lineWidth = 1.5;
        ctx.lineJoin = 'round';
        ctx.beginPath();
        ctx.moveTo(0, -s);
        ctx.lineTo(s * 0.7, s * 0.3);
        ctx.lineTo(s * 0.18, s * 0.3);
        ctx.lineTo(s * 0.4, s);
        ctx.lineTo(s * 0.05, s * 1.05);
        ctx.lineTo(-s * 0.18, s * 0.4);
        ctx.lineTo(-s * 0.7, s * 0.5);
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
        ctx.restore();
      }

      function drawBug(gx, gy) {
        const cx = gx * CELL + CELL / 2;
        const cy = gy * CELL + CELL / 2;
        const r = CELL * 0.32;
        ctx.fillStyle = '#dc2626';
        ctx.beginPath();
        ctx.ellipse(cx, cy + r * 0.1, r, r * 1.15, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = '#7f1d1d';
        ctx.lineWidth = 1.2;
        ctx.beginPath();
        ctx.moveTo(cx - r * 0.4, cy - r * 0.7);
        ctx.lineTo(cx - r * 0.7, cy - r * 1.2);
        ctx.moveTo(cx + r * 0.4, cy - r * 0.7);
        ctx.lineTo(cx + r * 0.7, cy - r * 1.2);
        ctx.stroke();
        ctx.fillStyle = '#fff';
        ctx.beginPath();
        ctx.arc(cx - r * 0.3, cy - r * 0.2, r * 0.18, 0, Math.PI * 2);
        ctx.arc(cx + r * 0.3, cy - r * 0.2, r * 0.18, 0, Math.PI * 2);
        ctx.fill();
      }

      function setDirection(nx, ny) {
        if (snake.length > 1 && gameStarted) {
          if (dir.x === -nx && dir.y === -ny) return;
          if (dir.x === nx && dir.y === ny) {
            beginMovement();
            return;
          }
        }
        nextDir = { x: nx, y: ny };
        beginMovement();
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !exitDialog.hidden) {
          hideExitDialog();
          return;
        }
        if (!statePlaying.classList.contains('state--active')) return;
        switch (e.key) {
          case 'ArrowUp': case 'w': case 'W':
            e.preventDefault(); setDirection(0, -1); break;
          case 'ArrowDown': case 's': case 'S':
            e.preventDefault(); setDirection(0, 1); break;
          case 'ArrowLeft': case 'a': case 'A':
            e.preventDefault(); setDirection(-1, 0); break;
          case 'ArrowRight': case 'd': case 'D':
            e.preventDefault(); setDirection(1, 0); break;
        }
      });

      let touchStartX = 0;
      let touchStartY = 0;
      let touchActive = false;

      canvas.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
        e.preventDefault();
      }, { passive: false });

      canvas.addEventListener('touchend', (e) => {
        if (!touchActive) return;
        touchActive = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        const absX = Math.abs(dx);
        const absY = Math.abs(dy);
        const MIN_SWIPE = 18;
        if (absX < MIN_SWIPE && absY < MIN_SWIPE) {
          beginMovement();
          return;
        }
        if (absX > absY) {
          setDirection(dx > 0 ? 1 : -1, 0);
        } else {
          setDirection(0, dy > 0 ? 1 : -1);
        }
      }, { passive: false });

      canvas.addEventListener('touchmove', (e) => {
        if (touchActive) e.preventDefault();
      }, { passive: false });

      canvas.addEventListener('click', () => {
        beginMovement();
      });

      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;
        if (window.ArcadeSound) {
          window.ArcadeSound.stopMusic();
          window.ArcadeSound.play('game_over');
        }
        gameStarted = false;
        clearTimeout(tickHandle);

        finalScore = score;
        resultScore.textContent = String(finalScore);
        resultLength.textContent = String(snake.length);

        initBoxes.forEach(b => { b.value = ''; b.classList.remove('initial-box--filled'); });
        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMIT SCORE';
        initialsError.textContent = '';

        showState('result');
        setTimeout(() => initBoxes[0].focus(), 100);
      }

      initBoxes.forEach((box, idx) => {
        box.addEventListener('input', (e) => {
          let val = box.value.toUpperCase();
          val = val.replace(/[^A-Z]/g, '');
          box.value = val;

          if (val.length === 1) {
            box.classList.add('initial-box--filled');
            if (idx < initBoxes.length - 1) initBoxes[idx + 1].focus();
            else box.blur();
          } else {
            box.classList.remove('initial-box--filled');
          }
          updateSubmitState();
        });

        box.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && box.value === '' && idx > 0) {
            initBoxes[idx - 1].focus();
            initBoxes[idx - 1].value = '';
            initBoxes[idx - 1].classList.remove('initial-box--filled');
            updateSubmitState();
          }
          if (e.key === 'Enter' && !submitBtn.disabled) submitScore();
        });

        box.addEventListener('focus', () => box.select());
      });

      function getInitials() { return initBoxes.map(b => b.value).join('').toUpperCase(); }

      function updateSubmitState() {
        const initials = getInitials();
        submitBtn.disabled = !/^[A-Z]{3}$/.test(initials);
      }

      async function submitScore() {
        const initials = getInitials();
        if (!/^[A-Z]{3}$/.test(initials)) return;

        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMITTING...';
        initialsError.textContent = '';

        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initials, score: finalScore }),
          });

          const data = await res.json();

          if (!res.ok) {
            initialsError.textContent = data.error || 'Could not save score. Try different initials.';
            submitBtn.disabled = false;
            submitBtnText.textContent = 'SUBMIT SCORE';
            return;
          }

          lastSubmittedInitials = initials;
          lastSubmittedRank = data.madeLeaderboard ? data.rank : null;
          renderLeaderboard(data.scores || []);
        } catch (err) {
          initialsError.textContent = 'Network error. Try again in a sec.';
          submitBtn.disabled = false;
          submitBtnText.textContent = 'SUBMIT SCORE';
        }
      }

      submitBtn.addEventListener('click', submitScore);

      skipBtn.addEventListener('click', async () => {
        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`);
          const data = await res.json();
          lastSubmittedRank = null;
          lastSubmittedInitials = null;
          renderLeaderboard(data.scores || []);
        } catch {
          renderLeaderboard([]);
        }
      });

      function renderLeaderboard(scores) {
        if (lastSubmittedRank) {
          const ord = ordinalSuffix(lastSubmittedRank);
          rankEyebrow.textContent = 'YOU RANKED';
          rankNumber.textContent = `#${lastSubmittedRank}`;
          rankDetail.textContent = lastSubmittedRank === 1 ? '🏆 First place!' : `${ord} place on the leaderboard`;
          document.getElementById('rank-reveal').style.display = '';
        } else if (lastSubmittedInitials) {
          rankEyebrow.textContent = 'SCORE SUBMITTED';
          rankNumber.textContent = String(finalScore);
          rankDetail.textContent = "Didn't crack the top 10 — keep practicing!";
          document.getElementById('rank-reveal').style.display = '';
        } else {
          document.getElementById('rank-reveal').style.display = 'none';
        }

        leaderboardList.innerHTML = '';

        if (scores.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'leaderboard-empty';
          empty.textContent = 'No scores yet. Be the first.';
          leaderboardList.appendChild(empty);
        } else {
          scores.slice(0, 10).forEach((entry, idx) => {
            const li = document.createElement('li');
            const rank = idx + 1;
            const isMe = lastSubmittedRank === rank && lastSubmittedInitials === entry.initials;
            li.className = `leaderboard-row leaderboard-row--${rank} ${isMe ? 'leaderboard-row--me' : ''}`;
            li.innerHTML = `
              <span class="rank-num">${rank}</span>
              <span class="rank-initials">${escapeHtml(entry.initials)}</span>
              <span class="rank-score">${entry.score}</span>
              ${isMe ? '<span class="rank-you">← YOU</span>' : ''}
            `;
            leaderboardList.appendChild(li);
          });
        }

        configureShare();
        showState('leaderboard');
      }

      function ordinalSuffix(n) {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      }

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function configureShare() {
        const url = window.location.href;
        const text = `I devoured ${finalScore} bugs on ${GAME_NAME} at Jake's Arcade. Beat me?`;
        const fullShare = `${text} ${url}`;

        shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`;
        shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;

        if (navigator.share) {
          shareNative.style.display = '';
          shareNative.onclick = async () => {
            try { await navigator.share({ title: GAME_NAME + " — Jake's Arcade", text, url }); } catch (e) { }
          };
        }

        shareCopy.onclick = async () => {
          try {
            await navigator.clipboard.writeText(fullShare);
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = fullShare;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          }
        };
      }

      playAgainBtn.addEventListener('click', () => startGame());

      function showExitDialog() {
        exitDialog.hidden = false;
        setTimeout(() => exitCancel.focus(), 50);
      }
      function hideExitDialog() { exitDialog.hidden = true; }

      exitBtn.addEventListener('click', () => {
        if (gameRunning) showExitDialog();
        else window.location.href = EXIT_TO;
      });

      exitCancel.addEventListener('click', hideExitDialog);
      exitConfirm.addEventListener('click', () => {
        gameRunning = false;
        clearTimeout(tickHandle);
        window.location.href = EXIT_TO;
      });

      startBtn.addEventListener('click', startGame);
    </script>

