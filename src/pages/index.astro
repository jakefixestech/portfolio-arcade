    <script>
      // @ts-nocheck
      const GAME_SLUGS = [
        'whack-a-virus',
        'system-response',
        'component-match',
        'error-override',
        'cursor-crawl',
        'usb-defender',
        'bug-smasher',
      ];

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      async function fetchLeaderboard(slug) {
        try {
          const res = await fetch(`/api/scores/${slug}`);
          if (!res.ok) return [];
          const data = await res.json();
          return data.scores || [];
        } catch {
          return [];
        }
      }

      function renderLeaderboard(slug, scores) {
        const container = document.querySelector(`[data-leaderboard-for="${slug}"]`);
        if (!container) return;

        const top3 = scores.slice(0, 3);
        if (top3.length === 0) {
          container.innerHTML = '<p class="leaderboard-empty">No scores yet. Be the first.</p>';
          return;
        }

        const rows = top3.map((entry, i) => `
          <li class="leaderboard-row leaderboard-row--${i + 1}">
            <span class="rank-num">${i + 1}</span>
            <span class="rank-initials">${escapeHtml(entry.initials)}</span>
            <span class="rank-score">${entry.score}</span>
          </li>
        `).join('');

        container.innerHTML = `<ol class="leaderboard-list">${rows}</ol>`;
      }

      function computeChampion(allLeaderboards) {
        const playerPoints = {};
        allLeaderboards.forEach(scores => {
          scores.forEach((entry, rank) => {
            const points = rank + 1;
            if (!playerPoints[entry.initials]) {
              playerPoints[entry.initials] = { points: 0, gamesPlayed: 0 };
            }
            playerPoints[entry.initials].points += points;
            playerPoints[entry.initials].gamesPlayed += 1;
          });
        });

        const eligible = Object.entries(playerPoints).filter(([_, p]) => p.gamesPlayed >= 2);
        if (eligible.length === 0) return null;

        eligible.sort((a, b) => a[1].points - b[1].points);
        return {
          initials: eligible[0][0],
          points: eligible[0][1].points,
          gamesPlayed: eligible[0][1].gamesPlayed,
        };
      }

      function showChampion(champion) {
        if (!champion) return;
        const card = document.getElementById('champion-card');
        const empty = document.getElementById('champion-empty');
        const active = document.getElementById('champion-active');
        const initialsEl = document.getElementById('champ-initials-text');
        const pointsEl = document.getElementById('champ-points');
        const gamesEl = document.getElementById('champ-games');

        if (initialsEl) initialsEl.textContent = champion.initials;
        if (pointsEl) pointsEl.textContent = String(champion.points);
        if (gamesEl) gamesEl.textContent = String(champion.gamesPlayed);

        if (empty) empty.style.display = 'none';
        if (active) active.style.display = '';
        if (card) {
          card.classList.remove('champion-card--empty');
          card.classList.add('champion-card--active');
        }
      }

      async function init() {
        const all = await Promise.all(GAME_SLUGS.map(fetchLeaderboard));
        GAME_SLUGS.forEach((slug, i) => renderLeaderboard(slug, all[i]));
        const champ = computeChampion(all);
        showChampion(champ);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>

