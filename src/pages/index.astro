---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Enter The Arcade — Jake Fixes Tech</title>
    <meta name="description" content="Step through the portal. Eight hand-built browser games await inside Jake's Arcade." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800;900&family=Inter+Tight:wght@400;700;900&display=swap"
    />
  </head>

  <body>
    <script src="/arcade-sound.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (!window.ArcadeSound) return;
        window.ArcadeSound.injectToggleButton();
        window.ArcadeSound.attachMusicAutoStart('portal');

        // Hover sound on the portal button itself
        const portalBtn = document.getElementById('portal-btn');
        if (portalBtn) {
          portalBtn.addEventListener('mouseenter', () => window.ArcadeSound.play('portal_hover'));
        }
      });
    </script>
    <main class="stage" id="stage">

      <!-- ============================================ -->
      <!-- STAGE 1: THE PORTAL DOOR                     -->
      <!-- ============================================ -->
      <section class="portal-stage" id="portal-stage" aria-label="Enter the arcade">

        <!-- Starfield backdrop -->
        <div class="starfield" aria-hidden="true">
          <span class="star s1"></span><span class="star s2"></span>
          <span class="star s3"></span><span class="star s4"></span>
          <span class="star s5"></span><span class="star s6"></span>
          <span class="star s7"></span><span class="star s8"></span>
          <span class="star s9"></span><span class="star s10"></span>
          <span class="star s11"></span><span class="star s12"></span>
          <span class="star s13"></span><span class="star s14"></span>
          <span class="star s15"></span><span class="star s16"></span>
          <span class="star s17"></span><span class="star s18"></span>
          <span class="star s19"></span><span class="star s20"></span>
        </div>

        <!-- The portal itself -->
        <button
          type="button"
          class="portal"
          id="portal-btn"
          aria-label="Open the portal and enter the arcade"
        >
          <!-- Outer ring -->
          <span class="portal-ring portal-ring-1" aria-hidden="true"></span>
          <span class="portal-ring portal-ring-2" aria-hidden="true"></span>
          <span class="portal-ring portal-ring-3" aria-hidden="true"></span>

          <!-- Energy core -->
          <span class="portal-core" aria-hidden="true">
            <span class="portal-vortex"></span>
            <span class="portal-shimmer"></span>
          </span>

          <!-- Glyph text on the portal -->
          <span class="portal-label" aria-hidden="true">
            <span class="portal-label-line">CLICK</span>
            <span class="portal-label-line portal-label-main">TO ENTER</span>
          </span>

          <!-- Particle bursts on hover -->
          <span class="portal-particles" aria-hidden="true">
            <span class="particle p1"></span>
            <span class="particle p2"></span>
            <span class="particle p3"></span>
            <span class="particle p4"></span>
            <span class="particle p5"></span>
            <span class="particle p6"></span>
            <span class="particle p7"></span>
            <span class="particle p8"></span>
          </span>
        </button>

        <!-- Reduced-motion fallback button -->
        <a href="/lobby" class="enter-fallback" aria-label="Enter the lobby">
          ENTER →
        </a>
      </section>

      <!-- ============================================ -->
      <!-- STAGE 2: PRESENTATION SEQUENCE               -->
      <!-- ============================================ -->
      <section class="present-stage" id="present-stage" aria-hidden="true">
        <div class="present-text-wrap">
          <p class="present-line present-jake" id="line-jake">JAKE PRESENTS</p>
          <h1 class="present-line present-arcade" id="line-arcade">THE ARCADE</h1>
        </div>

        <p class="skip-hint" id="skip-hint">Click anywhere to skip</p>
      </section>

    </main>

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        -webkit-tap-highlight-color: transparent;
        tap-highlight-color: transparent;
      }

      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #000;
      }

      body {
        font-family: 'Inter Tight', system-ui, sans-serif;
        color: #fff;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .stage {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
      }

      /* ============================================ */
      /* PORTAL STAGE                                  */
      /* ============================================ */
      .portal-stage {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
          radial-gradient(ellipse at center, #0f0a2e 0%, #050214 50%, #000 100%);
        transition: opacity 0.4s ease-out;
      }

      .portal-stage.fading {
        opacity: 0;
        pointer-events: none;
      }

      /* When zooming, the stage background fades through bright then black
         in lockstep with the portal zoom, so nothing lingers as a ghost glow. */
      .portal-stage.zooming {
        animation: stage-zoom-bg 1.4s ease-out forwards;
      }

      @keyframes stage-zoom-bg {
        0% {
          background:
            radial-gradient(circle at center, #0f0a2e 0%, #050214 50%, #000 100%);
        }
        50% {
          background:
            radial-gradient(circle at center, #ffffff 0%, #67e8f9 12%, #1e1b4b 35%, #000 70%);
        }
        100% {
          background: #000;
        }
      }

      .portal-stage.zooming .starfield {
        animation: starfield-pull 1.4s cubic-bezier(0.7, 0, 0.85, 0) forwards;
      }

      @keyframes starfield-pull {
        0%   { transform: scale(1); opacity: 1; }
        100% { transform: scale(1.6); opacity: 0; }
      }

      /* Starfield */
      .starfield {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }

      .star {
        position: absolute;
        width: 2px;
        height: 2px;
        background: #fff;
        border-radius: 50%;
        box-shadow: 0 0 4px rgba(255, 255, 255, 0.6);
        animation: star-twinkle 3s ease-in-out infinite;
      }

      .s1  { top:  8%; left: 12%; animation-delay: 0s;   }
      .s2  { top: 14%; left: 78%; animation-delay: 0.4s; }
      .s3  { top: 22%; left: 35%; animation-delay: 1.1s; }
      .s4  { top: 28%; left: 88%; animation-delay: 1.7s; }
      .s5  { top: 36%; left:  6%; animation-delay: 0.2s; }
      .s6  { top: 42%; left: 92%; animation-delay: 2.3s; }
      .s7  { top: 50%; left: 18%; animation-delay: 0.9s; }
      .s8  { top: 58%; left: 82%; animation-delay: 1.5s; }
      .s9  { top: 64%; left:  9%; animation-delay: 2.1s; }
      .s10 { top: 72%; left: 86%; animation-delay: 0.6s; }
      .s11 { top: 80%; left: 24%; animation-delay: 1.3s; }
      .s12 { top: 86%; left: 70%; animation-delay: 1.9s; }
      .s13 { top: 92%; left: 14%; animation-delay: 0.5s; }
      .s14 { top: 18%; left: 56%; animation-delay: 2.5s; }
      .s15 { top: 32%; left: 64%; animation-delay: 0.8s; width: 3px; height: 3px; }
      .s16 { top: 46%; left: 44%; animation-delay: 1.6s; width: 1px; height: 1px; }
      .s17 { top: 60%; left: 38%; animation-delay: 2.0s; width: 3px; height: 3px; }
      .s18 { top: 74%; left: 56%; animation-delay: 0.3s; width: 1px; height: 1px; }
      .s19 { top: 88%; left: 48%; animation-delay: 1.4s; }
      .s20 { top: 12%; left: 26%; animation-delay: 2.2s; width: 3px; height: 3px; }

      @keyframes star-twinkle {
        0%, 100% { opacity: 0.3; }
        50%      { opacity: 1; }
      }

      /* The portal */
      .portal {
        position: relative;
        width: clamp(220px, 38vmin, 460px);
        height: clamp(220px, 38vmin, 460px);
        background: transparent;
        border: 0;
        cursor: pointer;
        padding: 0;
        outline-offset: 8px;
        animation: portal-breathe 4s ease-in-out infinite;
      }

      .portal:focus-visible {
        outline: 3px solid #67e8f9;
        outline-offset: 12px;
        border-radius: 50%;
      }

      @keyframes portal-breathe {
        0%, 100% { transform: scale(1); }
        50%      { transform: scale(1.025); }
      }

      .portal.opening { animation: none; }

      /* Outer rings */
      .portal-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        pointer-events: none;
      }

      .portal-ring-1 {
        border: 2px solid rgba(103, 232, 249, 0.7);
        box-shadow:
          0 0 30px rgba(103, 232, 249, 0.6),
          inset 0 0 30px rgba(103, 232, 249, 0.3);
        animation: ring-rotate 14s linear infinite;
      }

      .portal-ring-2 {
        inset: -8%;
        border: 1px dashed rgba(168, 85, 247, 0.5);
        animation: ring-rotate-rev 22s linear infinite;
      }

      .portal-ring-3 {
        inset: -16%;
        border: 1px solid rgba(103, 232, 249, 0.2);
        animation: ring-rotate 30s linear infinite;
      }

      @keyframes ring-rotate {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      @keyframes ring-rotate-rev {
        from { transform: rotate(0deg); }
        to   { transform: rotate(-360deg); }
      }

      /* Energy core */
      .portal-core {
        position: absolute;
        inset: 6%;
        border-radius: 50%;
        overflow: hidden;
        background:
          radial-gradient(circle at center,
            rgba(103, 232, 249, 0.95) 0%,
            rgba(59, 130, 246, 0.85) 25%,
            rgba(91, 33, 182, 0.7) 55%,
            rgba(15, 10, 46, 0.95) 90%);
        box-shadow:
          inset 0 0 60px rgba(168, 85, 247, 0.5),
          0 0 80px rgba(103, 232, 249, 0.4),
          0 0 140px rgba(168, 85, 247, 0.3);
      }

      .portal-vortex {
        position: absolute;
        inset: -25%;
        background:
          conic-gradient(
            from 0deg,
            transparent 0deg,
            rgba(255, 255, 255, 0.4) 30deg,
            transparent 60deg,
            rgba(103, 232, 249, 0.5) 90deg,
            transparent 120deg,
            rgba(168, 85, 247, 0.4) 180deg,
            transparent 220deg,
            rgba(255, 255, 255, 0.3) 270deg,
            transparent 310deg,
            transparent 360deg);
        animation: vortex-spin 8s linear infinite;
      }

      @keyframes vortex-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      .portal-shimmer {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 30% 30%,
            rgba(255, 255, 255, 0.6) 0%,
            transparent 30%);
        mix-blend-mode: screen;
        animation: shimmer-drift 6s ease-in-out infinite;
      }

      @keyframes shimmer-drift {
        0%, 100% { transform: translate(0, 0); }
        25%      { transform: translate(8%, -6%); }
        50%      { transform: translate(-6%, 8%); }
        75%      { transform: translate(-8%, -4%); }
      }

      /* Click → zoom INTO the portal */
      .portal.opening {
        animation: portal-zoom-in 1.4s cubic-bezier(0.7, 0, 0.85, 0) forwards;
        pointer-events: none;
      }

      @keyframes portal-zoom-in {
        0% {
          transform: scale(1);
          opacity: 1;
        }
        100% {
          transform: scale(18);
          opacity: 0;
        }
      }

      /* Rings fade out fast as we zoom — they'd look weird scaled up */
      .portal.opening .portal-ring {
        animation: ring-fade 0.4s ease-out forwards;
      }

      @keyframes ring-fade {
        to { opacity: 0; }
      }

      /* Core flares as we fly in */
      .portal.opening .portal-core {
        animation: core-flare 1.4s ease-out forwards;
      }

      @keyframes core-flare {
        0% {
          filter: brightness(1);
          box-shadow:
            inset 0 0 60px rgba(168, 85, 247, 0.5),
            0 0 80px rgba(103, 232, 249, 0.4),
            0 0 140px rgba(168, 85, 247, 0.3);
        }
        70% {
          filter: brightness(2.5);
          box-shadow:
            inset 0 0 200px rgba(255, 255, 255, 1),
            0 0 300px rgba(255, 255, 255, 0.95),
            0 0 500px rgba(103, 232, 249, 1);
        }
        100% {
          filter: brightness(4);
          box-shadow:
            inset 0 0 400px rgba(255, 255, 255, 1),
            0 0 600px rgba(255, 255, 255, 1),
            0 0 800px rgba(255, 255, 255, 1);
        }
      }

      /* Vortex spins faster as we approach */
      .portal.opening .portal-vortex {
        animation: vortex-spin 0.6s linear infinite;
      }

      /* The off-center shimmer would lag behind during the zoom and look
         like a weird oval — kill it fast on click. */
      .portal.opening .portal-shimmer {
        animation: shimmer-out 0.25s ease-out forwards;
      }

      @keyframes shimmer-out {
        to { opacity: 0; }
      }

      /* Portal label */
      .portal-label {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Orbitron', system-ui, sans-serif;
        color: #fff;
        text-shadow:
          0 0 8px rgba(103, 232, 249, 0.9),
          0 0 18px rgba(103, 232, 249, 0.6);
        letter-spacing: 0.25em;
        pointer-events: none;
        z-index: 2;
        transition: opacity 0.3s ease-out;
      }

      .portal-label-line {
        font-size: clamp(0.7rem, 1.6vmin, 0.95rem);
        font-weight: 600;
        opacity: 0.85;
      }

      .portal-label-main {
        font-size: clamp(1.1rem, 3vmin, 1.8rem);
        font-weight: 900;
        letter-spacing: 0.3em;
        margin-top: 0.4rem;
        animation: label-pulse 2s ease-in-out infinite;
      }

      @keyframes label-pulse {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.6; }
      }

      .portal.opening .portal-label { opacity: 0; }

      /* Hover state */
      .portal:hover .portal-ring-1,
      .portal:focus-visible .portal-ring-1 {
        box-shadow:
          0 0 50px rgba(103, 232, 249, 0.9),
          inset 0 0 50px rgba(103, 232, 249, 0.5);
      }

      .portal:hover .portal-core,
      .portal:focus-visible .portal-core {
        box-shadow:
          inset 0 0 80px rgba(168, 85, 247, 0.7),
          0 0 120px rgba(103, 232, 249, 0.6),
          0 0 200px rgba(168, 85, 247, 0.5);
      }

      .portal:hover .particle {
        animation-play-state: running;
      }

      /* Particles */
      .portal-particles {
        position: absolute;
        inset: -20%;
        pointer-events: none;
      }

      .particle {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 4px;
        height: 4px;
        background: #67e8f9;
        border-radius: 50%;
        box-shadow: 0 0 8px #67e8f9;
        opacity: 0;
        animation: particle-fly 2s ease-out infinite;
        animation-play-state: paused;
      }

      .p1 { animation-delay: 0s;    --angle:   0deg; }
      .p2 { animation-delay: 0.25s; --angle:  45deg; }
      .p3 { animation-delay: 0.5s;  --angle:  90deg; }
      .p4 { animation-delay: 0.75s; --angle: 135deg; }
      .p5 { animation-delay: 1s;    --angle: 180deg; }
      .p6 { animation-delay: 1.25s; --angle: 225deg; }
      .p7 { animation-delay: 1.5s;  --angle: 270deg; }
      .p8 { animation-delay: 1.75s; --angle: 315deg; }

      @keyframes particle-fly {
        0% {
          transform: translate(-50%, -50%) rotate(var(--angle)) translateY(0);
          opacity: 0;
        }
        15% { opacity: 1; }
        100% {
          transform: translate(-50%, -50%) rotate(var(--angle)) translateY(-180px);
          opacity: 0;
        }
      }

      /* Reduced-motion fallback button */
      .enter-fallback {
        position: absolute;
        bottom: 8%;
        left: 50%;
        transform: translateX(-50%);
        display: none;
        padding: 1rem 3rem;
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: 0.3em;
        color: #67e8f9;
        background: rgba(15, 10, 46, 0.8);
        border: 2px solid #67e8f9;
        border-radius: 4px;
        text-decoration: none;
        text-shadow: 0 0 8px rgba(103, 232, 249, 0.6);
      }

      .enter-fallback:hover,
      .enter-fallback:focus-visible {
        background: rgba(103, 232, 249, 0.15);
        outline: none;
      }

      /* ============================================ */
      /* PRESENTATION STAGE                            */
      /* ============================================ */
      .present-stage {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #000;
        opacity: 0;
        pointer-events: none;
        cursor: pointer;
      }

      .present-stage.active {
        opacity: 1;
        pointer-events: auto;
      }

      .present-text-wrap {
        position: relative;
        text-align: center;
        padding: 2rem;
        width: 100%;
        max-width: 90vw;
        min-height: clamp(3.5rem, 13vmin, 8rem);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .present-line {
        position: absolute;
        left: 0;
        right: 0;
        color: #fff;
        opacity: 0;
        line-height: 1;
      }

      .present-jake {
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: clamp(1.25rem, 4.5vmin, 2.5rem);
        font-weight: 600;
        letter-spacing: 0.4em;
        text-transform: uppercase;
      }

      .present-arcade {
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: clamp(2.75rem, 11vmin, 7rem);
        font-weight: 900;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        text-shadow:
          0 0 20px rgba(255, 255, 255, 0.4),
          0 0 50px rgba(103, 232, 249, 0.3);
      }

      .present-line.show-jake {
        animation: present-fade 2.4s ease-out forwards;
      }

      .present-line.show-arcade {
        animation: present-fade-arcade 3s ease-out forwards;
      }

      @keyframes present-fade {
        0%   { opacity: 0; transform: translateY(8px); }
        25%  { opacity: 1; transform: translateY(0); }
        80%  { opacity: 1; }
        100% { opacity: 0; }
      }

      @keyframes present-fade-arcade {
        0%   { opacity: 0; transform: scale(0.96); letter-spacing: 0.32em; }
        20%  { opacity: 1; transform: scale(1); letter-spacing: 0.18em; }
        85%  { opacity: 1; }
        100% { opacity: 1; }
      }

      .skip-hint {
        position: absolute;
        bottom: 2.5rem;
        left: 0;
        right: 0;
        text-align: center;
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.3em;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        opacity: 0;
        animation: skip-fade-in 0.6s ease-out 0.8s forwards;
        pointer-events: none;
      }

      @keyframes skip-fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      /* ============================================ */
      /* REDUCED MOTION                                */
      /* ============================================ */
      @media (prefers-reduced-motion: reduce) {
        .portal,
        .portal-ring-1,
        .portal-ring-2,
        .portal-ring-3,
        .portal-vortex,
        .portal-shimmer,
        .portal-label-main,
        .star,
        .particle {
          animation: none !important;
        }

        .portal { display: none; }

        .enter-fallback {
          display: inline-block;
        }
      }

      /* ============================================ */
      /* MOBILE TWEAKS                                 */
      /* ============================================ */
      @media (max-width: 600px) {
        .portal {
          width: clamp(220px, 70vmin, 320px);
          height: clamp(220px, 70vmin, 320px);
        }
        .portal-label-main {
          letter-spacing: 0.25em;
        }
      }

      /* ============================================ */
      /* WIDE SCREENS                                  */
      /* ============================================ */
      @media (min-width: 1600px) {
        .portal {
          width: clamp(380px, 32vmin, 540px);
          height: clamp(380px, 32vmin, 540px);
        }
      }
    </style>

    <script is:inline>
      (function () {
        const portalBtn = document.getElementById('portal-btn');
        const portalStage = document.getElementById('portal-stage');
        const presentStage = document.getElementById('present-stage');
        const lineJake = document.getElementById('line-jake');
        const lineArcade = document.getElementById('line-arcade');

        let entered = false;

        function go() {
          window.location.href = '/lobby';
        }

        function startSequence() {
          if (entered) return;
          entered = true;

          // Portal opening whoosh + stop portal background music
          if (window.ArcadeSound) {
            window.ArcadeSound.stopMusic();
            window.ArcadeSound.play('portal_whoosh');
          }

          // Trigger zoom-through
          portalBtn.classList.add('opening');
          portalStage.classList.add('zooming');

          // After we've zoomed all the way in, swap to presentation stage
          setTimeout(() => {
            portalStage.classList.add('fading');
            presentStage.classList.add('active');
            presentStage.setAttribute('aria-hidden', 'false');

            // "JAKE PRESENTS" appears
            setTimeout(() => {
              lineJake.classList.add('show-jake');
              if (window.ArcadeSound) window.ArcadeSound.play('portal_present');
            }, 200);

            // "THE ARCADE" appears as Jake fades
            setTimeout(() => {
              lineArcade.classList.add('show-arcade');
              if (window.ArcadeSound) window.ArcadeSound.play('portal_reveal');
            }, 2400);

            // Redirect after the arcade title finishes
            setTimeout(go, 5400);
          }, 1400);
        }

        // Click portal to start
        portalBtn.addEventListener('click', startSequence);

        // Click anywhere on the present stage to skip
        presentStage.addEventListener('click', go);

        // Allow keyboard activation of portal
        portalBtn.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            startSequence();
          }
        });
      })();
    </script>
  </body>
</html>
