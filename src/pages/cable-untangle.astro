    <script>
      // @ts-nocheck

      // ============================================================
      // CABLE UNTANGLE — Layered logic puzzle
      // ============================================================
      // Each cable has a layer (z-index). When two cables cross, the
      // higher-layer cable is drawn ON TOP — visually shown by leaving a
      // small gap in the lower cable at the crossing point.
      //
      // To extract a cable: it must be on TOP at every crossing it has.
      // (i.e. nothing visually crosses over it.)
      // Click the right cable -> it animates out, you score points.
      // Click a cable that has anything over it -> sparks fail, lose a life.
      // ============================================================

      const CANVAS_W = 400;
      const CANVAS_H = 500;
      const STARTING_LIVES = 3;
      const GAME_SLUG = 'cable-untangle';
      const GAME_NAME = 'Cable Untangle';
      const EXIT_TO = '/code-maze';

      const CABLE_COLORS = [
        { fill: '#3b82f6', stroke: '#1e3a8a' },
        { fill: '#f97316', stroke: '#9a3412' },
        { fill: '#4ade80', stroke: '#166534' },
        { fill: '#a855f7', stroke: '#581c87' },
        { fill: '#ef4444', stroke: '#7f1d1d' },
        { fill: '#22d3ee', stroke: '#155e75' },
        { fill: '#fbbf24', stroke: '#b45309' },
        { fill: '#ec4899', stroke: '#9d174d' },
      ];

      const JACK_W = 18;
      const JACK_H = 18;
      const JACK_LEFT_X = 22;
      const JACK_RIGHT_X = CANVAS_W - 22 - JACK_W;
      const RACK_TOP = 40;
      const RACK_BOTTOM = CANVAS_H - 30;

      // Crossing gap rendering
      const CROSSING_GAP = 14;     // pixels of gap on the underlying cable

      // === DOM refs ===
      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const stateLeaderboard = document.getElementById('state-leaderboard');
      const startBtn = document.getElementById('start-btn');
      const exitBtn = document.getElementById('exit-btn');
      const scoreDisplay = document.getElementById('score-display');
      const levelDisplay = document.getElementById('level-display');
      const livesDisplay = document.getElementById('lives-display');
      const canvas = document.getElementById('game-canvas');
      const ctx = canvas.getContext('2d');
      const boardOverlay = document.getElementById('board-overlay');
      const overlayText = document.getElementById('overlay-text');
      const levelBanner = document.getElementById('level-banner');
      const levelBannerTitle = document.getElementById('level-banner-title');
      const resultScore = document.getElementById('result-score');
      const resultLevel = document.getElementById('result-level');
      const initBoxes = [
        document.getElementById('init-1'),
        document.getElementById('init-2'),
        document.getElementById('init-3'),
      ];
      const initialsError = document.getElementById('initials-error');
      const submitBtn = document.getElementById('submit-btn');
      const submitBtnText = document.getElementById('submit-btn-text');
      const skipBtn = document.getElementById('skip-btn');
      const rankNumber = document.getElementById('rank-number');
      const rankEyebrow = document.getElementById('rank-eyebrow');
      const rankDetail = document.getElementById('rank-detail');
      const leaderboardList = document.getElementById('leaderboard-list');
      const playAgainBtn = document.getElementById('play-again-btn');
      const exitDialog = document.getElementById('exit-dialog');
      const exitCancel = document.getElementById('exit-cancel');
      const exitConfirm = document.getElementById('exit-confirm');
      const shareFb = document.getElementById('share-fb');
      const shareX = document.getElementById('share-x');
      const shareNative = document.getElementById('share-native');
      const shareCopy = document.getElementById('share-copy');
      const copyToast = document.getElementById('copy-toast');

      // === Game state ===
      let cables = [];
      let crossings = []; // [{ cableA, cableB, ptA, ptB, topId }]
      let extractAnim = null; // { cable, t, startTime }
      let failAnim = null;    // { cable, t, startTime, point }
      let particles = [];
      let hoveredCableId = null;
      let score = 0;
      let lives = STARTING_LIVES;
      let level = 1;
      let cablesRemaining = 0;
      let lastFrame = 0;
      let rafHandle = null;
      let gameRunning = false;
      let gameStarted = false;
      let levelTransition = false;
      let finalScore = 0;
      let finalLevel = 1;
      let lastSubmittedRank = null;
      let lastSubmittedInitials = null;

      function showState(name) {
        [stateIntro, statePlaying, stateResult, stateLeaderboard].forEach(s => s.classList.remove('state--active'));
        if (name === 'intro')       stateIntro.classList.add('state--active');
        if (name === 'playing')     statePlaying.classList.add('state--active');
        if (name === 'result')      stateResult.classList.add('state--active');
        if (name === 'leaderboard') stateLeaderboard.classList.add('state--active');
      }

      // ----------------------------
      // Math helpers
      // ----------------------------
      function bezierPoint(p0, p1, p2, t) {
        const u = 1 - t;
        return {
          x: u * u * p0.x + 2 * u * t * p1.x + t * t * p2.x,
          y: u * u * p0.y + 2 * u * t * p1.y + t * t * p2.y,
        };
      }

      function sampleBezier(p0, p1, p2, n = 60) {
        const pts = [];
        for (let i = 0; i <= n; i++) {
          pts.push(bezierPoint(p0, p1, p2, i / n));
        }
        return pts;
      }

      function dist(a, b) {
        const dx = a.x - b.x, dy = a.y - b.y;
        return Math.sqrt(dx * dx + dy * dy);
      }

      function distPointSeg(p, a, b) {
        const dx = b.x - a.x, dy = b.y - a.y;
        const len2 = dx * dx + dy * dy;
        if (len2 === 0) return dist(p, a);
        let t = ((p.x - a.x) * dx + (p.y - a.y) * dy) / len2;
        t = Math.max(0, Math.min(1, t));
        return Math.sqrt((p.x - (a.x + t * dx)) ** 2 + (p.y - (a.y + t * dy)) ** 2);
      }

      function distPointToPolyline(p, samples) {
        let min = Infinity;
        for (let i = 0; i < samples.length - 1; i++) {
          const d = distPointSeg(p, samples[i], samples[i + 1]);
          if (d < min) min = d;
        }
        return min;
      }

      // Segment intersection: returns intersection point or null
      function segIntersection(p1, p2, p3, p4) {
        const d1x = p2.x - p1.x, d1y = p2.y - p1.y;
        const d2x = p4.x - p3.x, d2y = p4.y - p3.y;
        const denom = d1x * d2y - d1y * d2x;
        if (Math.abs(denom) < 1e-9) return null;
        const t = ((p3.x - p1.x) * d2y - (p3.y - p1.y) * d2x) / denom;
        const u = ((p3.x - p1.x) * d1y - (p3.y - p1.y) * d1x) / denom;
        if (t > 0.01 && t < 0.99 && u > 0.01 && u < 0.99) {
          return { x: p1.x + t * d1x, y: p1.y + t * d1y };
        }
        return null;
      }

      // ----------------------------
      // Find all crossings between cables
      // For each pair of cables, find every point where their sample paths cross.
      // ----------------------------
      function computeCrossings() {
        crossings = [];
        for (let i = 0; i < cables.length; i++) {
          for (let j = i + 1; j < cables.length; j++) {
            const a = cables[i];
            const b = cables[j];
            const sa = a.samples;
            const sb = b.samples;
            for (let ia = 0; ia < sa.length - 1; ia++) {
              for (let ib = 0; ib < sb.length - 1; ib++) {
                const inter = segIntersection(sa[ia], sa[ia + 1], sb[ib], sb[ib + 1]);
                if (inter) {
                  // Determine which is on top: the higher layer wins
                  const topId = a.layer > b.layer ? a.id : b.id;
                  crossings.push({
                    aId: a.id,
                    bId: b.id,
                    pt: inter,
                    topId,
                  });
                }
              }
            }
          }
        }
      }

      // Is this cable free? (Has nothing crossing OVER it.)
      function isCableOnTop(cable) {
        for (const cr of crossings) {
          if (cr.aId === cable.id || cr.bId === cable.id) {
            if (cr.topId !== cable.id) return false; // something crossing over
          }
        }
        return true;
      }

      // ----------------------------
      // Level generation
      // ----------------------------
      function cableCountForLevel(lvl) {
        return Math.min(7, 3 + Math.floor((lvl - 1) / 1.2));
      }

      function generateLevel(lvl) {
        const numCables = cableCountForLevel(lvl);

        const jacksLeft = [];
        const jacksRight = [];
        const jackSpacing = (RACK_BOTTOM - RACK_TOP - JACK_H) / Math.max(1, numCables - 1);
        for (let i = 0; i < numCables; i++) {
          const y = RACK_TOP + i * jackSpacing;
          jacksLeft.push({ x: JACK_LEFT_X, y, w: JACK_W, h: JACK_H, side: 'left' });
          jacksRight.push({ x: JACK_RIGHT_X, y, w: JACK_W, h: JACK_H, side: 'right' });
        }

        // Shuffle right indices to make tangles
        const rightIdxOrder = [];
        for (let i = 0; i < numCables; i++) rightIdxOrder.push(i);
        for (let i = rightIdxOrder.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [rightIdxOrder[i], rightIdxOrder[j]] = [rightIdxOrder[j], rightIdxOrder[i]];
        }
        // Force a swap so we always have crossings
        if (numCables >= 2) {
          let identity = true;
          for (let i = 0; i < numCables; i++) if (rightIdxOrder[i] !== i) { identity = false; break; }
          if (identity) [rightIdxOrder[0], rightIdxOrder[1]] = [rightIdxOrder[1], rightIdxOrder[0]];
        }

        // Random layer order — each cable gets a unique layer (0 = bottom)
        const layerOrder = [];
        for (let i = 0; i < numCables; i++) layerOrder.push(i);
        for (let i = layerOrder.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [layerOrder[i], layerOrder[j]] = [layerOrder[j], layerOrder[i]];
        }

        cables = [];
        for (let i = 0; i < numCables; i++) {
          const left = jacksLeft[i];
          const right = jacksRight[rightIdxOrder[i]];
          const color = CABLE_COLORS[i % CABLE_COLORS.length];

          const p0 = { x: left.x + left.w, y: left.y + left.h / 2 };
          const p2 = { x: right.x, y: right.y + right.h / 2 };

          const wobble = 60 + lvl * 6;
          const cp = {
            x: (p0.x + p2.x) / 2 + (Math.random() - 0.5) * 30,
            y: (p0.y + p2.y) / 2 + (Math.random() - 0.5) * wobble,
          };
          cp.y = Math.max(RACK_TOP + 20, Math.min(RACK_BOTTOM - 20, cp.y));

          cables.push({
            id: i,
            color,
            jackLeft: left,
            jackRight: right,
            p0, cp, p2,
            samples: sampleBezier(p0, cp, p2, 60),
            layer: layerOrder[i],
            extracted: false,
          });
        }

        computeCrossings();
        cablesRemaining = numCables;
      }

      function startLevel(lvl) {
        generateLevel(lvl);
        levelDisplay.textContent = String(lvl);
        levelTransition = true;
        levelBannerTitle.textContent = `LEVEL ${lvl}`;
        levelBanner.classList.add('level-banner--show');
        setTimeout(() => {
          levelBanner.classList.remove('level-banner--show');
          levelTransition = false;
        }, 1100);
      }

      function startGame() {
        score = 0;
        lives = STARTING_LIVES;
        level = 1;
        gameRunning = true;
        gameStarted = false;
        lastFrame = 0;
        extractAnim = null;
        failAnim = null;
        particles = [];

        scoreDisplay.textContent = '0';
        levelDisplay.textContent = '1';
        livesDisplay.textContent = String(lives);

        startLevel(level);
        showState('playing');
        boardOverlay.classList.remove('board-overlay--hidden');
        overlayText.textContent = 'Tap the top cable to start';

        draw();
        cancelAnimationFrame(rafHandle);
        rafHandle = requestAnimationFrame(loop);
      }

      function beginGameplay() {
        if (gameStarted || !gameRunning) return;
        gameStarted = true;
        boardOverlay.classList.add('board-overlay--hidden');
      }

      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;
        if (window.ArcadeSound) {
          window.ArcadeSound.stopMusic();
          window.ArcadeSound.play('game_over');
        }
        gameStarted = false;
        cancelAnimationFrame(rafHandle);

        finalScore = score;
        finalLevel = level;
        resultScore.textContent = String(finalScore);
        resultLevel.textContent = `Level ${finalLevel}`;

        initBoxes.forEach(b => { b.value = ''; b.classList.remove('initial-box--filled'); });
        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMIT SCORE';
        initialsError.textContent = '';

        showState('result');
        setTimeout(() => initBoxes[0].focus(), 100);
      }

      // ----------------------------
      // Input
      // ----------------------------
      function getCanvasPoint(clientX, clientY) {
        const rect = canvas.getBoundingClientRect();
        return {
          x: (clientX - rect.left) * (CANVAS_W / rect.width),
          y: (clientY - rect.top) * (CANVAS_H / rect.height),
        };
      }

      function findCableAtPoint(p) {
        // Topmost (highest layer) cable that's within hit distance
        let best = null;
        let bestLayer = -1;
        for (const c of cables) {
          if (c.extracted) continue;
          if (distPointToPolyline(p, c.samples) < 12) {
            if (c.layer > bestLayer) {
              bestLayer = c.layer;
              best = c;
            }
          }
        }
        return best;
      }

      function tryExtract(cable) {
        if (extractAnim || failAnim || levelTransition) return;
        if (isCableOnTop(cable)) {
          // Success animation
          extractAnim = {
            cable,
            startTime: performance.now(),
            duration: 600,
          };
          if (window.ArcadeSound) window.ArcadeSound.play('cable_pull');
        } else {
          if (window.ArcadeSound) window.ArcadeSound.play('cable_spark');
          // Failure: find the crossing where another cable is on top of this one
          const blockingCrossing = crossings.find(cr =>
            (cr.aId === cable.id || cr.bId === cable.id) && cr.topId !== cable.id
          );
          const failPt = blockingCrossing ? blockingCrossing.pt : { x: cable.cp.x, y: cable.cp.y };

          // Spark particles
          for (let i = 0; i < 18; i++) {
            const ang = Math.random() * Math.PI * 2;
            const speed = 80 + Math.random() * 130;
            particles.push({
              x: failPt.x,
              y: failPt.y,
              vx: Math.cos(ang) * speed,
              vy: Math.sin(ang) * speed - 60,
              t: 0,
              color: '#ef4444',
            });
          }

          failAnim = {
            cable,
            startTime: performance.now(),
            duration: 500,
            point: failPt,
          };

          lives--;
          livesDisplay.textContent = String(lives);
          if (lives <= 0) {
            // Wait for fail anim to play briefly then end
            setTimeout(() => endGame(), 400);
          }
        }
      }

      canvas.addEventListener('mousemove', (e) => {
        if (!gameRunning) return;
        const p = getCanvasPoint(e.clientX, e.clientY);
        const c = findCableAtPoint(p);
        hoveredCableId = c ? c.id : null;
        canvas.style.cursor = c ? 'pointer' : 'default';
      });

      canvas.addEventListener('mouseleave', () => {
        hoveredCableId = null;
        canvas.style.cursor = 'default';
      });

      canvas.addEventListener('click', (e) => {
        if (!gameRunning) return;
        beginGameplay();
        const p = getCanvasPoint(e.clientX, e.clientY);
        const c = findCableAtPoint(p);
        if (c) tryExtract(c);
      });

      canvas.addEventListener('touchstart', (e) => {
        if (!gameRunning) return;
        if (e.touches.length !== 1) return;
        e.preventDefault();
        beginGameplay();
        const p = getCanvasPoint(e.touches[0].clientX, e.touches[0].clientY);
        const c = findCableAtPoint(p);
        if (c) tryExtract(c);
      }, { passive: false });

      // ----------------------------
      // Game loop
      // ----------------------------
      function loop(timestamp) {
        if (!gameRunning) return;
        if (lastFrame === 0) lastFrame = timestamp;
        const dt = Math.min(0.05, (timestamp - lastFrame) / 1000);
        lastFrame = timestamp;

        // Particles
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.t += dt;
          p.x += p.vx * dt;
          p.y += p.vy * dt;
          p.vy += 220 * dt;
          if (p.t > 1) particles.splice(i, 1);
        }

        // Extract animation progress
        if (extractAnim) {
          const elapsed = performance.now() - extractAnim.startTime;
          extractAnim.t = Math.min(1, elapsed / extractAnim.duration);
          if (extractAnim.t >= 1) {
            // Cable is gone — actually remove it
            const cable = extractAnim.cable;
            const baseScore = 50 + cablesRemaining * 5;
            score += baseScore;
            scoreDisplay.textContent = String(score);

            // Endpoint particles
            const endPt = Math.random() < 0.5 ? cable.p0 : cable.p2;
            for (let i = 0; i < 12; i++) {
              const ang = Math.random() * Math.PI * 2;
              const speed = 60 + Math.random() * 90;
              particles.push({
                x: endPt.x,
                y: endPt.y,
                vx: Math.cos(ang) * speed,
                vy: Math.sin(ang) * speed - 30,
                t: 0,
                color: cable.color.fill,
              });
            }
            cables = cables.filter(c => c.id !== cable.id);
            computeCrossings(); // recompute now that cable is gone
            cablesRemaining--;
            extractAnim = null;

            if (cablesRemaining <= 0) {
              const bonus = 100 + lives * 25 + level * 10;
              score += bonus;
              scoreDisplay.textContent = String(score);
              if (window.ArcadeSound) window.ArcadeSound.play('level_up');
              setTimeout(() => {
                level++;
                startLevel(level);
              }, 500);
            }
          }
        }

        // Fail animation progress
        if (failAnim) {
          const elapsed = performance.now() - failAnim.startTime;
          failAnim.t = Math.min(1, elapsed / failAnim.duration);
          if (failAnim.t >= 1) failAnim = null;
        }

        draw();
        rafHandle = requestAnimationFrame(loop);
      }

      // ----------------------------
      // Drawing
      // ----------------------------
      function draw() {
        ctx.fillStyle = '#02100a';
        ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

        // Subtle vertical lines
        ctx.strokeStyle = 'rgba(74, 222, 128, 0.06)';
        ctx.lineWidth = 1;
        for (let x = 50; x < CANVAS_W; x += 50) {
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, CANVAS_H);
          ctx.stroke();
        }

        // Rack frame
        ctx.strokeStyle = 'rgba(74, 222, 128, 0.3)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(JACK_LEFT_X - 6, RACK_TOP - 6);
        ctx.lineTo(CANVAS_W - JACK_LEFT_X + 6, RACK_TOP - 6);
        ctx.moveTo(JACK_LEFT_X - 6, RACK_BOTTOM + JACK_H + 6);
        ctx.lineTo(CANVAS_W - JACK_LEFT_X + 6, RACK_BOTTOM + JACK_H + 6);
        ctx.stroke();

        // Title strip
        ctx.fillStyle = 'rgba(74, 222, 128, 0.15)';
        ctx.fillRect(JACK_LEFT_X - 6, RACK_TOP - 22, CANVAS_W - 2 * (JACK_LEFT_X - 6), 12);
        ctx.fillStyle = '#86efac';
        ctx.font = 'bold 9px JetBrains Mono, monospace';
        ctx.textAlign = 'center';
        ctx.fillText('— SERVER RACK —', CANVAS_W / 2, RACK_TOP - 13);

        // Draw jacks (use cable's jack info, but only for non-extracted cables)
        for (const c of cables) {
          drawJack(c.jackLeft, c, 'left');
          drawJack(c.jackRight, c, 'right');
        }

        // Draw cables in layer order (bottom first, top last). For each cable,
        // draw its full path EXCEPT mask out gaps where higher-layer cables cross over it.
        const sorted = [...cables].sort((a, b) => a.layer - b.layer);
        for (const c of sorted) {
          drawCable(c);
        }

        // Particles
        for (const p of particles) {
          const alpha = Math.max(0, 1 - p.t);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = alpha;
          ctx.beginPath();
          ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;

        // Failure visual: shake on the cable that failed
        // (Already handled via the spark particles above; could add red flash here.)
      }

      function drawJack(j, cable, side) {
        ctx.fillStyle = '#0f1c14';
        ctx.fillRect(j.x, j.y, j.w, j.h);
        ctx.strokeStyle = '#4ade80';
        ctx.lineWidth = 1.5;
        ctx.strokeRect(j.x + 0.75, j.y + 0.75, j.w - 1.5, j.h - 1.5);

        const cx = j.x + j.w / 2;
        const cy = j.y + j.h / 2;

        // If this cable is being extracted, we may dim/remove the plug indicator
        const beingExtracted = extractAnim && extractAnim.cable.id === cable.id;
        const t = beingExtracted ? extractAnim.t : 0;

        ctx.fillStyle = cable.color.fill;
        ctx.globalAlpha = beingExtracted ? Math.max(0, 1 - t * 1.3) : 1;
        ctx.beginPath();
        ctx.arc(cx, cy, 3.5, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      function drawCable(c) {
        const isHovered = hoveredCableId === c.id;
        const beingExtracted = extractAnim && extractAnim.cable.id === c.id;
        const beingFailed = failAnim && failAnim.cable.id === c.id;

        // Compute draw alpha for extract animation (cable shrinks/fades out)
        let alpha = 1;
        let liftOffset = 0;
        if (beingExtracted) {
          alpha = 1 - extractAnim.t;
          liftOffset = -extractAnim.t * 30; // lift visually as it extracts
        }

        // Get sample path
        const samples = c.samples;
        if (samples.length < 2) return;

        // Find all crossings where ANOTHER cable is on top of this cable
        // We'll skip drawing this cable in a small range around each such crossing
        // to create the "gap" visual.
        const overCrossings = [];
        for (const cr of crossings) {
          if (cr.aId === c.id || cr.bId === c.id) {
            if (cr.topId !== c.id) {
              overCrossings.push(cr.pt);
            }
          }
        }

        // For each crossing point, find the nearest segment index in our samples
        // and mark a range of segments to skip
        const skipSegments = new Set();
        for (const cp of overCrossings) {
          // Find closest sample to crossing point
          let bestIdx = 0;
          let bestDist = Infinity;
          for (let i = 0; i < samples.length; i++) {
            const d = dist(samples[i], cp);
            if (d < bestDist) { bestDist = d; bestIdx = i; }
          }
          // Determine how many segments around bestIdx to skip based on cable
          // angle and CROSSING_GAP. Approximate: just skip ~2-3 segments either side.
          const halfSpan = 2;
          for (let i = bestIdx - halfSpan; i <= bestIdx + halfSpan; i++) {
            if (i >= 0 && i < samples.length - 1) skipSegments.add(i);
          }
        }

        // Build segment groups to draw (consecutive non-skipped segments)
        const groups = [];
        let currentGroup = null;
        for (let i = 0; i < samples.length - 1; i++) {
          if (skipSegments.has(i)) {
            if (currentGroup) {
              groups.push(currentGroup);
              currentGroup = null;
            }
          } else {
            if (!currentGroup) currentGroup = { start: i, end: i };
            else currentGroup.end = i;
          }
        }
        if (currentGroup) groups.push(currentGroup);

        ctx.save();
        if (liftOffset !== 0) ctx.translate(0, liftOffset);
        ctx.globalAlpha = alpha;

        // Hover halo (drawn under cable)
        if (isHovered && !beingExtracted) {
          ctx.strokeStyle = c.color.fill + '88';
          ctx.lineWidth = 14;
          ctx.lineCap = 'round';
          ctx.lineJoin = 'round';
          for (const g of groups) {
            ctx.beginPath();
            ctx.moveTo(samples[g.start].x, samples[g.start].y);
            for (let i = g.start + 1; i <= g.end + 1; i++) {
              ctx.lineTo(samples[i].x, samples[i].y);
            }
            ctx.stroke();
          }
        }

        // Failure red flash
        const failFlash = beingFailed && Math.floor(failAnim.t * 8) % 2 === 0;

        // Outer stroke (darker outline)
        ctx.strokeStyle = failFlash ? '#7f1d1d' : c.color.stroke;
        ctx.lineWidth = 8;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        for (const g of groups) {
          ctx.beginPath();
          ctx.moveTo(samples[g.start].x, samples[g.start].y);
          for (let i = g.start + 1; i <= g.end + 1; i++) {
            ctx.lineTo(samples[i].x, samples[i].y);
          }
          ctx.stroke();
        }

        // Inner stroke (brighter)
        ctx.strokeStyle = failFlash ? '#ef4444' : c.color.fill;
        ctx.lineWidth = 5;
        for (const g of groups) {
          ctx.beginPath();
          ctx.moveTo(samples[g.start].x, samples[g.start].y);
          for (let i = g.start + 1; i <= g.end + 1; i++) {
            ctx.lineTo(samples[i].x, samples[i].y);
          }
          ctx.stroke();
        }

        // Highlight stripe
        ctx.strokeStyle = 'rgba(255,255,255,0.35)';
        ctx.lineWidth = 1.5;
        for (const g of groups) {
          ctx.beginPath();
          ctx.moveTo(samples[g.start].x, samples[g.start].y);
          for (let i = g.start + 1; i <= g.end + 1; i++) {
            ctx.lineTo(samples[i].x, samples[i].y);
          }
          ctx.stroke();
        }

        // Draw small "rounded ends" at the gap boundaries (so the gaps look like
        // the cable goes UNDER the other cable rather than just being broken)
        if (groups.length > 1) {
          ctx.fillStyle = c.color.stroke;
          for (const g of groups) {
            // Cap at start (if not the first sample)
            if (g.start > 0) {
              ctx.beginPath();
              ctx.arc(samples[g.start].x, samples[g.start].y, 4, 0, Math.PI * 2);
              ctx.fill();
            }
            // Cap at end (if not the last sample)
            if (g.end < samples.length - 2) {
              ctx.beginPath();
              ctx.arc(samples[g.end + 1].x, samples[g.end + 1].y, 4, 0, Math.PI * 2);
              ctx.fill();
            }
          }
        }

        ctx.globalAlpha = 1;
        ctx.restore();
      }

      // ----------------------------
      // Score submission boilerplate
      // ----------------------------
      initBoxes.forEach((box, idx) => {
        box.addEventListener('input', () => {
          let val = box.value.toUpperCase().replace(/[^A-Z]/g, '');
          box.value = val;
          if (val.length === 1) {
            box.classList.add('initial-box--filled');
            if (idx < initBoxes.length - 1) initBoxes[idx + 1].focus();
            else box.blur();
          } else {
            box.classList.remove('initial-box--filled');
          }
          updateSubmitState();
        });
        box.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && box.value === '' && idx > 0) {
            initBoxes[idx - 1].focus();
            initBoxes[idx - 1].value = '';
            initBoxes[idx - 1].classList.remove('initial-box--filled');
            updateSubmitState();
          }
          if (e.key === 'Enter' && !submitBtn.disabled) submitScore();
        });
        box.addEventListener('focus', () => box.select());
      });

      function getInitials() { return initBoxes.map(b => b.value).join('').toUpperCase(); }
      function updateSubmitState() {
        submitBtn.disabled = !/^[A-Z]{3}$/.test(getInitials());
      }

      async function submitScore() {
        const initials = getInitials();
        if (!/^[A-Z]{3}$/.test(initials)) return;

        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMITTING...';
        initialsError.textContent = '';

        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initials, score: finalScore }),
          });
          const data = await res.json();
          if (!res.ok) {
            initialsError.textContent = data.error || 'Could not save score. Try different initials.';
            submitBtn.disabled = false;
            submitBtnText.textContent = 'SUBMIT SCORE';
            return;
          }
          lastSubmittedInitials = initials;
          lastSubmittedRank = data.madeLeaderboard ? data.rank : null;
          renderLeaderboard(data.scores || []);
        } catch (err) {
          initialsError.textContent = 'Network error. Try again in a sec.';
          submitBtn.disabled = false;
          submitBtnText.textContent = 'SUBMIT SCORE';
        }
      }

      submitBtn.addEventListener('click', submitScore);

      skipBtn.addEventListener('click', async () => {
        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`);
          const data = await res.json();
          lastSubmittedRank = null;
          lastSubmittedInitials = null;
          renderLeaderboard(data.scores || []);
        } catch {
          renderLeaderboard([]);
        }
      });

      function renderLeaderboard(scores) {
        if (lastSubmittedRank) {
          const ord = ordinalSuffix(lastSubmittedRank);
          rankEyebrow.textContent = 'YOU RANKED';
          rankNumber.textContent = `#${lastSubmittedRank}`;
          rankDetail.textContent = lastSubmittedRank === 1 ? '🏆 First place!' : `${ord} place on the leaderboard`;
          document.getElementById('rank-reveal').style.display = '';
        } else if (lastSubmittedInitials) {
          rankEyebrow.textContent = 'SCORE SUBMITTED';
          rankNumber.textContent = String(finalScore);
          rankDetail.textContent = "Didn't crack the top 10 — keep practicing!";
          document.getElementById('rank-reveal').style.display = '';
        } else {
          document.getElementById('rank-reveal').style.display = 'none';
        }

        leaderboardList.innerHTML = '';
        if (scores.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'leaderboard-empty';
          empty.textContent = 'No scores yet. Be the first.';
          leaderboardList.appendChild(empty);
        } else {
          scores.slice(0, 10).forEach((entry, idx) => {
            const li = document.createElement('li');
            const rank = idx + 1;
            const isMe = lastSubmittedRank === rank && lastSubmittedInitials === entry.initials;
            li.className = `leaderboard-row leaderboard-row--${rank} ${isMe ? 'leaderboard-row--me' : ''}`;
            li.innerHTML = `
              <span class="rank-num">${rank}</span>
              <span class="rank-initials">${escapeHtml(entry.initials)}</span>
              <span class="rank-score">${entry.score}</span>
              ${isMe ? '<span class="rank-you">← YOU</span>' : ''}
            `;
            leaderboardList.appendChild(li);
          });
        }
        configureShare();
        showState('leaderboard');
      }

      function ordinalSuffix(n) {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      }

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function configureShare() {
        const url = window.location.href;
        const text = `I scored ${finalScore} on ${GAME_NAME} at Jake's Arcade. Beat me?`;
        const fullShare = `${text} ${url}`;

        shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`;
        shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;

        if (navigator.share) {
          shareNative.style.display = '';
          shareNative.onclick = async () => {
            try { await navigator.share({ title: GAME_NAME + " — Jake's Arcade", text, url }); } catch (e) { }
          };
        }

        shareCopy.onclick = async () => {
          try {
            await navigator.clipboard.writeText(fullShare);
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = fullShare;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          }
        };
      }

      playAgainBtn.addEventListener('click', () => startGame());

      function showExitDialog() {
        exitDialog.hidden = false;
        setTimeout(() => exitCancel.focus(), 50);
      }
      function hideExitDialog() { exitDialog.hidden = true; }

      exitBtn.addEventListener('click', () => {
        if (gameRunning) showExitDialog();
        else window.location.href = EXIT_TO;
      });

      exitCancel.addEventListener('click', hideExitDialog);
      exitConfirm.addEventListener('click', () => {
        gameRunning = false;
        cancelAnimationFrame(rafHandle);
        window.location.href = EXIT_TO;
      });

      startBtn.addEventListener('click', startGame);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !exitDialog.hidden) {
          hideExitDialog();
        }
      });
    </script>

