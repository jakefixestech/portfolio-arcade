<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Packet Sort — Jake's Arcade</title>
    <meta name="description" content="Route packets to the matching color port before they hit the floor. Speed-based sorting at Jake's Arcade." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Packet Sort — Jake's Arcade" />
    <meta property="og:description" content="Route packets to the matching color port before they hit the floor." />
    <meta property="og:url" content="https://arcade.jakefixestech.com/packet-sort" />
    <meta property="og:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />
    <meta property="og:site_name" content="Jake's Arcade" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Packet Sort — Jake's Arcade" />
    <meta name="twitter:description" content="Route packets to the matching color port." />
    <meta name="twitter:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=swap"
      />
    </noscript>
  </head>

  <body>
    <main class="page">

      <button id="exit-btn" type="button" class="exit-btn" aria-label="Back to Speed Lab">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 9 6 L 4 12 L 9 18 M 4 12 L 19 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="exit-btn-label">SPEED LAB</span>
      </button>

      <a href="/" class="portal-return" aria-label="Return to the portal">
        <span class="portal-return-icon" aria-hidden="true">↻</span>
        <span class="portal-return-label">PORTAL</span>
      </a>

      <div class="motes" aria-hidden="true">
        {Array.from({ length: 18 }).map((_, i) => (
          <span class={`mote mt-${i + 1}`}></span>
        ))}
      </div>

      <section class="game-section">

        <!-- ARCADE CABINET WRAPPER (desktop only via CSS) -->
        <div class="cabinet-shell">

          <div class="shell-marquee" aria-hidden="true">
            <div class="shell-marquee-bulbs">
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span>
            </div>
            <p class="shell-marquee-title">PACKET SORT</p>
          </div>

          <div class="cabinet-body">

            <div class="shell-side shell-side-l" aria-hidden="true">
              <div class="shell-side-art">
                <span class="side-decor side-d1"></span>
                <span class="side-decor side-d2"></span>
                <span class="side-decor side-d3"></span>
              </div>
            </div>
            <div class="shell-side shell-side-r" aria-hidden="true">
              <div class="shell-side-art">
                <span class="side-decor side-d1"></span>
                <span class="side-decor side-d2"></span>
                <span class="side-decor side-d3"></span>
              </div>
            </div>

            <div class="shell-bezel">

              <!-- ============================== -->
              <!-- GAME                            -->
              <!-- ============================== -->
              <div class="game-wrap">
                <div class="game-header" aria-hidden="true">
                  <div class="game-dots">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                  </div>
                  <div class="game-title">jake@arcade: ~/packet-sort</div>
                </div>

                <div class="game-body">

                  <!-- INTRO -->
                  <div id="state-intro" class="state state--active">
                    <div class="intro-icon" aria-hidden="true">
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <rect x="6" y="8" width="68" height="64" rx="3" fill="#0e1b29" stroke="#22d3ee" stroke-width="2"/>
                        <rect x="14" y="14" width="14" height="10" rx="1" fill="#22d3ee" stroke="#0891b2" stroke-width="1"/>
                        <circle cx="21" cy="19" r="1.5" fill="#0e1b29"/>
                        <rect x="32" y="26" width="14" height="10" rx="1" fill="#fbbf24" stroke="#b45309" stroke-width="1"/>
                        <circle cx="39" cy="31" r="1.5" fill="#0e1b29"/>
                        <rect x="50" y="22" width="14" height="10" rx="1" fill="#4ade80" stroke="#15803d" stroke-width="1"/>
                        <circle cx="57" cy="27" r="1.5" fill="#0e1b29"/>
                        <line x1="6" y1="50" x2="74" y2="50" stroke="rgba(34, 211, 238, 0.3)" stroke-width="1" stroke-dasharray="2 2"/>
                        <rect x="10" y="56" width="18" height="14" rx="1" fill="rgba(34, 211, 238, 0.15)" stroke="#22d3ee" stroke-width="1.5"/>
                        <rect x="31" y="56" width="18" height="14" rx="1" fill="rgba(251, 191, 36, 0.15)" stroke="#fbbf24" stroke-width="1.5"/>
                        <rect x="52" y="56" width="18" height="14" rx="1" fill="rgba(74, 222, 128, 0.15)" stroke="#4ade80" stroke-width="1.5"/>
                        <circle cx="19" cy="63" r="2" fill="#22d3ee"/>
                        <circle cx="40" cy="63" r="2" fill="#fbbf24"/>
                        <circle cx="61" cy="63" r="2" fill="#4ade80"/>
                      </svg>
                    </div>

                    <h1 class="intro-title">Packet Sort</h1>
                    <p class="intro-text">
                      Route <strong class="cyan-strong">packets</strong> to the matching color port — fast.
                    </p>
                    <p class="intro-hint">
                      <strong>Click</strong> or <strong>tap</strong> a port when its color packet falls. <strong>Keys 1/2/3/4</strong> also work. Miss 5 packets = game over.
                    </p>

                    <button id="start-btn" class="primary-btn" type="button">
                      <span>PLAY</span>
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M 7 5 L 7 19 L 19 12 Z" fill="currentColor" />
                      </svg>
                    </button>
                  </div>

                  <!-- PLAYING -->
                  <div id="state-playing" class="state">
                    <div class="hud">
                      <div class="hud-item">
                        <span class="hud-label">SCORE</span>
                        <span class="hud-value" id="score-display">0</span>
                      </div>
                      <div class="hud-item">
                        <span class="hud-label">WAVE</span>
                        <span class="hud-value" id="wave-display">1</span>
                      </div>
                      <div class="hud-item">
                        <span class="hud-label">LIVES</span>
                        <span class="hud-value" id="lives-display">5</span>
                      </div>
                    </div>

                    <div class="board-wrap">
                      <canvas
                        id="game-canvas"
                        class="game-canvas"
                        width="400"
                        height="500"
                        aria-label="Packet Sort game board"
                      ></canvas>
                      <div id="board-overlay" class="board-overlay">
                        <p class="overlay-text" id="overlay-text">Tap a port to start</p>
                      </div>
                      <div id="wave-banner" class="wave-banner" aria-hidden="true">
                        <p class="wave-banner-eyebrow">INCOMING</p>
                        <p class="wave-banner-title" id="wave-banner-title">WAVE 1</p>
                      </div>
                    </div>

                    <p class="game-hint">Click/tap a port · Keys 1–4 · Catch packets before they hit the floor</p>
                  </div>

                  <!-- RESULT -->
                  <div id="state-result" class="state">
                    <div class="result-icon" aria-hidden="true">
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="40" cy="40" r="36" fill="#ef4444" />
                        <path d="M 28 28 L 52 52 M 52 28 L 28 52" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" />
                      </svg>
                    </div>

                    <h2 class="result-title">PACKETS LOST</h2>
                    <p class="result-text">
                      Network failure.<br>
                      Final score: <strong id="result-score">0</strong><br>
                      Reached: <strong id="result-wave">Wave 1</strong>
                    </p>

                    <div class="initials-section">
                      <p class="initials-label">ENTER YOUR INITIALS</p>
                      <div class="initials-inputs" role="group" aria-label="Three letter initials">
                        <input type="text" class="initial-box" id="init-1" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="First letter" />
                        <input type="text" class="initial-box" id="init-2" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Second letter" />
                        <input type="text" class="initial-box" id="init-3" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Third letter" />
                      </div>

                      <p class="initials-error" id="initials-error" aria-live="polite"></p>

                      <button id="submit-btn" class="primary-btn" type="button" disabled>
                        <span id="submit-btn-text">SUBMIT SCORE</span>
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>

                      <button id="skip-btn" class="ghost-btn" type="button">Skip — don't save my score</button>
                    </div>
                  </div>

                  <!-- LEADERBOARD -->
                  <div id="state-leaderboard" class="state">
                    <div id="rank-reveal" class="rank-reveal">
                      <p class="rank-eyebrow" id="rank-eyebrow">YOU RANKED</p>
                      <p class="rank-number" id="rank-number">#1</p>
                      <p class="rank-detail" id="rank-detail">on the leaderboard</p>
                    </div>

                    <div class="leaderboard-wrap">
                      <p class="leaderboard-title">TOP 10 — PACKET SORT</p>
                      <ol id="leaderboard-list" class="leaderboard"></ol>
                    </div>

                    <div class="share-section">
                      <p class="share-eyebrow">SHARE YOUR SCORE</p>
                      <div class="share-buttons">
                        <a id="share-fb" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to Facebook">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 12 2 C 6.477 2 2 6.477 2 12 C 2 17 5.66 21.13 10.44 21.88 L 10.44 14.89 L 7.9 14.89 L 7.9 12 L 10.44 12 L 10.44 9.8 C 10.44 7.29 11.93 5.91 14.22 5.91 C 15.31 5.91 16.45 6.1 16.45 6.1 L 16.45 8.56 L 15.19 8.56 C 13.95 8.56 13.56 9.33 13.56 10.12 L 13.56 12 L 16.34 12 L 15.89 14.89 L 13.56 14.89 L 13.56 21.88 C 18.34 21.13 22 17 22 12 C 22 6.477 17.523 2 12 2 Z" fill="currentColor" />
                          </svg>
                        </a>
                        <a id="share-x" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to X">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 18.244 2.25 L 21.552 2.25 L 14.325 10.51 L 22.827 21.75 L 16.17 21.75 L 10.956 14.933 L 4.99 21.75 L 1.68 21.75 L 9.41 12.915 L 1.254 2.25 L 8.08 2.25 L 12.793 8.481 L 18.244 2.25 Z M 17.083 19.77 L 18.916 19.77 L 7.084 4.126 L 5.117 4.126 L 17.083 19.77 Z" fill="currentColor" />
                          </svg>
                        </a>
                        <button id="share-native" type="button" class="share-btn" aria-label="Share via system share menu" style="display:none">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 12 3 L 12 16 M 7 8 L 12 3 L 17 8 M 4 14 L 4 20 a 1 1 0 0 0 1 1 L 19 21 a 1 1 0 0 0 1 -1 L 20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </button>
                        <button id="share-copy" type="button" class="share-btn" aria-label="Copy link to clipboard">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="8" y="8" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
                            <path d="M 5 15 L 4 15 a 1 1 0 0 1 -1 -1 L 3 4 a 1 1 0 0 1 1 -1 L 14 3 a 1 1 0 0 1 1 1 L 15 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                          </svg>
