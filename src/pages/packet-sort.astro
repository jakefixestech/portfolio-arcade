                    </div>
                  </div>

                </div>
              </div>
              <!-- ============================== -->

            </div>

            <div class="shell-controls" aria-hidden="true">
              <span class="shell-joystick">
                <span class="shell-joystick-base"></span>
                <span class="shell-joystick-stick"></span>
                <span class="shell-joystick-ball"></span>
              </span>
              <span class="shell-buttons">
                <span class="shell-btn shell-btn-cyan"></span>
                <span class="shell-btn shell-btn-yellow"></span>
                <span class="shell-btn shell-btn-green"></span>
                <span class="shell-btn shell-btn-magenta"></span>
              </span>
            </div>

            <div class="shell-coin" aria-hidden="true">
              <span class="shell-coin-slot"></span>
              <span class="shell-coin-label">25¢ INSERT COIN</span>
            </div>

          </div>

          <span class="shell-floor-shadow" aria-hidden="true"></span>

        </div>

      </section>

      <div id="exit-dialog" class="dialog" role="dialog" aria-modal="true" aria-labelledby="exit-dialog-title" hidden>
        <div class="dialog-backdrop"></div>
        <div class="dialog-content">
          <h2 id="exit-dialog-title" class="dialog-title">Exit mid-game?</h2>
          <p class="dialog-text">Your score won't be saved if you leave now.</p>
          <div class="dialog-buttons">
            <button id="exit-cancel" type="button" class="ghost-btn">Keep playing</button>
            <button id="exit-confirm" type="button" class="danger-btn">Exit anyway</button>
          </div>
        </div>
      </div>
    </main>

    <script>
      // @ts-nocheck

      // === Config ===
      const CANVAS_W = 400;
      const CANVAS_H = 500;
      const PACKET_W = 50;
      const PACKET_H = 30;
      const PORT_H = 70;          // height of port rectangles at bottom
      const PORT_GAP = 6;         // visual gap between ports
      const FLOOR_Y = CANVAS_H - PORT_H;
      const STARTING_LIVES = 5;
      const GAME_SLUG = 'packet-sort';
      const GAME_NAME = 'Packet Sort';
      const EXIT_TO = '/speed-lab';

      // Color definitions: 4 channels, used progressively as waves advance
      const ALL_COLORS = [
        { key: 'cyan',    fill: '#22d3ee', stroke: '#0891b2', name: 'CYAN'    },
        { key: 'yellow',  fill: '#fbbf24', stroke: '#b45309', name: 'YELLOW'  },
        { key: 'green',   fill: '#4ade80', stroke: '#15803d', name: 'GREEN'   },
        { key: 'magenta', fill: '#ec4899', stroke: '#9d174d', name: 'MAGENTA' },
      ];

      // Wave config: number of ports/colors active and packet fall speed (px/sec)
      function waveConfig(wave) {
        // Waves 1–3: 3 colors. Waves 4+: 4 colors.
        const numColors = wave <= 3 ? 3 : 4;
        // Fall speed ramps from ~120px/s up to ~360px/s
        const baseSpeed = 110 + (wave - 1) * 22;
        const maxSpeed = Math.min(baseSpeed, 380);
        // Packets per wave (more as you advance)
        const packetsInWave = 8 + (wave - 1) * 2;
        // Spawn interval shrinks
        const spawnIntervalMs = Math.max(420, 1100 - (wave - 1) * 70);
        return { numColors, fallSpeed: maxSpeed, packetsInWave, spawnIntervalMs };
      }

      // === DOM refs ===
      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const stateLeaderboard = document.getElementById('state-leaderboard');
      const startBtn = document.getElementById('start-btn');
      const exitBtn = document.getElementById('exit-btn');
      const scoreDisplay = document.getElementById('score-display');
      const waveDisplay = document.getElementById('wave-display');
      const livesDisplay = document.getElementById('lives-display');
      const canvas = document.getElementById('game-canvas');
      const ctx = canvas.getContext('2d');
      const boardOverlay = document.getElementById('board-overlay');
      const overlayText = document.getElementById('overlay-text');
      const waveBanner = document.getElementById('wave-banner');
      const waveBannerTitle = document.getElementById('wave-banner-title');
      const resultScore = document.getElementById('result-score');
      const resultWave = document.getElementById('result-wave');
      const initBoxes = [
        document.getElementById('init-1'),
        document.getElementById('init-2'),
        document.getElementById('init-3'),
      ];
      const initialsError = document.getElementById('initials-error');
      const submitBtn = document.getElementById('submit-btn');
      const submitBtnText = document.getElementById('submit-btn-text');
      const skipBtn = document.getElementById('skip-btn');
      const rankNumber = document.getElementById('rank-number');
      const rankEyebrow = document.getElementById('rank-eyebrow');
      const rankDetail = document.getElementById('rank-detail');
      const leaderboardList = document.getElementById('leaderboard-list');
      const playAgainBtn = document.getElementById('play-again-btn');
      const exitDialog = document.getElementById('exit-dialog');
      const exitCancel = document.getElementById('exit-cancel');
      const exitConfirm = document.getElementById('exit-confirm');
      const shareFb = document.getElementById('share-fb');
      const shareX = document.getElementById('share-x');
      const shareNative = document.getElementById('share-native');
      const shareCopy = document.getElementById('share-copy');
      const copyToast = document.getElementById('copy-toast');

      // === Game state ===
      let activeColors = [];           // subset of ALL_COLORS for current wave
      let packets = [];                // {x, y, vy, color} active
      let pulses = [];                 // {portIdx, t, kind: 'good'|'bad'}
      let score = 0;
      let lives = STARTING_LIVES;
      let wave = 1;
      let packetsSpawnedThisWave = 0;
      let packetsResolvedThisWave = 0;
      let lastSpawnAt = 0;
      let lastFrameAt = 0;
      let rafHandle = null;
      let gameRunning = false;
      let gameStarted = false;
      let waveTransition = false;     // pause spawning while showing banner
      let comboHits = 0;              // consecutive correct catches
      let finalScore = 0;
      let finalWave = 1;
      let lastSubmittedRank = null;
      let lastSubmittedInitials = null;

      function showState(name) {
        [stateIntro, statePlaying, stateResult, stateLeaderboard].forEach(s => s.classList.remove('state--active'));
        if (name === 'intro')       stateIntro.classList.add('state--active');
        if (name === 'playing')     statePlaying.classList.add('state--active');
        if (name === 'result')      stateResult.classList.add('state--active');
        if (name === 'leaderboard') stateLeaderboard.classList.add('state--active');
      }

      function getPortRects() {
        const cfg = waveConfig(wave);
        const n = cfg.numColors;
        const totalGap = (n + 1) * PORT_GAP;
        const portW = (CANVAS_W - totalGap) / n;
        const rects = [];
        for (let i = 0; i < n; i++) {
          const x = PORT_GAP + i * (portW + PORT_GAP);
          rects.push({ x, y: FLOOR_Y, w: portW, h: PORT_H, color: activeColors[i] });
        }
        return rects;
      }

      function spawnPacket() {
        const cfg = waveConfig(wave);
        const colorIdx = Math.floor(Math.random() * cfg.numColors);
        const color = activeColors[colorIdx];
        const x = Math.random() * (CANVAS_W - PACKET_W);
        packets.push({
          x,
          y: -PACKET_H,
          vy: cfg.fallSpeed,
          color,
        });
        packetsSpawnedThisWave++;
      }

      function startWave(w) {
        wave = w;
        const cfg = waveConfig(wave);
        activeColors = ALL_COLORS.slice(0, cfg.numColors);
        packetsSpawnedThisWave = 0;
        packetsResolvedThisWave = 0;
        comboHits = 0;
        waveDisplay.textContent = String(wave);

        // Show wave banner briefly
        waveTransition = true;
        waveBannerTitle.textContent = `WAVE ${wave}`;
        waveBanner.classList.add('wave-banner--show');
        setTimeout(() => {
          waveBanner.classList.remove('wave-banner--show');
          waveTransition = false;
          lastSpawnAt = performance.now();
        }, 1400);
      }

      function startGame() {
        score = 0;
        lives = STARTING_LIVES;
        wave = 1;
        packets = [];
        pulses = [];
        gameRunning = true;
        gameStarted = false;
        lastSpawnAt = 0;
        lastFrameAt = 0;
        comboHits = 0;

        scoreDisplay.textContent = '0';
        livesDisplay.textContent = String(lives);

        showState('playing');
        boardOverlay.classList.remove('board-overlay--hidden');
        overlayText.textContent = 'Tap a port to start';

        startWave(1);
        draw();

        cancelAnimationFrame(rafHandle);
        rafHandle = requestAnimationFrame(loop);
      }

      function beginGameplay() {
        if (gameStarted || !gameRunning) return;
        gameStarted = true;
        boardOverlay.classList.add('board-overlay--hidden');
        lastSpawnAt = performance.now();
      }

      function loop(timestamp) {
        if (!gameRunning) return;
        if (!gameStarted) {
          rafHandle = requestAnimationFrame(loop);
          return;
        }
        if (lastFrameAt === 0) lastFrameAt = timestamp;
        const dt = (timestamp - lastFrameAt) / 1000; // seconds
        lastFrameAt = timestamp;

        const cfg = waveConfig(wave);

        // Spawn
        if (!waveTransition && packetsSpawnedThisWave < cfg.packetsInWave) {
          if (timestamp - lastSpawnAt >= cfg.spawnIntervalMs) {
            spawnPacket();
            lastSpawnAt = timestamp;
          }
        }

        // Fall
        for (const p of packets) {
          p.y += p.vy * dt;
        }

        // Floor: any packet whose bottom edge hits FLOOR_Y has been "missed"
        // (player should have caught it before it landed)
        for (let i = packets.length - 1; i >= 0; i--) {
          const p = packets[i];
          if (p.y + PACKET_H >= FLOOR_Y) {
            // Find which port it landed on
            const portRects = getPortRects();
            const cx = p.x + PACKET_W / 2;
            let landedPort = null;
            for (const pr of portRects) {
              if (cx >= pr.x && cx <= pr.x + pr.w) {
                landedPort = pr;
                break;
              }
            }
            // If packet's color matches the port it landed on, count as correct catch
            if (landedPort && landedPort.color.key === p.color.key) {
              comboHits++;
              const bonus = Math.min(comboHits * 5, 50);
              score += 10 + bonus;
              scoreDisplay.textContent = String(score);
              const portIdx = portRects.indexOf(landedPort);
              pulses.push({ portIdx, t: 0, kind: 'good' });
            } else {
              // Wrong port or fell into a gap = miss
              comboHits = 0;
              lives--;
              livesDisplay.textContent = String(lives);
              if (landedPort) {
                const portIdx = portRects.indexOf(landedPort);
                pulses.push({ portIdx, t: 0, kind: 'bad' });
              }
              if (lives <= 0) {
                packets.splice(i, 1);
                packetsResolvedThisWave++;
                endGame();
                return;
              }
            }
            packets.splice(i, 1);
            packetsResolvedThisWave++;
          }
        }

        // Pulse animations
        for (let i = pulses.length - 1; i >= 0; i--) {
          pulses[i].t += dt;
          if (pulses[i].t > 0.45) pulses.splice(i, 1);
        }

        // Wave complete?
        if (!waveTransition && packetsSpawnedThisWave >= cfg.packetsInWave && packets.length === 0) {
          // Bonus for clearing a wave + lives remaining
          score += 50 + (lives * 10);
          scoreDisplay.textContent = String(score);
          startWave(wave + 1);
        }

        draw();
        rafHandle = requestAnimationFrame(loop);
      }

      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;
        gameStarted = false;
        cancelAnimationFrame(rafHandle);

        finalScore = score;
        finalWave = wave;
        resultScore.textContent = String(finalScore);
        resultWave.textContent = `Wave ${finalWave}`;

        initBoxes.forEach(b => { b.value = ''; b.classList.remove('initial-box--filled'); });
        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMIT SCORE';
        initialsError.textContent = '';

        showState('result');
        setTimeout(() => initBoxes[0].focus(), 100);
      }

      // === Drawing ===
      function draw() {
        // Background
        ctx.fillStyle = '#050d18';
        ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

        // Vertical conveyor lines
        ctx.strokeStyle = 'rgba(34, 211, 238, 0.08)';
        ctx.lineWidth = 1;
        for (let x = 40; x < CANVAS_W; x += 40) {
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, FLOOR_Y);
          ctx.stroke();
        }

        // Floor line (port boundary)
        ctx.strokeStyle = 'rgba(34, 211, 238, 0.4)';
        ctx.lineWidth = 1.5;
        ctx.setLineDash([4, 4]);
        ctx.beginPath();
        ctx.moveTo(0, FLOOR_Y);
        ctx.lineTo(CANVAS_W, FLOOR_Y);
        ctx.stroke();
        ctx.setLineDash([]);

        // Ports
        const portRects = getPortRects();
        portRects.forEach((pr, i) => {
          const pulse = pulses.find(pu => pu.portIdx === i);
          drawPort(pr, i, pulse);
        });

        // Packets
        for (const p of packets) {
          drawPacket(p);
        }
      }

      function drawPort(pr, idx, pulse) {
        const c = pr.color;
        ctx.save();

        // Backplate
        ctx.fillStyle = c.fill + '22';
        ctx.fillRect(pr.x, pr.y, pr.w, pr.h);

        // Pulse highlight
        if (pulse) {
          const t = Math.min(1, pulse.t / 0.45);
          const fade = 1 - t;
          if (pulse.kind === 'good') {
            ctx.fillStyle = `rgba(74, 222, 128, ${0.5 * fade})`;
          } else {
            ctx.fillStyle = `rgba(239, 68, 68, ${0.55 * fade})`;
          }
          ctx.fillRect(pr.x, pr.y, pr.w, pr.h);
        }

        // Border
        ctx.strokeStyle = c.fill;
        ctx.lineWidth = 2;
        ctx.strokeRect(pr.x + 1, pr.y + 1, pr.w - 2, pr.h - 2);

        // Inner glow line
        ctx.strokeStyle = c.fill + '60';
        ctx.lineWidth = 1;
        ctx.strokeRect(pr.x + 5, pr.y + 5, pr.w - 10, pr.h - 10);

        // Color indicator dot in center
        const cx = pr.x + pr.w / 2;
        const cy = pr.y + pr.h / 2 + 3;
        ctx.fillStyle = c.fill;
        ctx.beginPath();
        ctx.arc(cx, cy, 8, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = c.stroke;
        ctx.lineWidth = 1.5;
        ctx.stroke();

        // Port number / key hint above the dot
        ctx.fillStyle = c.fill;
        ctx.font = 'bold 11px JetBrains Mono, monospace';
        ctx.textAlign = 'center';
        ctx.fillText(`[${idx + 1}]`, cx, pr.y + 16);

        ctx.restore();
      }

      function drawPacket(p) {
        const c = p.color;
        ctx.save();
        // Body
        ctx.fillStyle = c.fill;
        ctx.fillRect(p.x, p.y, PACKET_W, PACKET_H);
        // Highlight
        ctx.fillStyle = 'rgba(255,255,255,0.2)';
        ctx.fillRect(p.x, p.y, PACKET_W, 4);
        ctx.fillRect(p.x, p.y, 4, PACKET_H);
        // Shadow
        ctx.fillStyle = 'rgba(0,0,0,0.25)';
        ctx.fillRect(p.x + PACKET_W - 4, p.y, 4, PACKET_H);
        ctx.fillRect(p.x, p.y + PACKET_H - 4, PACKET_W, 4);
        // Border
        ctx.strokeStyle = c.stroke;
        ctx.lineWidth = 1.5;
        ctx.strokeRect(p.x + 0.75, p.y + 0.75, PACKET_W - 1.5, PACKET_H - 1.5);
        // Center dot (color tag)
        const cx = p.x + PACKET_W / 2;
        const cy = p.y + PACKET_H / 2;
        ctx.fillStyle = '#0e1b29';
        ctx.beginPath();
        ctx.arc(cx, cy, 4, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      // === Input ===
      function handlePortHit(portIdx) {
        if (!gameRunning) return;
        beginGameplay();
        const portRects = getPortRects();
        if (portIdx < 0 || portIdx >= portRects.length) return;
        const pr = portRects[portIdx];
        const portColor = pr.color;

        // Find lowest packet matching this port's color (the most urgent one)
        let bestIdx = -1;
        let bestY = -Infinity;
        for (let i = 0; i < packets.length; i++) {
          if (packets[i].color.key === portColor.key && packets[i].y > bestY) {
            // Only allow catching if packet is in lower half of board
            if (packets[i].y > FLOOR_Y * 0.35) {
              bestY = packets[i].y;
              bestIdx = i;
            }
          }
        }

        if (bestIdx >= 0) {
          // Catch! Score scales with how close to floor (skill bonus)
          const p = packets[bestIdx];
          const closeness = (p.y + PACKET_H) / FLOOR_Y; // 0..1
          const proximityBonus = Math.round(closeness * 15);
          comboHits++;
          const comboBonus = Math.min(comboHits * 5, 50);
          score += 10 + proximityBonus + comboBonus;
          scoreDisplay.textContent = String(score);
          packets.splice(bestIdx, 1);
          packetsResolvedThisWave++;
          pulses.push({ portIdx, t: 0, kind: 'good' });
        } else {
          // Wrong color tap or no packet to catch = penalty
          comboHits = 0;
          score = Math.max(0, score - 5);
          scoreDisplay.textContent = String(score);
          pulses.push({ portIdx, t: 0, kind: 'bad' });
        }
      }

      // Canvas click/tap handler
      canvas.addEventListener('click', (e) => {
        if (!gameRunning) return;
        const rect = canvas.getBoundingClientRect();
        const x = (e.clientX - rect.left) * (CANVAS_W / rect.width);
        const y = (e.clientY - rect.top) * (CANVAS_H / rect.height);
        // Only register clicks in port zone
        if (y < FLOOR_Y) return;
        const portRects = getPortRects();
        for (let i = 0; i < portRects.length; i++) {
          const pr = portRects[i];
          if (x >= pr.x && x <= pr.x + pr.w) {
            handlePortHit(i);
            break;
          }
        }
      });

      canvas.addEventListener('touchstart', (e) => {
        if (!gameRunning) return;
        if (e.touches.length !== 1) return;
        e.preventDefault();
        const rect = canvas.getBoundingClientRect();
        const x = (e.touches[0].clientX - rect.left) * (CANVAS_W / rect.width);
        const y = (e.touches[0].clientY - rect.top) * (CANVAS_H / rect.height);
        if (y < FLOOR_Y) return;
        const portRects = getPortRects();
        for (let i = 0; i < portRects.length; i++) {
          const pr = portRects[i];
          if (x >= pr.x && x <= pr.x + pr.w) {
            handlePortHit(i);
            break;
          }
        }
      }, { passive: false });

      // Keyboard 1-4
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !exitDialog.hidden) {
          hideExitDialog();
          return;
        }
        if (!statePlaying.classList.contains('state--active')) return;
        if (['1','2','3','4'].includes(e.key)) {
          e.preventDefault();
          const portIdx = parseInt(e.key, 10) - 1;
          handlePortHit(portIdx);
        }
      });

      // === Result/score submission ===
      initBoxes.forEach((box, idx) => {
        box.addEventListener('input', () => {
          let val = box.value.toUpperCase().replace(/[^A-Z]/g, '');
          box.value = val;
          if (val.length === 1) {
            box.classList.add('initial-box--filled');
            if (idx < initBoxes.length - 1) initBoxes[idx + 1].focus();
            else box.blur();
          } else {
            box.classList.remove('initial-box--filled');
          }
          updateSubmitState();
        });
        box.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && box.value === '' && idx > 0) {
            initBoxes[idx - 1].focus();
            initBoxes[idx - 1].value = '';
            initBoxes[idx - 1].classList.remove('initial-box--filled');
            updateSubmitState();
          }
          if (e.key === 'Enter' && !submitBtn.disabled) submitScore();
        });
        box.addEventListener('focus', () => box.select());
      });

      function getInitials() { return initBoxes.map(b => b.value).join('').toUpperCase(); }
      function updateSubmitState() {
        submitBtn.disabled = !/^[A-Z]{3}$/.test(getInitials());
      }

      async function submitScore() {
        const initials = getInitials();
        if (!/^[A-Z]{3}$/.test(initials)) return;

        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMITTING...';
        initialsError.textContent = '';

        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initials, score: finalScore }),
          });
          const data = await res.json();
          if (!res.ok) {
            initialsError.textContent = data.error || 'Could not save score. Try different initials.';
            submitBtn.disabled = false;
            submitBtnText.textContent = 'SUBMIT SCORE';
            return;
          }
          lastSubmittedInitials = initials;
          lastSubmittedRank = data.madeLeaderboard ? data.rank : null;
          renderLeaderboard(data.scores || []);
        } catch (err) {
          initialsError.textContent = 'Network error. Try again in a sec.';
          submitBtn.disabled = false;
          submitBtnText.textContent = 'SUBMIT SCORE';
        }
      }

      submitBtn.addEventListener('click', submitScore);

      skipBtn.addEventListener('click', async () => {
        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`);
          const data = await res.json();
          lastSubmittedRank = null;
          lastSubmittedInitials = null;
          renderLeaderboard(data.scores || []);
        } catch {
          renderLeaderboard([]);
        }
      });

      function renderLeaderboard(scores) {
        if (lastSubmittedRank) {
          const ord = ordinalSuffix(lastSubmittedRank);
          rankEyebrow.textContent = 'YOU RANKED';
          rankNumber.textContent = `#${lastSubmittedRank}`;
          rankDetail.textContent = lastSubmittedRank === 1 ? '🏆 First place!' : `${ord} place on the leaderboard`;
          document.getElementById('rank-reveal').style.display = '';
        } else if (lastSubmittedInitials) {
          rankEyebrow.textContent = 'SCORE SUBMITTED';
          rankNumber.textContent = String(finalScore);
          rankDetail.textContent = "Didn't crack the top 10 — keep practicing!";
          document.getElementById('rank-reveal').style.display = '';
        } else {
          document.getElementById('rank-reveal').style.display = 'none';
        }

        leaderboardList.innerHTML = '';
        if (scores.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'leaderboard-empty';
          empty.textContent = 'No scores yet. Be the first.';
          leaderboardList.appendChild(empty);
        } else {
          scores.slice(0, 10).forEach((entry, idx) => {
            const li = document.createElement('li');
            const rank = idx + 1;
            const isMe = lastSubmittedRank === rank && lastSubmittedInitials === entry.initials;
            li.className = `leaderboard-row leaderboard-row--${rank} ${isMe ? 'leaderboard-row--me' : ''}`;
            li.innerHTML = `
              <span class="rank-num">${rank}</span>
              <span class="rank-initials">${escapeHtml(entry.initials)}</span>
              <span class="rank-score">${entry.score}</span>
              ${isMe ? '<span class="rank-you">← YOU</span>' : ''}
            `;
            leaderboardList.appendChild(li);
          });
        }
        configureShare();
        showState('leaderboard');
      }

      function ordinalSuffix(n) {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      }

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function configureShare() {
        const url = window.location.href;
        const text = `I sorted ${finalScore} packets on ${GAME_NAME} at Jake's Arcade. Beat me?`;
        const fullShare = `${text} ${url}`;

        shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`;
        shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;

        if (navigator.share) {
          shareNative.style.display = '';
          shareNative.onclick = async () => {
            try { await navigator.share({ title: GAME_NAME + " — Jake's Arcade", text, url }); } catch (e) { }
          };
        }

        shareCopy.onclick = async () => {
          try {
            await navigator.clipboard.writeText(fullShare);
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = fullShare;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          }
        };
      }

      playAgainBtn.addEventListener('click', () => startGame());

      function showExitDialog() {
        exitDialog.hidden = false;
        setTimeout(() => exitCancel.focus(), 50);
      }
      function hideExitDialog() { exitDialog.hidden = true; }

      exitBtn.addEventListener('click', () => {
        if (gameRunning) showExitDialog();
        else window.location.href = EXIT_TO;
      });

      exitCancel.addEventListener('click', hideExitDialog);
      exitConfirm.addEventListener('click', () => {
        gameRunning = false;
        cancelAnimationFrame(rafHandle);
        window.location.href = EXIT_TO;
      });

      startBtn.addEventListener('click', startGame);
    </script>

