        gap: 0.6rem;
        justify-content: center;
        margin-bottom: 1rem;
      }

      .initial-box {
        width: 3.5rem;
        height: 4rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 2rem;
        font-weight: 700;
        text-align: center;
        background: rgba(15, 23, 42, 0.8);
        color: #fbbf24;
        border: 2px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.5rem;
        text-transform: uppercase;
        outline: none;
        transition: all 0.15s ease;
        caret-color: #fbbf24;
      }

      .initial-box:focus {
        border-color: #fbbf24;
        background: rgba(15, 23, 42, 1);
        box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.15);
      }

      .initial-box--filled {
        border-color: rgba(251, 191, 36, 0.7);
        background: rgba(251, 191, 36, 0.08);
      }

      .initials-error {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: #fca5a5;
        min-height: 1.2rem;
        margin-bottom: 1rem;
      }

      #skip-btn { margin-top: 1rem; width: 100%; }

      .rank-reveal {
        text-align: center;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.06));
        border: 1px solid rgba(251, 191, 36, 0.3);
        border-radius: 0.75rem;
        animation: rank-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes rank-pop {
        0%   { transform: scale(0.7); opacity: 0; }
        70%  { transform: scale(1.05); opacity: 1; }
        100% { transform: scale(1); }
      }

      .rank-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        color: #fbbf24;
        letter-spacing: 0.25em;
        margin-bottom: 0.5rem;
      }

      .rank-number {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(3rem, 9vw, 4.5rem);
        font-weight: 700;
        line-height: 1;
        background: linear-gradient(135deg, #fbbf24, #fde68a, #fbbf24);
        background-size: 200% 200%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gold-shimmer 3.5s ease-in-out infinite;
        margin-bottom: 0.5rem;
      }

      @keyframes gold-shimmer {
        0%, 100% { background-position: 0% 50%; }
        50%      { background-position: 100% 50%; }
      }

      .rank-detail {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 1rem;
        color: #d1d5db;
      }

      .leaderboard-wrap { width: 100%; margin-bottom: 2rem; }

      .leaderboard-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.2em;
        text-align: center;
        margin-bottom: 0.85rem;
        padding-bottom: 0.65rem;
        border-bottom: 1px dashed rgba(96, 165, 250, 0.25);
      }

      .leaderboard {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .leaderboard-row {
        display: grid;
        grid-template-columns: 2.2rem 1fr auto auto;
        align-items: center;
        gap: 0.85rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.95rem;
        color: #cbd5e1;
        padding: 0.55rem 0.85rem;
        background: rgba(15, 23, 42, 0.4);
        border-radius: 0.4rem;
        border: 1px solid transparent;
      }

      .leaderboard-row--1 { color: #fbbf24; font-weight: 700; }
      .leaderboard-row--2 { color: #cbd5e1; font-weight: 600; }
      .leaderboard-row--3 { color: #d97706; font-weight: 600; }

      .leaderboard-row--me {
        background: rgba(251, 191, 36, 0.15);
        border-color: rgba(251, 191, 36, 0.6);
        box-shadow: 0 0 20px rgba(251, 191, 36, 0.25);
        animation: me-pulse 2s ease-in-out infinite;
      }

      @keyframes me-pulse {
        0%, 100% { box-shadow: 0 0 20px rgba(251,191,36,0.25); }
        50%      { box-shadow: 0 0 30px rgba(251,191,36,0.45); }
      }

      .rank-num { text-align: center; font-weight: 700; }
      .rank-initials { letter-spacing: 0.05em; }
      .rank-score { text-align: right; font-variant-numeric: tabular-nums; }
      .rank-you {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 0.7rem;
        font-weight: 900;
        color: #fbbf24;
        letter-spacing: 0.1em;
      }

      .leaderboard-empty {
        text-align: center;
        padding: 1rem;
        color: #64748b;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
      }

      .share-section {
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
      }

      .share-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.2em;
        margin-bottom: 0.85rem;
      }

      .share-buttons {
        display: flex;
        gap: 0.6rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .share-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.5rem;
        color: #93c5fd;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
      }

      .share-btn:hover, .share-btn:focus-visible {
        background: rgba(251, 191, 36, 0.15);
        border-color: rgba(251, 191, 36, 0.6);
        color: #fbbf24;
        outline: none;
        transform: translateY(-2px);
      }

      .share-btn svg { width: 1.2rem; height: 1.2rem; }

      .copy-toast {
        position: absolute;
        bottom: -1.75rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #4ade80;
        opacity: 0;
        transition: opacity 0.2s;
        pointer-events: none;
      }

      .copy-toast--show { opacity: 1; }

      .action-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        width: 100%;
      }

      .dialog {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }

      .dialog[hidden] { display: none; }

      .dialog-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(2, 6, 23, 0.75);
        backdrop-filter: blur(4px);
      }

      .dialog-content {
        position: relative;
        background: #0a0e1a;
        border: 1px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.75rem;
        padding: 2rem 1.75rem;
        max-width: 24rem;
        width: 100%;
        text-align: center;
        box-shadow: 0 0 40px rgba(96, 165, 250, 0.3), 0 25px 60px rgba(0, 0, 0, 0.5);
      }

      .dialog-title {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: #fff;
        margin-bottom: 0.6rem;
      }

      .dialog-text {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #cbd5e1;
        margin-bottom: 1.5rem;
        line-height: 1.5;
      }

      .dialog-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      @media (max-width: 600px) {
        .game-section { padding: 4rem 0.75rem 2rem; }
        .game-wrap { border-radius: 0.625rem; }
        .game-body { padding: 1.5rem 1rem; min-height: 28rem; }
        .game-title { font-size: 0.7rem; }

        .hud { padding: 0.5rem 0.75rem; gap: 0.75rem; }
        .hud-value { font-size: 1.3rem; }
        .hud-label { font-size: 0.6rem; }

        .grid { gap: 0.4rem; }

        .intro-title { font-size: 1.5rem; }
        .intro-text { font-size: 0.95rem; }
        .intro-hint { font-size: 0.78rem; }

        .primary-btn { font-size: 0.9rem; padding: 0.85rem 1.5rem; }

        .initial-box { width: 3rem; height: 3.5rem; font-size: 1.75rem; }

        .leaderboard-row { font-size: 0.85rem; padding: 0.5rem 0.6rem; gap: 0.5rem; }

        .exit-btn-label { display: none; }
        .exit-btn { padding: 0.5rem; }
      }

      @media (min-width: 1600px) {
        .game-wrap { max-width: 48rem; }
        .game-body { padding: 3rem 2.5rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .spark { animation: none; opacity: 0; }
        .intro-icon { animation: none; }
        .primary-btn { animation: none; }
        .timer-urgent { animation: none; }
        .virus--popping { animation: virus-pop-in 0.1s ease forwards; }
        .virus--smashed { animation: virus-smash 0.2s ease forwards !important; }
        .result-icon { animation: none; }
        .state--active { animation: none; }
        .rank-reveal { animation: none; }
        .rank-number { animation: none; background-position: 0% 50%; }
        .leaderboard-row--me { animation: none; }
      }
    </style>
  </body>
</html>