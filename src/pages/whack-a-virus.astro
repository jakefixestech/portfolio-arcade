<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Whack-a-Virus — Jake's Arcade</title>
    <meta name="description" content="Smash as many viruses as you can in 30 seconds. Compete on the leaderboard at Jake's Arcade." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Whack-a-Virus — Jake's Arcade" />
    <meta property="og:description" content="Smash as many viruses as you can in 30 seconds. Compete on the leaderboard at Jake's Arcade." />
    <meta property="og:url" content="https://arcade.jakefixestech.com/whack-a-virus" />
    <meta property="og:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />
    <meta property="og:site_name" content="Jake's Arcade" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Whack-a-Virus — Jake's Arcade" />
    <meta name="twitter:description" content="Smash as many viruses as you can in 30 seconds. Compete on the leaderboard." />
    <meta name="twitter:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      />
    </noscript>
  </head>

  <body>
    <main class="page">

      <button id="exit-btn" type="button" class="exit-btn" aria-label="Exit to arcade">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 9 6 L 4 12 L 9 18 M 4 12 L 19 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="exit-btn-label">EXIT</span>
      </button>

      <div class="sparkles" aria-hidden="true">
        {Array.from({ length: 18 }).map((_, i) => (
          <span class={`spark sp-${i + 1}`}></span>
        ))}
      </div>

      <section class="game-section">
        <div class="game-wrap">
          <div class="game-header" aria-hidden="true">
            <div class="game-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <div class="game-title">jake@arcade: ~/whack-a-virus</div>
          </div>

          <div class="game-body">

            <!-- INTRO -->
            <div id="state-intro" class="state state--active">
              <div class="intro-icon" aria-hidden="true">
                <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                  <ellipse cx="40" cy="44" rx="22" ry="26" fill="#ef4444" />
                  <ellipse cx="40" cy="40" rx="20" ry="22" fill="#dc2626" />
                  <line x1="40" y1="14" x2="40" y2="22" stroke="#dc2626" stroke-width="3.5" stroke-linecap="round" />
                  <circle cx="40" cy="11" r="2.5" fill="#dc2626" />
                  <line x1="6" y1="22" x2="20" y2="32" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" />
                  <line x1="74" y1="22" x2="60" y2="32" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" />
                  <line x1="2" y1="44" x2="18" y2="44" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" />
                  <line x1="78" y1="44" x2="62" y2="44" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" />
                  <line x1="6" y1="66" x2="20" y2="56" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" />
                  <line x1="74" y1="66" x2="60" y2="56" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" />
                  <ellipse cx="32" cy="38" rx="5" ry="6" fill="#fff" />
                  <ellipse cx="48" cy="38" rx="5" ry="6" fill="#fff" />
                  <circle cx="32" cy="40" r="2.5" fill="#000" />
                  <circle cx="48" cy="40" r="2.5" fill="#000" />
                  <path d="M 28 54 L 31 50 L 34 54 L 37 50 L 40 54 L 43 50 L 46 54 L 49 50 L 52 54" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>

              <h1 class="intro-title">Whack-a-Virus</h1>
              <p class="intro-text">
                Smash as many viruses as you can in <strong>30 seconds</strong>.
              </p>
              <p class="intro-hint">
                Tap each virus before it disappears. Watch out — they get faster the more you smash.
              </p>

              <button id="start-btn" class="primary-btn" type="button">
                <span>PLAY</span>
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M 7 5 L 7 19 L 19 12 Z" fill="currentColor" />
                </svg>
              </button>
            </div>

            <!-- PLAYING -->
            <div id="state-playing" class="state">
              <div class="hud">
                <div class="hud-item">
                  <span class="hud-label">SCORE</span>
                  <span class="hud-value" id="score-display">0</span>
                </div>
                <div class="hud-item hud-timer-wrap">
                  <span class="hud-label">TIME</span>
                  <span class="hud-value" id="timer-display">30</span>
                  <div class="timer-bar" aria-hidden="true">
                    <div class="timer-fill" id="timer-fill"></div>
                  </div>
                </div>
              </div>

              <div class="grid" role="application" aria-label="Whack-a-virus grid">
                <button type="button" class="cell" data-cell="0" aria-label="Cell 1"></button>
                <button type="button" class="cell" data-cell="1" aria-label="Cell 2"></button>
                <button type="button" class="cell" data-cell="2" aria-label="Cell 3"></button>
                <button type="button" class="cell" data-cell="3" aria-label="Cell 4"></button>
                <button type="button" class="cell" data-cell="4" aria-label="Cell 5"></button>
                <button type="button" class="cell" data-cell="5" aria-label="Cell 6"></button>
                <button type="button" class="cell" data-cell="6" aria-label="Cell 7"></button>
                <button type="button" class="cell" data-cell="7" aria-label="Cell 8"></button>
                <button type="button" class="cell" data-cell="8" aria-label="Cell 9"></button>
              </div>
            </div>

            <!-- RESULT -->
            <div id="state-result" class="state">
              <div class="result-icon" aria-hidden="true">
                <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="40" cy="40" r="36" fill="#10b981" />
                  <path d="M 22 40 L 36 54 L 58 28" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>

              <h2 class="result-title">Time's up!</h2>
              <p class="result-text">
                You smashed <strong id="result-score">0</strong> viruses.
              </p>

              <div class="initials-section">
                <p class="initials-label">ENTER YOUR INITIALS</p>
                <div class="initials-inputs" role="group" aria-label="Three letter initials">
                  <input type="text" class="initial-box" id="init-1" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="First letter" />
                  <input type="text" class="initial-box" id="init-2" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Second letter" />
                  <input type="text" class="initial-box" id="init-3" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Third letter" />
                </div>

                <p class="initials-error" id="initials-error" aria-live="polite"></p>

                <button id="submit-btn" class="primary-btn" type="button" disabled>
                  <span id="submit-btn-text">SUBMIT SCORE</span>
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>

                <button id="skip-btn" class="ghost-btn" type="button">Skip — don't save my score</button>
              </div>
            </div>

            <!-- LEADERBOARD -->
            <div id="state-leaderboard" class="state">
              <div id="rank-reveal" class="rank-reveal">
                <p class="rank-eyebrow" id="rank-eyebrow">YOU RANKED</p>
                <p class="rank-number" id="rank-number">#1</p>
                <p class="rank-detail" id="rank-detail">on the leaderboard</p>
              </div>

              <div class="leaderboard-wrap">
                <p class="leaderboard-title">TOP 10 — WHACK-A-VIRUS</p>
                <ol id="leaderboard-list" class="leaderboard"></ol>
              </div>

              <div class="share-section">
                <p class="share-eyebrow">SHARE YOUR SCORE</p>
                <div class="share-buttons">
                  <a id="share-fb" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to Facebook">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M 12 2 C 6.477 2 2 6.477 2 12 C 2 17 5.66 21.13 10.44 21.88 L 10.44 14.89 L 7.9 14.89 L 7.9 12 L 10.44 12 L 10.44 9.8 C 10.44 7.29 11.93 5.91 14.22 5.91 C 15.31 5.91 16.45 6.1 16.45 6.1 L 16.45 8.56 L 15.19 8.56 C 13.95 8.56 13.56 9.33 13.56 10.12 L 13.56 12 L 16.34 12 L 15.89 14.89 L 13.56 14.89 L 13.56 21.88 C 18.34 21.13 22 17 22 12 C 22 6.477 17.523 2 12 2 Z" fill="currentColor" />
                    </svg>
                  </a>
                  <a id="share-x" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to X">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M 18.244 2.25 L 21.552 2.25 L 14.325 10.51 L 22.827 21.75 L 16.17 21.75 L 10.956 14.933 L 4.99 21.75 L 1.68 21.75 L 9.41 12.915 L 1.254 2.25 L 8.08 2.25 L 12.793 8.481 L 18.244 2.25 Z M 17.083 19.77 L 18.916 19.77 L 7.084 4.126 L 5.117 4.126 L 17.083 19.77 Z" fill="currentColor" />
                    </svg>
                  </a>
                  <button id="share-native" type="button" class="share-btn" aria-label="Share via system share menu" style="display:none">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M 12 3 L 12 16 M 7 8 L 12 3 L 17 8 M 4 14 L 4 20 a 1 1 0 0 0 1 1 L 19 21 a 1 1 0 0 0 1 -1 L 20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>
                  <button id="share-copy" type="button" class="share-btn" aria-label="Copy link to clipboard">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <rect x="8" y="8" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
                      <path d="M 5 15 L 4 15 a 1 1 0 0 1 -1 -1 L 3 4 a 1 1 0 0 1 1 -1 L 14 3 a 1 1 0 0 1 1 1 L 15 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                  </button>
                </div>
                <p class="copy-toast" id="copy-toast" aria-live="polite">Link copied!</p>
              </div>

              <div class="action-buttons">
                <button id="play-again-btn" type="button" class="primary-btn">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M 4 12 a 8 8 0 1 1 2.5 5.7 M 4 12 V 6 M 4 12 H 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span>PLAY AGAIN</span>
                </button>
                <a href="/" class="ghost-btn ghost-btn--link">← Back to Arcade</a>
              </div>
            </div>

          </div>
        </div>
      </section>

      <template id="virus-template-1">
        <svg class="virus" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <ellipse cx="40" cy="44" rx="22" ry="26" fill="#ef4444" />
          <ellipse cx="40" cy="40" rx="20" ry="22" fill="#dc2626" />
          <line x1="40" y1="14" x2="40" y2="22" stroke="#dc2626" stroke-width="4" stroke-linecap="round" />
          <line x1="6" y1="22" x2="20" y2="32" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
          <line x1="74" y1="22" x2="60" y2="32" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
          <line x1="2" y1="44" x2="18" y2="44" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
          <line x1="78" y1="44" x2="62" y2="44" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
          <line x1="6" y1="66" x2="20" y2="56" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
          <line x1="74" y1="66" x2="60" y2="56" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
          <ellipse cx="32" cy="38" rx="5" ry="6" fill="#fff" />
          <ellipse cx="48" cy="38" rx="5" ry="6" fill="#fff" />
          <circle cx="32" cy="40" r="2.5" fill="#000" />
          <circle cx="48" cy="40" r="2.5" fill="#000" />
          <path d="M 28 54 L 31 50 L 34 54 L 37 50 L 40 54 L 43 50 L 46 54 L 49 50 L 52 54" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </template>

      <template id="virus-template-2">
        <svg class="virus" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="40" cy="40" r="26" fill="#a855f7" />
          <circle cx="40" cy="40" r="23" fill="#9333ea" />
          <line x1="40" y1="8" x2="40" y2="17" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <line x1="14" y1="14" x2="20" y2="22" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <line x1="66" y1="14" x2="60" y2="22" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <line x1="6" y1="40" x2="14" y2="40" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <line x1="74" y1="40" x2="66" y2="40" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <line x1="14" y1="66" x2="20" y2="58" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <line x1="66" y1="66" x2="60" y2="58" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
          <ellipse cx="30" cy="36" rx="6" ry="7" fill="#fff" />
          <ellipse cx="50" cy="36" rx="6" ry="7" fill="#fff" />
          <circle cx="30" cy="38" r="3" fill="#000" />
          <circle cx="50" cy="38" r="3" fill="#000" />
          <path d="M 26 52 Q 40 60 54 52" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </template>

      <template id="virus-template-3">
        <svg class="virus" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 40 14 L 60 22 L 64 44 L 56 64 L 40 70 L 24 64 L 16 44 L 20 22 Z" fill="#f59e0b" />
          <path d="M 40 18 L 56 24 L 60 44 L 53 60 L 40 65 L 27 60 L 20 44 L 24 24 Z" fill="#d97706" />
          <ellipse cx="33" cy="38" rx="5" ry="6" fill="#fff" />
          <ellipse cx="47" cy="38" rx="5" ry="6" fill="#fff" />
          <circle cx="33" cy="40" r="2.5" fill="#000" />
          <circle cx="47" cy="40" r="2.5" fill="#000" />
          <path d="M 30 54 L 50 54 L 47 58 L 43 54 L 40 58 L 37 54 L 33 58 Z" fill="#fff" stroke="#fff" stroke-width="0.5" stroke-linejoin="round" />
        </svg>
      </template>

      <div id="exit-dialog" class="dialog" role="dialog" aria-modal="true" aria-labelledby="exit-dialog-title" hidden>
        <div class="dialog-backdrop"></div>
        <div class="dialog-content">
          <h2 id="exit-dialog-title" class="dialog-title">Exit mid-game?</h2>
          <p class="dialog-text">Your score won't be saved if you leave now.</p>
          <div class="dialog-buttons">
            <button id="exit-cancel" type="button" class="ghost-btn">Keep playing</button>
            <button id="exit-confirm" type="button" class="danger-btn">Exit anyway</button>
          </div>
        </div>
      </div>
    </main>

    <script>
      // @ts-nocheck

      // === Config ===
      const GAME_DURATION = 30;
      const GAME_SLUG = 'whack-a-virus';
      const GAME_NAME = 'Whack-a-Virus';

      // Difficulty curve based on current score:
      // - 0-10:  spawn 750ms, lifetime 1100ms (kid-friendly start)
      // - 11-25: spawn 600ms, lifetime 950ms (current speed)
      // - 26-40: spawn 450ms, lifetime 800ms (faster)
      // - 41+:   spawn 350ms, lifetime 650ms (on crack mode)
      function getDifficulty(score) {
        if (score <= 10) return { spawn: 750, lifetime: 1100 };
        if (score <= 25) return { spawn: 600, lifetime: 950 };
        if (score <= 40) return { spawn: 450, lifetime: 800 };
        return { spawn: 350, lifetime: 650 };
      }

      // === DOM refs ===
      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const stateLeaderboard = document.getElementById('state-leaderboard');
      const startBtn = document.getElementById('start-btn');
      const exitBtn = document.getElementById('exit-btn');
      const scoreDisplay = document.getElementById('score-display');
      const timerDisplay = document.getElementById('timer-display');
      const timerFill = document.getElementById('timer-fill');
      const cells = Array.from(document.querySelectorAll('.cell'));
      const virusTemplates = [
        document.getElementById('virus-template-1'),
        document.getElementById('virus-template-2'),
        document.getElementById('virus-template-3'),
      ];
      const resultScore = document.getElementById('result-score');
      const initBoxes = [
        document.getElementById('init-1'),
        document.getElementById('init-2'),
        document.getElementById('init-3'),
      ];
      const initialsError = document.getElementById('initials-error');
      const submitBtn = document.getElementById('submit-btn');
      const submitBtnText = document.getElementById('submit-btn-text');
      const skipBtn = document.getElementById('skip-btn');
      const rankNumber = document.getElementById('rank-number');
      const rankEyebrow = document.getElementById('rank-eyebrow');
      const rankDetail = document.getElementById('rank-detail');
      const leaderboardList = document.getElementById('leaderboard-list');
      const playAgainBtn = document.getElementById('play-again-btn');
      const exitDialog = document.getElementById('exit-dialog');
      const exitCancel = document.getElementById('exit-cancel');
      const exitConfirm = document.getElementById('exit-confirm');
      const shareFb = document.getElementById('share-fb');
      const shareX = document.getElementById('share-x');
      const shareNative = document.getElementById('share-native');
      const shareCopy = document.getElementById('share-copy');
      const copyToast = document.getElementById('copy-toast');

      // === Game state ===
      let score = 0;
      let timeLeft = GAME_DURATION;
      let gameRunning = false;
      let timerHandle = null;
      let spawnHandle = null;
      let currentSpawnRate = 750; // tracks current difficulty tier's spawn rate
      let activeViruses = new Map();
      let lastSubmittedRank = null;
      let lastSubmittedInitials = null;

      function showState(name) {
        [stateIntro, statePlaying, stateResult, stateLeaderboard].forEach(s => s.classList.remove('state--active'));
        if (name === 'intro')       stateIntro.classList.add('state--active');
        if (name === 'playing')     statePlaying.classList.add('state--active');
        if (name === 'result')      stateResult.classList.add('state--active');
        if (name === 'leaderboard') stateLeaderboard.classList.add('state--active');
      }

      function startGame() {
        score = 0;
        timeLeft = GAME_DURATION;
        gameRunning = true;
        activeViruses.clear();

        scoreDisplay.textContent = '0';
        timerDisplay.textContent = String(GAME_DURATION);
        timerFill.style.width = '100%';
        timerDisplay.classList.remove('timer-urgent');

        cells.forEach(cell => { cell.innerHTML = ''; cell.classList.remove('cell--smashed'); });

        showState('playing');

        timerHandle = setInterval(tickTimer, 1000);

        // Start with easiest tier spawn rate
        const initialDiff = getDifficulty(0);
        currentSpawnRate = initialDiff.spawn;
        spawnHandle = setInterval(spawnVirus, currentSpawnRate);
        spawnVirus();
      }

      function tickTimer() {
        timeLeft--;
        timerDisplay.textContent = String(timeLeft);
        timerFill.style.width = (timeLeft / GAME_DURATION * 100) + '%';
        if (timeLeft <= 5) timerDisplay.classList.add('timer-urgent');
        if (timeLeft <= 0) endGame();
      }

      // Re-evaluate difficulty after each smash. If we crossed a tier boundary,
      // restart the spawn interval at the new rate.
      function maybeRampDifficulty() {
        const diff = getDifficulty(score);
        if (diff.spawn !== currentSpawnRate) {
          currentSpawnRate = diff.spawn;
          clearInterval(spawnHandle);
          spawnHandle = setInterval(spawnVirus, currentSpawnRate);
        }
      }

      function spawnVirus() {
        if (!gameRunning) return;

        const emptyCells = cells.filter((_, i) => !activeViruses.has(i));
        if (emptyCells.length === 0) return;

        const targetCell = emptyCells[Math.floor(Math.random() * emptyCells.length)];
        const cellIndex = parseInt(targetCell.dataset.cell);

        const template = virusTemplates[Math.floor(Math.random() * virusTemplates.length)];
        const virusClone = template.content.cloneNode(true);
        targetCell.appendChild(virusClone);

        const virusEl = targetCell.querySelector('.virus');
        if (!virusEl) return;
        virusEl.classList.add('virus--popping');

        // Lifetime depends on current score's difficulty tier
        const lifetime = getDifficulty(score).lifetime;
        const hideTimeout = setTimeout(() => {
          if (gameRunning && activeViruses.has(cellIndex)) {
            removeVirus(cellIndex, false);
          }
        }, lifetime);

        activeViruses.set(cellIndex, { element: virusEl, hideTimeout, smashed: false });
      }

      function removeVirus(cellIndex, wasSmashed) {
        const data = activeViruses.get(cellIndex);
        if (!data) return;

        clearTimeout(data.hideTimeout);
        const cell = cells[cellIndex];
        const virus = data.element;

        if (wasSmashed && virus) {
          virus.classList.remove('virus--popping');
          virus.classList.add('virus--smashed');
          cell.classList.add('cell--smashed');
          setTimeout(() => {
            cell.innerHTML = '';
            cell.classList.remove('cell--smashed');
          }, 350);
        } else {
          if (virus) virus.classList.add('virus--escaping');
          setTimeout(() => { cell.innerHTML = ''; }, 250);
        }

        activeViruses.delete(cellIndex);
      }

      cells.forEach(cell => {
        cell.addEventListener('click', () => {
          if (!gameRunning) return;
          const cellIndex = parseInt(cell.dataset.cell);
          if (!activeViruses.has(cellIndex)) return;

          const data = activeViruses.get(cellIndex);
          if (data.smashed) return;
          data.smashed = true;

          score++;
          scoreDisplay.textContent = String(score);
          scoreDisplay.classList.remove('score-bump');
          void scoreDisplay.offsetWidth;
          scoreDisplay.classList.add('score-bump');

          removeVirus(cellIndex, true);

          // Check if we crossed a difficulty tier boundary
          maybeRampDifficulty();
        });
      });

      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;

        clearInterval(timerHandle);
        clearInterval(spawnHandle);

        activeViruses.forEach((data, idx) => {
          clearTimeout(data.hideTimeout);
          cells[idx].innerHTML = '';
        });
        activeViruses.clear();

        timerDisplay.classList.remove('timer-urgent');

        resultScore.textContent = String(score);

        initBoxes.forEach(b => { b.value = ''; b.classList.remove('initial-box--filled'); });
        initialsError.textContent = '';
        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMIT SCORE';

        showState('result');
        setTimeout(() => initBoxes[0].focus(), 250);
      }

      initBoxes.forEach((box, idx) => {
        box.addEventListener('input', (e) => {
          let val = box.value.toUpperCase();
          val = val.replace(/[^A-Z]/g, '');
          box.value = val;

          if (val.length === 1) {
            box.classList.add('initial-box--filled');
            if (idx < initBoxes.length - 1) {
              initBoxes[idx + 1].focus();
            } else {
              box.blur();
            }
          } else {
            box.classList.remove('initial-box--filled');
          }

          updateSubmitState();
        });

        box.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && box.value === '' && idx > 0) {
            initBoxes[idx - 1].focus();
            initBoxes[idx - 1].value = '';
            initBoxes[idx - 1].classList.remove('initial-box--filled');
            updateSubmitState();
          }
          if (e.key === 'Enter' && !submitBtn.disabled) {
            submitScore();
          }
        });

        box.addEventListener('focus', () => {
          box.select();
        });
      });

      function getInitials() {
        return initBoxes.map(b => b.value).join('').toUpperCase();
      }

      function updateSubmitState() {
        const initials = getInitials();
        submitBtn.disabled = !/^[A-Z]{3}$/.test(initials);
      }

      async function submitScore() {
        const initials = getInitials();
        if (!/^[A-Z]{3}$/.test(initials)) return;

        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMITTING...';
        initialsError.textContent = '';

        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initials, score }),
          });

          const data = await res.json();

          if (!res.ok) {
            initialsError.textContent = data.error || 'Could not save score. Try different initials.';
            submitBtn.disabled = false;
            submitBtnText.textContent = 'SUBMIT SCORE';
            return;
          }

          lastSubmittedInitials = initials;
          lastSubmittedRank = data.madeLeaderboard ? data.rank : null;
          renderLeaderboard(data.scores || []);
        } catch (err) {
          initialsError.textContent = 'Network error. Try again in a sec.';
          submitBtn.disabled = false;
          submitBtnText.textContent = 'SUBMIT SCORE';
        }
      }

      submitBtn.addEventListener('click', submitScore);

      skipBtn.addEventListener('click', async () => {
        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`);
          const data = await res.json();
          lastSubmittedRank = null;
          lastSubmittedInitials = null;
          renderLeaderboard(data.scores || []);
        } catch {
          renderLeaderboard([]);
        }
      });

      function renderLeaderboard(scores) {
        if (lastSubmittedRank) {
          const ord = ordinalSuffix(lastSubmittedRank);
          rankEyebrow.textContent = 'YOU RANKED';
          rankNumber.textContent = `#${lastSubmittedRank}`;
          rankDetail.textContent = lastSubmittedRank === 1 ? '🏆 First place!' : `${ord} place on the leaderboard`;
          document.getElementById('rank-reveal').style.display = '';
        } else if (lastSubmittedInitials) {
          rankEyebrow.textContent = 'SCORE SUBMITTED';
          rankNumber.textContent = String(score);
          rankDetail.textContent = "Didn't crack the top 10 — keep practicing!";
          document.getElementById('rank-reveal').style.display = '';
        } else {
          document.getElementById('rank-reveal').style.display = 'none';
        }

        leaderboardList.innerHTML = '';

        if (scores.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'leaderboard-empty';
          empty.textContent = 'No scores yet. Be the first.';
          leaderboardList.appendChild(empty);
        } else {
          scores.slice(0, 10).forEach((entry, idx) => {
            const li = document.createElement('li');
            const rank = idx + 1;
            const isMe = lastSubmittedRank === rank && lastSubmittedInitials === entry.initials;
            li.className = `leaderboard-row leaderboard-row--${rank} ${isMe ? 'leaderboard-row--me' : ''}`;
            li.innerHTML = `
              <span class="rank-num">${rank}</span>
              <span class="rank-initials">${escapeHtml(entry.initials)}</span>
              <span class="rank-score">${entry.score}</span>
              ${isMe ? '<span class="rank-you">← YOU</span>' : ''}
            `;
            leaderboardList.appendChild(li);
          });
        }

        configureShare();

        showState('leaderboard');
      }

      function ordinalSuffix(n) {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      }

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function configureShare() {
        const url = window.location.href;
        const text = `I scored ${score} on ${GAME_NAME} at Jake's Arcade. Beat me?`;
        const fullShare = `${text} ${url}`;

        shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`;
        shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;

        if (navigator.share) {
          shareNative.style.display = '';
          shareNative.onclick = async () => {
            try {
              await navigator.share({ title: GAME_NAME + " — Jake's Arcade", text, url });
            } catch (e) { }
          };
        }

        shareCopy.onclick = async () => {
          try {
            await navigator.clipboard.writeText(fullShare);
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = fullShare;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          }
        };
      }

      playAgainBtn.addEventListener('click', () => {
        startGame();
      });

      function showExitDialog() {
        exitDialog.hidden = false;
        setTimeout(() => exitCancel.focus(), 50);
      }

      function hideExitDialog() {
        exitDialog.hidden = true;
      }

      exitBtn.addEventListener('click', () => {
        if (gameRunning) {
          showExitDialog();
        } else {
          window.location.href = '/';
        }
      });

      exitCancel.addEventListener('click', hideExitDialog);
      exitConfirm.addEventListener('click', () => {
        gameRunning = false;
        clearInterval(timerHandle);
        clearInterval(spawnHandle);
        window.location.href = '/';
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !exitDialog.hidden) {
          hideExitDialog();
        }
      });

      startBtn.addEventListener('click', startGame);
    </script>

