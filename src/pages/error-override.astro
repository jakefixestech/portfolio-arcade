        cursor: pointer;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 8px 30px rgba(251, 191, 36, 0.35);
        animation: btn-pulse 2.4s ease-in-out infinite;
      }

      .primary-btn:hover:not(:disabled),
      .primary-btn:focus-visible:not(:disabled) {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 0 0 6px rgba(251, 191, 36, 0.25), 0 12px 40px rgba(251, 191, 36, 0.5);
        outline: none;
        animation-play-state: paused;
      }

      .primary-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        animation: none;
      }

      .primary-btn svg {
        width: 1.1rem !important;
        height: 1.1rem !important;
        flex-shrink: 0;
      }

      @keyframes btn-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(251,191,36,0.4), 0 8px 30px rgba(251,191,36,0.35); }
        50%      { box-shadow: 0 0 0 10px rgba(251,191,36,0), 0 10px 35px rgba(251,191,36,0.45); }
      }

      .ghost-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.75rem 1.25rem;
        background: transparent;
        color: #94a3b8;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(148, 163, 184, 0.3);
        border-radius: 0.5rem;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .ghost-btn:hover, .ghost-btn:focus-visible {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.5);
        outline: none;
      }

      .ghost-btn--link { display: inline-flex; }

      .danger-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.75rem 1.25rem;
        background: rgba(239, 68, 68, 0.15);
        color: #fca5a5;
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        border: 1px solid rgba(239, 68, 68, 0.5);
        border-radius: 0.5rem;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .danger-btn:hover, .danger-btn:focus-visible {
        background: rgba(239, 68, 68, 0.3);
        color: #fff;
        outline: none;
      }

      .hud {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding: 0.75rem 1rem;
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(96, 165, 250, 0.25);
        border-radius: 0.5rem;
        width: 100%;
      }

      .hud-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
      }

      .hud-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        font-weight: 600;
        color: #64748b;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .hud-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.4rem;
        font-weight: 700;
        color: #f8fafc;
        line-height: 1;
        font-variant-numeric: tabular-nums;
      }

      .error-stage {
        width: 100%;
        background: #0a0e1a;
        border: 1.5px solid rgba(239, 68, 68, 0.4);
        border-radius: 0.75rem;
        padding: 1.5rem 1.25rem;
        margin-bottom: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-height: 8rem;
        justify-content: center;
        align-items: flex-start;
      }

      .error-prefix {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #ef4444;
        letter-spacing: 0.15em;
      }

      .error-target {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1rem, 3.5vw, 1.5rem);
        font-weight: 700;
        line-height: 1.4;
        word-break: break-all;
        letter-spacing: 0.02em;
      }

      .error-target .ch-good {
        color: #10b981;
      }

      .error-target .ch-bad {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.18);
        border-radius: 2px;
      }

      .error-target .ch-cursor {
        color: #fbbf24;
        background: rgba(251, 191, 36, 0.2);
        border-radius: 2px;
        animation: cursor-blink 0.9s step-end infinite;
      }

      .error-target .ch-pending {
        color: #64748b;
      }

      @keyframes cursor-blink {
        0%, 50%   { background: rgba(251, 191, 36, 0.2); }
        51%, 100% { background: transparent; }
      }

      .error-input {
        width: 100%;
        padding: 0.85rem 1rem;
        background: #0a0e1a;
        border: 1.5px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.625rem;
        color: #fff;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
      }

      .error-input:focus {
        border-color: #fbbf24;
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.18);
      }

      .error-input:disabled {
        opacity: 0.5;
      }

      .error-hint {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: #64748b;
        margin-top: 0.6rem;
        text-align: center;
      }

      .result-icon {
        width: 96px;
        height: 96px;
        margin: 0 auto 1.5rem auto;
        flex-shrink: 0;
        animation: result-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes result-pop {
        0%   { transform: scale(0); }
        70%  { transform: scale(1.15); }
        100% { transform: scale(1); }
      }

      .result-icon svg {
        width: 96px;
        height: 96px;
        display: block;
      }

      .result-title {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 900;
        color: #fff;
        margin-bottom: 0.75rem;
        line-height: 1.15;
      }

      .result-text {
        font-size: 1rem;
        color: #d1d5db;
        margin-bottom: 1rem;
        line-height: 1.7;
      }

      .result-text strong { color: #fbbf24; font-weight: 700; }

      .initials-section { width: 100%; max-width: 24rem; }

      .initials-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #fbbf24;
        letter-spacing: 0.2em;
        margin-bottom: 0.85rem;
      }

      .initials-inputs {
        display: flex;
        gap: 0.6rem;
        justify-content: center;
        margin-bottom: 1rem;
      }

      .initial-box {
        width: 3.5rem;
        height: 4rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 2rem;
        font-weight: 700;
        text-align: center;
        background: rgba(15, 23, 42, 0.8);
        color: #fbbf24;
        border: 2px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.5rem;
        text-transform: uppercase;
        outline: none;
        transition: all 0.15s ease;
        caret-color: #fbbf24;
      }

      .initial-box:focus {
        border-color: #fbbf24;
        background: rgba(15, 23, 42, 1);
        box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.15);
      }

      .initial-box--filled {
        border-color: rgba(251, 191, 36, 0.7);
        background: rgba(251, 191, 36, 0.08);
      }

      .initials-error {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: #fca5a5;
        min-height: 1.2rem;
        margin-bottom: 1rem;
      }

      #skip-btn { margin-top: 1rem; width: 100%; }

      .rank-reveal {
        text-align: center;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.06));
        border: 1px solid rgba(251, 191, 36, 0.3);
        border-radius: 0.75rem;
        animation: rank-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes rank-pop {
        0%   { transform: scale(0.7); opacity: 0; }
        70%  { transform: scale(1.05); opacity: 1; }
        100% { transform: scale(1); }
      }

      .rank-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 700;
        color: #fbbf24;
        letter-spacing: 0.25em;
        margin-bottom: 0.5rem;
      }

      .rank-number {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(3rem, 9vw, 4.5rem);
        font-weight: 700;
        line-height: 1;
        background: linear-gradient(135deg, #fbbf24, #fde68a, #fbbf24);
        background-size: 200% 200%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gold-shimmer 3.5s ease-in-out infinite;
        margin-bottom: 0.5rem;
      }

      @keyframes gold-shimmer {
        0%, 100% { background-position: 0% 50%; }
        50%      { background-position: 100% 50%; }
      }

      .rank-detail {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 1rem;
        color: #d1d5db;
      }

      .leaderboard-wrap { width: 100%; margin-bottom: 2rem; }

      .leaderboard-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.2em;
        text-align: center;
        margin-bottom: 0.85rem;
        padding-bottom: 0.65rem;
        border-bottom: 1px dashed rgba(96, 165, 250, 0.25);
      }

      .leaderboard {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .leaderboard-row {
        display: grid;
        grid-template-columns: 2.2rem 1fr auto auto;
        align-items: center;
        gap: 0.85rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.95rem;
        color: #cbd5e1;
        padding: 0.55rem 0.85rem;
        background: rgba(15, 23, 42, 0.4);
        border-radius: 0.4rem;
        border: 1px solid transparent;
      }

      .leaderboard-row--1 { color: #fbbf24; font-weight: 700; }
      .leaderboard-row--2 { color: #cbd5e1; font-weight: 600; }
      .leaderboard-row--3 { color: #d97706; font-weight: 600; }

      .leaderboard-row--me {
        background: rgba(251, 191, 36, 0.15);
        border-color: rgba(251, 191, 36, 0.6);
        box-shadow: 0 0 20px rgba(251, 191, 36, 0.25);
        animation: me-pulse 2s ease-in-out infinite;
      }

      @keyframes me-pulse {
        0%, 100% { box-shadow: 0 0 20px rgba(251,191,36,0.25); }
        50%      { box-shadow: 0 0 30px rgba(251,191,36,0.45); }
      }

      .rank-num { text-align: center; font-weight: 700; }
      .rank-initials { letter-spacing: 0.05em; }
      .rank-score { text-align: right; font-variant-numeric: tabular-nums; }
      .rank-you {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 0.7rem;
        font-weight: 900;
        color: #fbbf24;
        letter-spacing: 0.1em;
      }

      .leaderboard-empty {
        text-align: center;
        padding: 1rem;
        color: #64748b;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
      }

      .share-section {
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
      }

      .share-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.2em;
        margin-bottom: 0.85rem;
      }

      .share-buttons {
        display: flex;
        gap: 0.6rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .share-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.5rem;
        color: #93c5fd;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
      }

      .share-btn:hover, .share-btn:focus-visible {
        background: rgba(251, 191, 36, 0.15);
        border-color: rgba(251, 191, 36, 0.6);
        color: #fbbf24;
        outline: none;
        transform: translateY(-2px);
      }

      .share-btn svg { width: 1.2rem; height: 1.2rem; }

      .copy-toast {
        position: absolute;
        bottom: -1.75rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #4ade80;
        opacity: 0;
        transition: opacity 0.2s;
        pointer-events: none;
      }

      .copy-toast--show { opacity: 1; }

      .action-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        width: 100%;
      }

      .dialog {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }

      .dialog[hidden] { display: none; }

      .dialog-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(2, 6, 23, 0.75);
        backdrop-filter: blur(4px);
      }

      .dialog-content {
        position: relative;
        background: #0a0e1a;
        border: 1px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.75rem;
        padding: 2rem 1.75rem;
        max-width: 24rem;
        width: 100%;
        text-align: center;
        box-shadow: 0 0 40px rgba(96, 165, 250, 0.3), 0 25px 60px rgba(0, 0, 0, 0.5);
      }

      .dialog-title {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: #fff;
        margin-bottom: 0.6rem;
      }

      .dialog-text {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #cbd5e1;
        margin-bottom: 1.5rem;
        line-height: 1.5;
      }

      .dialog-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      @media (max-width: 600px) {
        .game-section { padding: 4rem 0.75rem 4rem; }
        .game-wrap { border-radius: 0.625rem; }
        .game-body { padding: 1.5rem 1rem; min-height: 28rem; }
        .game-title { font-size: 0.7rem; }

        .hud { padding: 0.5rem 0.75rem; gap: 0.5rem; }
        .hud-value { font-size: 1.05rem; }
        .hud-label { font-size: 0.55rem; }

        .error-stage { padding: 1rem 0.85rem; min-height: 7rem; }
        .error-target { font-size: 1rem; }
        .error-input { font-size: 0.95rem; padding: 0.75rem 0.85rem; }

        .intro-title { font-size: 1.5rem; }
        .intro-text { font-size: 0.95rem; }
        .intro-hint { font-size: 0.78rem; }

        .primary-btn { font-size: 0.9rem; padding: 0.85rem 1.5rem; }

        .initial-box { width: 3rem; height: 3.5rem; font-size: 1.75rem; }

        .leaderboard-row { font-size: 0.85rem; padding: 0.5rem 0.6rem; gap: 0.5rem; }

        .exit-btn-label { display: none; }
        .exit-btn { padding: 0.5rem; }
      }

      @media (min-width: 1600px) {
        .cabinet-shell { max-width: 54rem; }
        .game-wrap { max-width: none; }
        .game-body { padding: 3rem 2.5rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .mote { animation: none; opacity: 0; }
        .intro-icon { animation: none; }
        .primary-btn { animation: none; }
        .ch-cursor { animation: none; }
        .result-icon { animation: none; }
        .state--active { animation: none; }
        .rank-reveal { animation: none; }
        .rank-number { animation: none; background-position: 0% 50%; }
        .leaderboard-row--me { animation: none; }
        .shell-marquee-bulbs span { animation: none !important; }
        .portal-return-icon { animation: none !important; }
      }
    </style>
  </body>
</html>