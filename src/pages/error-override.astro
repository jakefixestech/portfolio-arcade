<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error Override — Jake's Arcade</title>
    <meta name="description" content="Type fake error messages at speed. 60 seconds of code-flavored chaos at Jake's Arcade." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Error Override — Jake's Arcade" />
    <meta property="og:description" content="Type fake error messages at speed. 60 seconds of code-flavored chaos at Jake's Arcade." />
    <meta property="og:url" content="https://arcade.jakefixestech.com/error-override" />
    <meta property="og:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />
    <meta property="og:site_name" content="Jake's Arcade" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Error Override — Jake's Arcade" />
    <meta name="twitter:description" content="Type fake error messages at speed. 60 seconds." />
    <meta name="twitter:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=swap"
      />
    </noscript>
  </head>

  <body>
    <main class="page">

      <button id="exit-btn" type="button" class="exit-btn" aria-label="Back to Speed Lab">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 9 6 L 4 12 L 9 18 M 4 12 L 19 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="exit-btn-label">SPEED LAB</span>
      </button>

      <a href="/" class="portal-return" aria-label="Return to the portal">
        <span class="portal-return-icon" aria-hidden="true">↻</span>
        <span class="portal-return-label">PORTAL</span>
      </a>

      <div class="motes" aria-hidden="true">
        {Array.from({ length: 18 }).map((_, i) => (
          <span class={`mote mt-${i + 1}`}></span>
        ))}
      </div>

      <section class="game-section">

        <!-- ARCADE CABINET WRAPPER (desktop only via CSS) -->
        <div class="cabinet-shell">

          <div class="shell-marquee" aria-hidden="true">
            <div class="shell-marquee-bulbs">
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span>
            </div>
            <p class="shell-marquee-title">ERROR OVERRIDE</p>
          </div>

          <div class="cabinet-body">

            <div class="shell-side shell-side-l" aria-hidden="true">
              <div class="shell-side-art">
                <span class="side-decor side-d1"></span>
                <span class="side-decor side-d2"></span>
                <span class="side-decor side-d3"></span>
              </div>
            </div>
            <div class="shell-side shell-side-r" aria-hidden="true">
              <div class="shell-side-art">
                <span class="side-decor side-d1"></span>
                <span class="side-decor side-d2"></span>
                <span class="side-decor side-d3"></span>
              </div>
            </div>

            <div class="shell-bezel">

              <!-- ============================== -->
              <!-- ORIGINAL GAME — UNTOUCHED       -->
              <!-- ============================== -->
              <div class="game-wrap">
                <div class="game-header" aria-hidden="true">
                  <div class="game-dots">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                  </div>
                  <div class="game-title">jake@arcade: ~/error-override</div>
                </div>

                <div class="game-body">

                  <div id="state-intro" class="state state--active">
                    <div class="intro-icon" aria-hidden="true">
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <rect x="8" y="16" width="64" height="48" rx="3" fill="#0a0e1a" stroke="#1e3a8a" stroke-width="2" />
                        <rect x="8" y="16" width="64" height="10" rx="3" fill="#1e3a8a" />
                        <circle cx="14" cy="21" r="1.5" fill="#ef4444" />
                        <circle cx="20" cy="21" r="1.5" fill="#fbbf24" />
                        <circle cx="26" cy="21" r="1.5" fill="#10b981" />
                        <text x="14" y="38" font-family="JetBrains Mono, monospace" font-size="6" font-weight="700" fill="#ef4444">ERROR_</text>
                        <rect x="14" y="42" width="40" height="2" fill="#fbbf24" />
                        <rect x="14" y="48" width="50" height="2" fill="#cbd5e1" />
                        <rect x="14" y="54" width="30" height="2" fill="#cbd5e1" opacity="0.6" />
                      </svg>
                    </div>

                    <h1 class="intro-title">Error Override</h1>
                    <p class="intro-text">
                      Type fake error messages at <strong class="green-strong">full speed</strong>.
                    </p>
                    <p class="intro-hint">
                      <strong>60 seconds.</strong> Type each error to override it. Score is your WPM. Backspace to fix typos.
                    </p>

                    <button id="start-btn" class="primary-btn" type="button">
                      <span>PLAY</span>
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M 7 5 L 7 19 L 19 12 Z" fill="currentColor" />
                      </svg>
                    </button>
                  </div>

                  <div id="state-playing" class="state">
                    <div class="hud">
                      <div class="hud-item">
                        <span class="hud-label">TIME</span>
                        <span class="hud-value" id="time-display">60.0s</span>
                      </div>
                      <div class="hud-item">
                        <span class="hud-label">WPM</span>
                        <span class="hud-value" id="wpm-display">0</span>
                      </div>
                      <div class="hud-item">
                        <span class="hud-label">OVERRIDDEN</span>
                        <span class="hud-value" id="overridden-display">0</span>
                      </div>
                    </div>

                    <div class="error-stage" aria-live="polite">
                      <p class="error-prefix">[ERR]</p>
                      <p id="error-target" class="error-target" aria-label="Type this error message"></p>
                    </div>

                    <input
                      type="text"
                      id="error-input"
                      class="error-input"
                      autocomplete="off"
                      autocapitalize="characters"
                      autocorrect="off"
                      spellcheck="false"
                      aria-label="Type the error message"
                    />

                    <p class="error-hint">Type the error above. Capitalization doesn't matter.</p>
                  </div>

                  <div id="state-result" class="state">
                    <div class="result-icon" aria-hidden="true">
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="40" cy="40" r="36" fill="#10b981" />
                        <path d="M 22 40 L 36 54 L 58 28" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </div>

                    <h2 class="result-title">Time's up!</h2>
                    <p class="result-text">
                      WPM (final score): <strong id="result-score">0</strong><br>
                      Errors overridden: <strong id="result-overridden">0</strong><br>
                      Characters typed: <strong id="result-chars">0</strong>
                    </p>

                    <div class="initials-section">
                      <p class="initials-label">ENTER YOUR INITIALS</p>
                      <div class="initials-inputs" role="group" aria-label="Three letter initials">
                        <input type="text" class="initial-box" id="init-1" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="First letter" />
                        <input type="text" class="initial-box" id="init-2" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Second letter" />
                        <input type="text" class="initial-box" id="init-3" maxlength="1" autocomplete="off" inputmode="text" pattern="[A-Za-z]" aria-label="Third letter" />
                      </div>

                      <p class="initials-error" id="initials-error" aria-live="polite"></p>

                      <button id="submit-btn" class="primary-btn" type="button" disabled>
                        <span id="submit-btn-text">SUBMIT SCORE</span>
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>

                      <button id="skip-btn" class="ghost-btn" type="button">Skip — don't save my score</button>
                    </div>
                  </div>

                  <div id="state-leaderboard" class="state">
                    <div id="rank-reveal" class="rank-reveal">
                      <p class="rank-eyebrow" id="rank-eyebrow">YOU RANKED</p>
                      <p class="rank-number" id="rank-number">#1</p>
                      <p class="rank-detail" id="rank-detail">on the leaderboard</p>
                    </div>

                    <div class="leaderboard-wrap">
                      <p class="leaderboard-title">TOP 10 — ERROR OVERRIDE</p>
                      <ol id="leaderboard-list" class="leaderboard"></ol>
                    </div>

                    <div class="share-section">
                      <p class="share-eyebrow">SHARE YOUR SCORE</p>
                      <div class="share-buttons">
                        <a id="share-fb" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to Facebook">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 12 2 C 6.477 2 2 6.477 2 12 C 2 17 5.66 21.13 10.44 21.88 L 10.44 14.89 L 7.9 14.89 L 7.9 12 L 10.44 12 L 10.44 9.8 C 10.44 7.29 11.93 5.91 14.22 5.91 C 15.31 5.91 16.45 6.1 16.45 6.1 L 16.45 8.56 L 15.19 8.56 C 13.95 8.56 13.56 9.33 13.56 10.12 L 13.56 12 L 16.34 12 L 15.89 14.89 L 13.56 14.89 L 13.56 21.88 C 18.34 21.13 22 17 22 12 C 22 6.477 17.523 2 12 2 Z" fill="currentColor" />
                          </svg>
                        </a>
                        <a id="share-x" href="#" target="_blank" rel="noopener" class="share-btn" aria-label="Share to X">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 18.244 2.25 L 21.552 2.25 L 14.325 10.51 L 22.827 21.75 L 16.17 21.75 L 10.956 14.933 L 4.99 21.75 L 1.68 21.75 L 9.41 12.915 L 1.254 2.25 L 8.08 2.25 L 12.793 8.481 L 18.244 2.25 Z M 17.083 19.77 L 18.916 19.77 L 7.084 4.126 L 5.117 4.126 L 17.083 19.77 Z" fill="currentColor" />
                          </svg>
                        </a>
                        <button id="share-native" type="button" class="share-btn" aria-label="Share via system share menu" style="display:none">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M 12 3 L 12 16 M 7 8 L 12 3 L 17 8 M 4 14 L 4 20 a 1 1 0 0 0 1 1 L 19 21 a 1 1 0 0 0 1 -1 L 20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </button>
                        <button id="share-copy" type="button" class="share-btn" aria-label="Copy link to clipboard">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="8" y="8" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
                            <path d="M 5 15 L 4 15 a 1 1 0 0 1 -1 -1 L 3 4 a 1 1 0 0 1 1 -1 L 14 3 a 1 1 0 0 1 1 1 L 15 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                          </svg>
                        </button>
                      </div>
                      <p class="copy-toast" id="copy-toast" aria-live="polite">Link copied!</p>
                    </div>

                    <div class="action-buttons">
                      <button id="play-again-btn" type="button" class="primary-btn">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M 4 12 a 8 8 0 1 1 2.5 5.7 M 4 12 V 6 M 4 12 H 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>PLAY AGAIN</span>
                      </button>
                      <a href="/speed-lab" class="ghost-btn ghost-btn--link">← Back to Speed Lab</a>
                    </div>
                  </div>

                </div>
              </div>
              <!-- ============================== -->
              <!-- END ORIGINAL GAME               -->
              <!-- ============================== -->

            </div>

            <div class="shell-controls" aria-hidden="true">
              <span class="shell-joystick">
                <span class="shell-joystick-base"></span>
                <span class="shell-joystick-stick"></span>
                <span class="shell-joystick-ball"></span>
              </span>
              <span class="shell-buttons">
                <span class="shell-btn shell-btn-cyan"></span>
                <span class="shell-btn shell-btn-green"></span>
                <span class="shell-btn shell-btn-yellow"></span>
                <span class="shell-btn shell-btn-cyan2"></span>
              </span>
            </div>

            <div class="shell-coin" aria-hidden="true">
              <span class="shell-coin-slot"></span>
              <span class="shell-coin-label">25¢ INSERT COIN</span>
            </div>

          </div>

          <span class="shell-floor-shadow" aria-hidden="true"></span>

        </div>

      </section>

      <div id="exit-dialog" class="dialog" role="dialog" aria-modal="true" aria-labelledby="exit-dialog-title" hidden>
        <div class="dialog-backdrop"></div>
        <div class="dialog-content">
          <h2 id="exit-dialog-title" class="dialog-title">Exit mid-game?</h2>
          <p class="dialog-text">Your score won't be saved if you leave now.</p>
          <div class="dialog-buttons">
            <button id="exit-cancel" type="button" class="ghost-btn">Keep playing</button>
            <button id="exit-confirm" type="button" class="danger-btn">Exit anyway</button>
          </div>
        </div>
      </div>
    </main>

    <script>
      // @ts-nocheck

      const TIME_LIMIT_MS = 60000;
      const GAME_SLUG = 'error-override';
      const GAME_NAME = 'Error Override';
      const EXIT_TO = '/speed-lab';

      const ERROR_POOL = [
        'OOPS', 'BOOM', 'YIKES', 'CRASH', 'GLITCH', 'BORKED', 'NOPE', 'OUCH', 'OOF', 'ZAP',
        'POOF', 'DOOM', 'KAPUT', 'FROZEN', 'STUCK', 'BROKEN', 'MELTED', 'FRIED', 'ZONKED',
        'BUSTED', 'WONKY', 'MISSING', 'LOST', 'GONE', 'EMPTY', 'BLANK', 'NULL', 'VOID',
        'PANIC', 'FATAL',
        'BAD CHIP', 'NO SIGNAL', 'BLUE SCREEN', 'DEAD PIXEL', 'LOW BATTERY', 'OUT OF INK',
        'NO BUENO', 'SAD MAC', 'GHOST CAT', 'COLD COFFEE', 'BAD MAGIC', 'LOST SOCK', 'TINY BUG',
        'NULL_DRAGON', 'STACK_TOAST', 'BUFFER_GHOST', 'PANIC_HAMSTER', 'FATAL_PIZZA',
        'HEAP_BUTTERFLY', 'RACE_VOLCANO', 'DEADLOCK_MUFFIN', 'CACHE_TUNDRA', 'PIPE_LIGHTNING',
        'LEAK_CASCADE', 'HUNG_OBELISK', 'THREAD_NEBULA', 'MUTEX_BLIZZARD', 'OPCODE_RAINBOW',
        'BUS_PHANTOM', 'PAGE_PRISM', 'SMASH_GLACIER', 'LOOP_OWL', 'SYNTAX_VORTEX',
        'TYPE_PHOENIX', 'INDEX_SAGA', 'HANDLE_TIDE', 'RESET_ECHO', 'TIMEOUT_RIDDLE',
        'UNDEF_RIPPLE', 'OVERFLOW_THUNDER', 'PERM_CRYSTAL', 'ACCESS_LANTERN', 'ZERO_OBELISK',
        'IMPORT_ZEPHYR', 'CRIT_ANCHOR', 'OOM_SOLSTICE', 'CHECKSUM_FOREST', 'PROTO_AMBER',
        'SHAKE_MIRAGE', 'TOKEN_SHARD', 'CERT_DUSK', 'TLS_RUNE', 'DRIVER_NIMBUS',
        'BIOS_HALCYON', 'FIRM_ASTER', 'WATCH_NEPTUNE', 'POWER_BRAMBLE', 'THERM_PYRE',
        'CLOCK_VEIN', 'REG_CARMINE', 'BSOD_GLITCH', 'PANIC_DISCO', 'GHOST_SHELL',
        'TURBO_OFFLINE', 'FLUX_DESYNC', 'PRIME_BREACH', 'COFFEE_KERNEL', 'CTRL_LOOP',
        'MAGIC_SMOKE', 'BLINK_OFFLINE', 'COSMIC_FLIP', 'YAML_HORROR', 'REGEX_DEATH',
        'SUDO_DENIED', 'GIT_GHOST', 'NPM_VOID', 'HASH_FOG', 'PORT_CLOSED', 'PROXY_RIFT',
        'JSON_BROKEN', 'XML_LOST', 'DNS_GRIM', 'SSH_FROST',
      ];

      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const stateLeaderboard = document.getElementById('state-leaderboard');
      const startBtn = document.getElementById('start-btn');
      const exitBtn = document.getElementById('exit-btn');
      const timeDisplay = document.getElementById('time-display');
      const wpmDisplay = document.getElementById('wpm-display');
      const overriddenDisplay = document.getElementById('overridden-display');
      const errorTarget = document.getElementById('error-target');
      const errorInput = document.getElementById('error-input');
      const resultScore = document.getElementById('result-score');
      const resultOverridden = document.getElementById('result-overridden');
      const resultChars = document.getElementById('result-chars');
      const initBoxes = [
        document.getElementById('init-1'),
        document.getElementById('init-2'),
        document.getElementById('init-3'),
      ];
      const initialsError = document.getElementById('initials-error');
      const submitBtn = document.getElementById('submit-btn');
      const submitBtnText = document.getElementById('submit-btn-text');
      const skipBtn = document.getElementById('skip-btn');
      const rankNumber = document.getElementById('rank-number');
      const rankEyebrow = document.getElementById('rank-eyebrow');
      const rankDetail = document.getElementById('rank-detail');
      const leaderboardList = document.getElementById('leaderboard-list');
      const playAgainBtn = document.getElementById('play-again-btn');
      const exitDialog = document.getElementById('exit-dialog');
      const exitCancel = document.getElementById('exit-cancel');
      const exitConfirm = document.getElementById('exit-confirm');
      const shareFb = document.getElementById('share-fb');
      const shareX = document.getElementById('share-x');
      const shareNative = document.getElementById('share-native');
      const shareCopy = document.getElementById('share-copy');
      const copyToast = document.getElementById('copy-toast');

      let currentTarget = '';
      let queue = [];
      let charsTyped = 0;
      let overriddenCount = 0;
      let startTime = 0;
      let elapsedMs = 0;
      let timerHandle = null;
      let gameRunning = false;
      let finalScore = 0;
      let lastSubmittedRank = null;
      let lastSubmittedInitials = null;

      function showState(name) {
        [stateIntro, statePlaying, stateResult, stateLeaderboard].forEach(s => s.classList.remove('state--active'));
        if (name === 'intro')       stateIntro.classList.add('state--active');
        if (name === 'playing')     statePlaying.classList.add('state--active');
        if (name === 'result')      stateResult.classList.add('state--active');
        if (name === 'leaderboard') stateLeaderboard.classList.add('state--active');
      }

      function shuffle(arr) {
        const a = arr.slice();
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
      }

      function refillQueue() {
        queue = shuffle(ERROR_POOL);
      }

      function nextTarget() {
        if (queue.length === 0) refillQueue();
        currentTarget = queue.shift();
        renderTarget('');
      }

      function renderTarget(typed) {
        const target = currentTarget;
        const out = [];
        for (let i = 0; i < target.length; i++) {
          const tc = target[i];
          if (i < typed.length) {
            const ic = typed[i];
            const correct = ic.toLowerCase() === tc.toLowerCase();
            out.push(`<span class="${correct ? 'ch-good' : 'ch-bad'}">${escapeHtml(tc)}</span>`);
          } else if (i === typed.length) {
            out.push(`<span class="ch-cursor">${escapeHtml(tc)}</span>`);
          } else {
            out.push(`<span class="ch-pending">${escapeHtml(tc)}</span>`);
          }
        }
        errorTarget.innerHTML = out.join('');
      }

      function startGame() {
        charsTyped = 0;
        overriddenCount = 0;
        elapsedMs = 0;
        gameRunning = true;
        finalScore = 0;

        wpmDisplay.textContent = '0';
        overriddenDisplay.textContent = '0';
        timeDisplay.textContent = (TIME_LIMIT_MS / 1000).toFixed(1) + 's';

        refillQueue();
        nextTarget();

        errorInput.value = '';
        errorInput.disabled = false;

        showState('playing');
        setTimeout(() => errorInput.focus(), 50);

        startTime = performance.now();
        timerHandle = setInterval(updateTimer, 100);
      }

      function updateTimer() {
        elapsedMs = performance.now() - startTime;
        const remaining = Math.max(0, TIME_LIMIT_MS - elapsedMs);
        timeDisplay.textContent = (remaining / 1000).toFixed(1) + 's';

        const minutes = elapsedMs / 60000;
        if (minutes > 0) {
          const wpm = Math.round((charsTyped / 5) / minutes);
          wpmDisplay.textContent = String(wpm);
        }

        if (remaining <= 0) {
          endGame();
        }
      }

      errorInput.addEventListener('input', () => {
        if (!gameRunning) return;

        const typed = errorInput.value;
        renderTarget(typed);

        if (typed.length >= currentTarget.length) {
          const matches = typed.toLowerCase() === currentTarget.toLowerCase();
          if (matches) {
            charsTyped += currentTarget.length;
            overriddenCount++;
            overriddenDisplay.textContent = String(overriddenCount);
            errorInput.value = '';
            nextTarget();
          }
        }
      });

      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;
        clearInterval(timerHandle);
        errorInput.disabled = true;

        const minutes = TIME_LIMIT_MS / 60000;
        finalScore = Math.round((charsTyped / 5) / minutes);

        resultScore.textContent = String(finalScore);
        resultOverridden.textContent = String(overriddenCount);
        resultChars.textContent = String(charsTyped);

        initBoxes.forEach(b => { b.value = ''; b.classList.remove('initial-box--filled'); });
        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMIT SCORE';
        initialsError.textContent = '';

        showState('result');
        setTimeout(() => initBoxes[0].focus(), 100);
      }

      initBoxes.forEach((box, idx) => {
        box.addEventListener('input', (e) => {
          let val = box.value.toUpperCase();
          val = val.replace(/[^A-Z]/g, '');
          box.value = val;

          if (val.length === 1) {
            box.classList.add('initial-box--filled');
            if (idx < initBoxes.length - 1) initBoxes[idx + 1].focus();
            else box.blur();
          } else {
            box.classList.remove('initial-box--filled');
          }
          updateSubmitState();
        });

        box.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && box.value === '' && idx > 0) {
            initBoxes[idx - 1].focus();
            initBoxes[idx - 1].value = '';
            initBoxes[idx - 1].classList.remove('initial-box--filled');
            updateSubmitState();
          }
          if (e.key === 'Enter' && !submitBtn.disabled) submitScore();
        });

        box.addEventListener('focus', () => box.select());
      });

      function getInitials() { return initBoxes.map(b => b.value).join('').toUpperCase(); }

      function updateSubmitState() {
        const initials = getInitials();
        submitBtn.disabled = !/^[A-Z]{3}$/.test(initials);
      }

      async function submitScore() {
        const initials = getInitials();
        if (!/^[A-Z]{3}$/.test(initials)) return;

        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMITTING...';
        initialsError.textContent = '';

        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initials, score: finalScore }),
          });

          const data = await res.json();

          if (!res.ok) {
            initialsError.textContent = data.error || 'Could not save score. Try different initials.';
            submitBtn.disabled = false;
            submitBtnText.textContent = 'SUBMIT SCORE';
            return;
          }

          lastSubmittedInitials = initials;
          lastSubmittedRank = data.madeLeaderboard ? data.rank : null;
          renderLeaderboard(data.scores || []);
        } catch (err) {
          initialsError.textContent = 'Network error. Try again in a sec.';
          submitBtn.disabled = false;
          submitBtnText.textContent = 'SUBMIT SCORE';
        }
      }

      submitBtn.addEventListener('click', submitScore);

      skipBtn.addEventListener('click', async () => {
        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`);
          const data = await res.json();
          lastSubmittedRank = null;
          lastSubmittedInitials = null;
          renderLeaderboard(data.scores || []);
        } catch {
          renderLeaderboard([]);
        }
      });

      function renderLeaderboard(scores) {
        if (lastSubmittedRank) {
          const ord = ordinalSuffix(lastSubmittedRank);
          rankEyebrow.textContent = 'YOU RANKED';
          rankNumber.textContent = `#${lastSubmittedRank}`;
          rankDetail.textContent = lastSubmittedRank === 1 ? '🏆 First place!' : `${ord} place on the leaderboard`;
          document.getElementById('rank-reveal').style.display = '';
        } else if (lastSubmittedInitials) {
          rankEyebrow.textContent = 'SCORE SUBMITTED';
          rankNumber.textContent = String(finalScore);
          rankDetail.textContent = "Didn't crack the top 10 — keep practicing!";
          document.getElementById('rank-reveal').style.display = '';
        } else {
          document.getElementById('rank-reveal').style.display = 'none';
        }

        leaderboardList.innerHTML = '';

        if (scores.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'leaderboard-empty';
          empty.textContent = 'No scores yet. Be the first.';
          leaderboardList.appendChild(empty);
        } else {
          scores.slice(0, 10).forEach((entry, idx) => {
            const li = document.createElement('li');
            const rank = idx + 1;
            const isMe = lastSubmittedRank === rank && lastSubmittedInitials === entry.initials;
            li.className = `leaderboard-row leaderboard-row--${rank} ${isMe ? 'leaderboard-row--me' : ''}`;
            li.innerHTML = `
              <span class="rank-num">${rank}</span>
              <span class="rank-initials">${escapeHtml(entry.initials)}</span>
              <span class="rank-score">${entry.score}</span>
              ${isMe ? '<span class="rank-you">← YOU</span>' : ''}
            `;
            leaderboardList.appendChild(li);
          });
        }

        configureShare();
        showState('leaderboard');
      }

      function ordinalSuffix(n) {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      }

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function configureShare() {
        const url = window.location.href;
        const text = `I overrode ${overriddenCount} errors at ${finalScore} WPM on ${GAME_NAME} at Jake's Arcade. Beat me?`;
        const fullShare = `${text} ${url}`;

        shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`;
        shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;

        if (navigator.share) {
          shareNative.style.display = '';
          shareNative.onclick = async () => {
            try { await navigator.share({ title: GAME_NAME + " — Jake's Arcade", text, url }); } catch (e) { }
          };
        }

        shareCopy.onclick = async () => {
          try {
            await navigator.clipboard.writeText(fullShare);
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = fullShare;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          }
        };
      }

      playAgainBtn.addEventListener('click', () => startGame());

      function showExitDialog() {
        exitDialog.hidden = false;
        setTimeout(() => exitCancel.focus(), 50);
      }
      function hideExitDialog() { exitDialog.hidden = true; }

      exitBtn.addEventListener('click', () => {
        if (gameRunning) showExitDialog();
        else window.location.href = EXIT_TO;
      });

      exitCancel.addEventListener('click', hideExitDialog);
      exitConfirm.addEventListener('click', () => {
        gameRunning = false;
        clearInterval(timerHandle);
        window.location.href = EXIT_TO;
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !exitDialog.hidden) {
          hideExitDialog();
        }
      });

      startBtn.addEventListener('click', startGame);
    </script>

