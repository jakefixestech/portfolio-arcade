---
const CABINETS = [
  {
    name: 'Cursor Crawl',
    slug: 'cursor-crawl',
    tagline: 'Devour bugs. Grow longer. Don\'t crash.',
    iconKey: 'crawl',
  },
  {
    name: 'Loop Trap',
    slug: 'loop-trap',
    tagline: 'Collect tickets. Dodge the tracers.',
    iconKey: 'loop',
  },
  {
    name: 'Cable Untangle',
    slug: 'cable-untangle',
    tagline: 'Unplug cables one by one without crossing.',
    iconKey: 'cable',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Code Maze — Jake's Arcade</title>
    <meta name="description" content="The Code Maze. Navigate the labyrinth at Jake's Arcade." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800;900&family=Monoton&family=JetBrains+Mono:wght@400;600;700&family=Inter+Tight:wght@400;600;700;900&display=swap"
    />
  </head>

  <body>
    <script src="/arcade-sound.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (!window.ArcadeSound) return;
        window.ArcadeSound.injectToggleButton();
        window.ArcadeSound.attachMusicAutoStart('code-maze');

        // Cabinet hover + click sounds (stop music when entering a cabinet)
        document.querySelectorAll('.cabinet').forEach((c) => {
          c.addEventListener('mouseenter', () => window.ArcadeSound.play('button_hover'));
          c.addEventListener('click', () => {
            window.ArcadeSound.stopMusic();
            window.ArcadeSound.play('insert_coin');
          });
        });
      });
    </script>
    <main class="bay">

      <!-- Matrix rain (falling characters down both sides) -->
      <div class="matrix-rain matrix-rain--left" aria-hidden="true">
        <div class="rain-col rain-c1"><span>0</span><span>1</span><span>0</span><span>$</span><span>1</span><span>0</span><span>#</span><span>1</span><span>0</span><span>1</span><span>></span><span>0</span><span>1</span><span>{</span><span>0</span><span>1</span><span>1</span><span>0</span></div>
        <div class="rain-col rain-c2"><span>1</span><span>0</span><span>}</span><span>1</span><span>0</span><span>1</span><span>$</span><span>0</span><span>1</span><span>#</span><span>0</span><span>1</span><span>0</span><span>></span><span>1</span><span>0</span><span>1</span><span>0</span></div>
        <div class="rain-col rain-c3"><span>0</span><span>1</span><span>0</span><span>1</span><span>{</span><span>0</span><span>1</span><span>$</span><span>0</span><span>1</span><span>#</span><span>0</span><span>1</span><span>0</span><span>1</span><span>></span><span>0</span><span>1</span></div>
      </div>

      <div class="matrix-rain matrix-rain--right" aria-hidden="true">
        <div class="rain-col rain-c4"><span>1</span><span>0</span><span>1</span><span>0</span><span>$</span><span>1</span><span>0</span><span>#</span><span>1</span><span>0</span><span>></span><span>1</span><span>0</span><span>1</span><span>}</span><span>0</span><span>1</span><span>0</span></div>
        <div class="rain-col rain-c5"><span>0</span><span>1</span><span>0</span><span>{</span><span>1</span><span>0</span><span>$</span><span>1</span><span>0</span><span>1</span><span>0</span><span>#</span><span>1</span><span>0</span><span>1</span><span>></span><span>0</span><span>1</span></div>
        <div class="rain-col rain-c6"><span>1</span><span>0</span><span>1</span><span>0</span><span>1</span><span>$</span><span>0</span><span>}</span><span>1</span><span>0</span><span>#</span><span>1</span><span>0</span><span>1</span><span>0</span><span>1</span><span>></span><span>0</span></div>
      </div>

      <!-- Terminal grid floor (perspective-rendered grid) -->
      <div class="terminal-grid" aria-hidden="true"></div>

      <!-- Drifting green glitch motes -->
      <div class="ambient" aria-hidden="true">
        <span class="mote mt1"></span><span class="mote mt2"></span>
        <span class="mote mt3"></span><span class="mote mt4"></span>
        <span class="mote mt5"></span><span class="mote mt6"></span>
        <span class="mote mt7"></span><span class="mote mt8"></span>
      </div>

      <!-- Terminal HUD top-left (desktop only) -->
      <div class="terminal-hud" aria-hidden="true">
        <p class="hud-line hud-prompt">$ ./code_maze.sh</p>
        <p class="hud-line hud-status">[OK] mainframe online</p>
        <p class="hud-line hud-status">[OK] firewall bypassed</p>
        <p class="hud-line hud-status hud-blink">[..] awaiting cursor</p>
        <p class="hud-line hud-prompt hud-cursor">_</p>
      </div>

      <!-- Navigation -->
      <a href="https://jakefixestech.com" class="exit-sign" aria-label="Exit the arcade and return to Jake Fixes Tech">
        <span class="exit-arrow" aria-hidden="true">←</span>
        <span class="exit-label">EXIT</span>
      </a>

      <a href="/lobby" class="back-to-lobby" aria-label="Back to the lobby">
        <span class="back-arrow" aria-hidden="true">←</span>
        <span class="back-label">LOBBY</span>
      </a>

      <a href="/" class="portal-return" aria-label="Return to the portal">
        <span class="portal-return-icon" aria-hidden="true">↻</span>
        <span class="portal-return-label">PORTAL</span>
      </a>

      <!-- Wall sign -->
      <header class="bay-marquee">
        <p class="marquee-eyebrow">YOU HAVE ENTERED</p>
        <h1 class="marquee-title">CODE MAZE</h1>
        <p class="marquee-tagline">// chase the bugs. don't bite your tail.</p>
      </header>

      <!-- The maze floor with cabinet -->
      <section class="workshop" aria-label="Arcade cabinet">
        <div class="floor" aria-hidden="true"></div>

        <div class="cabinets">
          {CABINETS.map((cab, idx) => (
            <a
              href={`/${cab.slug}`}
              class="cabinet"
              style={`--cab-delay: ${0.5 + idx * 0.25}s;`}
              aria-label={`Play ${cab.name}: ${cab.tagline}`}
            >
              <span class="cabinet-spotlight" aria-hidden="true"></span>

              <div class="cab-marquee" aria-hidden="true">
                <div class="cab-marquee-bulbs">
                  <span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span>
                </div>
                <p class="cab-marquee-title">{cab.name}</p>
              </div>

              <div class="cab-screen" aria-hidden="true">
                <div class="cab-screen-glow"></div>
                <div class="cab-screen-content">
                  <span class="cab-screen-icon">
                    {cab.iconKey === 'crawl' && (
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <!-- Grid background hint -->
                        <rect x="6" y="6" width="68" height="68" rx="2" fill="#02100a" stroke="#166534" stroke-width="1.5"/>
                        <line x1="6" y1="22" x2="74" y2="22" stroke="rgba(74,222,128,0.12)" stroke-width="0.5"/>
                        <line x1="6" y1="38" x2="74" y2="38" stroke="rgba(74,222,128,0.12)" stroke-width="0.5"/>
                        <line x1="6" y1="54" x2="74" y2="54" stroke="rgba(74,222,128,0.12)" stroke-width="0.5"/>
                        <line x1="22" y1="6" x2="22" y2="74" stroke="rgba(74,222,128,0.12)" stroke-width="0.5"/>
                        <line x1="38" y1="6" x2="38" y2="74" stroke="rgba(74,222,128,0.12)" stroke-width="0.5"/>
                        <line x1="54" y1="6" x2="54" y2="74" stroke="rgba(74,222,128,0.12)" stroke-width="0.5"/>

                        <!-- Snake body segments (gold-to-amber gradient from head to tail) -->
                        <rect x="14" y="46" width="10" height="10" rx="1" fill="#d97706"/>
                        <rect x="14" y="38" width="10" height="10" rx="1" fill="#e08a0d"/>
                        <rect x="14" y="30" width="10" height="10" rx="1" fill="#ea9c14"/>
                        <rect x="22" y="30" width="10" height="10" rx="1" fill="#f0a91d"/>
                        <rect x="30" y="30" width="10" height="10" rx="1" fill="#f4b427"/>
                        <rect x="38" y="30" width="10" height="10" rx="1" fill="#f7be32"/>
                        <rect x="38" y="38" width="10" height="10" rx="1" fill="#f9c63d"/>

                        <!-- Snake head (cursor arrow pointing right toward bug) -->
                        <g transform="translate(50, 38) rotate(90)">
                          <path d="M 0 -8 L 6 5 L 1.5 5 L 3.5 9 L 0.5 10 L -1.5 5 L -6 5 Z" fill="#fbbf24" stroke="#92400e" stroke-width="1" stroke-linejoin="round"/>
                        </g>

                        <!-- Red bug (the prey) -->
                        <g transform="translate(60, 14)">
                          <ellipse cx="0" cy="0" rx="5" ry="6" fill="#dc2626" stroke="#7f1d1d" stroke-width="1"/>
                          <line x1="-2" y1="-4" x2="-4" y2="-7" stroke="#7f1d1d" stroke-width="1"/>
                          <line x1="2" y1="-4" x2="4" y2="-7" stroke="#7f1d1d" stroke-width="1"/>
                          <circle cx="-1.5" cy="-1" r="1" fill="#fff"/>
                          <circle cx="1.5" cy="-1" r="1" fill="#fff"/>
                        </g>
                      </svg>
                    )}
                    {cab.iconKey === 'loop' && (
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <!-- Maze background -->
                        <rect x="6" y="6" width="68" height="68" rx="2" fill="#02100a" stroke="#166534" stroke-width="1.5"/>

                        <!-- Maze walls (matrix green) -->
                        <line x1="6" y1="22" x2="30" y2="22" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="40" y1="22" x2="74" y2="22" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="22" y1="22" x2="22" y2="38" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="50" y1="22" x2="50" y2="38" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="6" y1="46" x2="22" y2="46" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="30" y1="38" x2="50" y2="38" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="58" y1="46" x2="74" y2="46" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="14" y1="54" x2="14" y2="74" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="30" y1="54" x2="50" y2="54" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="66" y1="54" x2="66" y2="74" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="22" y1="62" x2="38" y2="62" stroke="#4ade80" stroke-width="1.5"/>
                        <line x1="42" y1="62" x2="58" y2="62" stroke="#4ade80" stroke-width="1.5"/>

                        <!-- Tickets (small dots) -->
                        <circle cx="10" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="18" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="26" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="34" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="46" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="58" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="66" cy="14" r="1" fill="#fbbf24"/>
                        <circle cx="10" cy="42" r="1" fill="#fbbf24"/>
                        <circle cx="42" cy="42" r="1" fill="#fbbf24"/>
                        <circle cx="58" cy="50" r="1" fill="#fbbf24"/>
                        <circle cx="22" cy="58" r="1" fill="#fbbf24"/>
                        <circle cx="42" cy="58" r="1" fill="#fbbf24"/>

                        <!-- Power pellet (completed job) -->
                        <circle cx="10" cy="68" r="2.5" fill="#fbbf24">
                          <animate attributeName="opacity" values="1;0.4;1" dur="1s" repeatCount="indefinite"/>
                        </circle>
                        <circle cx="70" cy="68" r="2.5" fill="#fbbf24">
                          <animate attributeName="opacity" values="0.4;1;0.4" dur="1s" repeatCount="indefinite"/>
                        </circle>

                        <!-- Player cursor (gold arrow pointing right) -->
                        <g transform="translate(38, 30) rotate(90)">
                          <path d="M 0 -5 L 4 3 L 1 3 L 2.5 6 L 0.5 7 L -1 3 L -4 3 Z" fill="#fbbf24" stroke="#92400e" stroke-width="0.8" stroke-linejoin="round"/>
                        </g>

                        <!-- Tracer enemies (Pac-Man ghost shapes) -->
                        <!-- Pink Spam ghost top -->
                        <g transform="translate(10, 30)">
                          <path d="M -4 0 Q -4 -4 0 -4 Q 4 -4 4 0 L 4 3 L 3 4 L 2 3 L 1 4 L 0 3 L -1 4 L -2 3 L -3 4 L -4 3 Z" fill="#ec4899" stroke="#9d174d" stroke-width="0.5"/>
                          <circle cx="-1.5" cy="-1" r="0.7" fill="#fff"/>
                          <circle cx="1.5" cy="-1" r="0.7" fill="#fff"/>
                        </g>
                        <!-- Red Virus ghost middle -->
                        <g transform="translate(58, 30)">
                          <path d="M -4 0 Q -4 -4 0 -4 Q 4 -4 4 0 L 4 3 L 3 4 L 2 3 L 1 4 L 0 3 L -1 4 L -2 3 L -3 4 L -4 3 Z" fill="#ef4444" stroke="#7f1d1d" stroke-width="0.5"/>
                          <circle cx="-1.5" cy="-1" r="0.7" fill="#fff"/>
                          <circle cx="1.5" cy="-1" r="0.7" fill="#fff"/>
                        </g>
                        <!-- Cyan 404 ghost bottom -->
                        <g transform="translate(30, 68)">
                          <path d="M -4 0 Q -4 -4 0 -4 Q 4 -4 4 0 L 4 3 L 3 4 L 2 3 L 1 4 L 0 3 L -1 4 L -2 3 L -3 4 L -4 3 Z" fill="#22d3ee" stroke="#0891b2" stroke-width="0.5"/>
                          <circle cx="-1.5" cy="-1" r="0.7" fill="#fff"/>
                          <circle cx="1.5" cy="-1" r="0.7" fill="#fff"/>
                        </g>
                      </svg>
                    )}
                    {cab.iconKey === 'cable' && (
                      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                        <!-- Server rack background -->
                        <rect x="6" y="6" width="68" height="68" rx="2" fill="#02100a" stroke="#166534" stroke-width="1.5"/>

                        <!-- Left side jacks (top-to-bottom) -->
                        <rect x="8" y="14" width="6" height="6" rx="1" fill="#1e3a8a" stroke="#3b82f6" stroke-width="0.8"/>
                        <rect x="8" y="26" width="6" height="6" rx="1" fill="#7c2d12" stroke="#f97316" stroke-width="0.8"/>
                        <rect x="8" y="38" width="6" height="6" rx="1" fill="#14532d" stroke="#4ade80" stroke-width="0.8"/>
                        <rect x="8" y="50" width="6" height="6" rx="1" fill="#7e1d1d" stroke="#ef4444" stroke-width="0.8"/>
                        <rect x="8" y="62" width="6" height="6" rx="1" fill="#581c87" stroke="#a855f7" stroke-width="0.8"/>

                        <!-- Right side jacks -->
                        <rect x="66" y="14" width="6" height="6" rx="1" fill="#581c87" stroke="#a855f7" stroke-width="0.8"/>
                        <rect x="66" y="26" width="6" height="6" rx="1" fill="#14532d" stroke="#4ade80" stroke-width="0.8"/>
                        <rect x="66" y="38" width="6" height="6" rx="1" fill="#1e3a8a" stroke="#3b82f6" stroke-width="0.8"/>
                        <rect x="66" y="50" width="6" height="6" rx="1" fill="#7c2d12" stroke="#f97316" stroke-width="0.8"/>
                        <rect x="66" y="62" width="6" height="6" rx="1" fill="#7e1d1d" stroke="#ef4444" stroke-width="0.8"/>

                        <!-- Tangled cables (curved bezier paths crossing each other) -->
                        <!-- Blue cable (left top → right middle, crosses over) -->
                        <path d="M 14 17 Q 30 17, 40 35 T 66 41" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" opacity="0.9"/>
                        <!-- Orange cable (left 2nd → right 4th, crosses through) -->
                        <path d="M 14 29 Q 35 60, 50 53 T 66 53" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round" opacity="0.9"/>
                        <!-- Green cable (left middle → right 2nd) -->
                        <path d="M 14 41 Q 28 25, 45 30 T 66 29" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" opacity="0.9"/>
                        <!-- Red cable (left 4th → right bottom, crosses through) -->
                        <path d="M 14 53 Q 30 70, 50 65 T 66 65" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" opacity="0.9"/>
                        <!-- Purple cable (left bottom → right top, big diagonal) -->
                        <path d="M 14 65 Q 40 30, 60 22 T 66 17" fill="none" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round" opacity="0.9"/>

                        <!-- Highlight one cable (the easiest to pull) -->
                        <path d="M 14 41 Q 28 25, 45 30 T 66 29" fill="none" stroke="#86efac" stroke-width="0.8" stroke-linecap="round" opacity="0.8" stroke-dasharray="2 2">
                          <animate attributeName="stroke-dashoffset" values="0;-4" dur="0.8s" repeatCount="indefinite"/>
                        </path>
                      </svg>
                    )}
                  </span>
                  <span class="cab-screen-tagline">{cab.tagline}</span>
                  <span class="cab-screen-press">▸ PRESS START</span>
                </div>
              </div>

              <div class="cab-controls" aria-hidden="true">
                <span class="cab-joystick">
                  <span class="cab-joystick-base"></span>
                  <span class="cab-joystick-stick"></span>
                  <span class="cab-joystick-ball"></span>
                </span>
                <span class="cab-buttons">
                  <span class="cab-btn cab-btn-green"></span>
                  <span class="cab-btn cab-btn-green2"></span>
                  <span class="cab-btn cab-btn-yellow"></span>
                </span>
              </div>

              <div class="cab-coin" aria-hidden="true">
                <span class="cab-coin-slot"></span>
                <span class="cab-coin-label">25¢ INSERT COIN</span>
              </div>

              <span class="cab-shadow" aria-hidden="true"></span>
            </a>
          ))}
        </div>
      </section>

    </main>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; tap-highlight-color: transparent; }

      :root {
        --c-bg: #020610;
        --c-green: #4ade80;
        --c-green-bright: #86efac;
        --c-green-glow: rgba(74, 222, 128, 0.7);
        --c-green-soft: rgba(74, 222, 128, 0.2);
      }

      html, body {
        background: var(--c-bg);
        color: #fff;
        font-family: 'Inter Tight', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
      }

      html { overflow-x: hidden; }
      body { overflow-x: hidden; max-width: 100vw; }

      .bay {
        position: relative;
        min-height: 100vh;
        padding: 0 1.5rem 5rem;
        overflow-x: hidden;
        background:
          radial-gradient(ellipse at 50% 0%, rgba(74, 222, 128, 0.12) 0%, transparent 55%),
          radial-gradient(ellipse at 20% 80%, rgba(74, 222, 128, 0.08) 0%, transparent 55%),
          radial-gradient(ellipse at 80% 80%, rgba(74, 222, 128, 0.08) 0%, transparent 55%),
          linear-gradient(180deg, #051a10 0%, #02100a 50%, #010805 100%);
      }

      /* ============================================ */
      /* MATRIX RAIN                                  */
      /* ============================================ */
      .matrix-rain {
        position: fixed;
        top: 0;
        bottom: 0;
        width: 12%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
        opacity: 0.55;
      }

      .matrix-rain--left { left: 0; }
      .matrix-rain--right { right: 0; }

      .rain-col {
        position: absolute;
        top: -100%;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.6;
        color: #4ade80;
        text-shadow: 0 0 6px rgba(74, 222, 128, 0.7);
        white-space: nowrap;
      }

      .rain-col span {
        display: block;
        animation: rain-fade 3s ease-in-out infinite;
      }

      .rain-col span:nth-child(odd)  { animation-delay: 0.2s; }
      .rain-col span:nth-child(3n)   { animation-delay: 0.5s; color: #86efac; text-shadow: 0 0 8px rgba(134, 239, 172, 0.9); }
      .rain-col span:nth-child(5n)   { animation-delay: 0.9s; }

      @keyframes rain-fade {
        0%, 100% { opacity: 0.3; }
        50%      { opacity: 1; }
      }

      .rain-c1 { left: 15%; animation: rain-fall 9s linear infinite; }
      .rain-c2 { left: 50%; animation: rain-fall 11s linear infinite; animation-delay: -3s; }
      .rain-c3 { left: 80%; animation: rain-fall 8s linear infinite; animation-delay: -5s; }
      .rain-c4 { left: 20%; animation: rain-fall 10s linear infinite; }
      .rain-c5 { left: 55%; animation: rain-fall 9s linear infinite; animation-delay: -4s; }
      .rain-c6 { left: 85%; animation: rain-fall 12s linear infinite; animation-delay: -6s; }

      @keyframes rain-fall {
        0%   { transform: translateY(0); }
        100% { transform: translateY(220vh); }
      }

      /* ============================================ */
      /* TERMINAL GRID FLOOR                          */
      /* ============================================ */
      .terminal-grid {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 50vh;
        pointer-events: none;
        z-index: 0;
        background-image:
          linear-gradient(rgba(74, 222, 128, 0.18) 1px, transparent 1px),
          linear-gradient(90deg, rgba(74, 222, 128, 0.18) 1px, transparent 1px);
        background-size: 60px 60px;
        background-position: center bottom;
        transform: perspective(500px) rotateX(60deg);
        transform-origin: center bottom;
        mask-image: linear-gradient(180deg, transparent 0%, rgba(0,0,0,1) 40%, rgba(0,0,0,1) 100%);
        -webkit-mask-image: linear-gradient(180deg, transparent 0%, rgba(0,0,0,1) 40%, rgba(0,0,0,1) 100%);
        animation: grid-pulse 5s ease-in-out infinite;
      }

      @keyframes grid-pulse {
        0%, 100% { opacity: 0.7; }
        50%      { opacity: 1; }
      }

      /* ============================================ */
      /* AMBIENT MOTES                                */
      /* ============================================ */
      .ambient {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
      }

      .mote {
        position: absolute;
        width: 3px;
        height: 3px;
        background: #86efac;
        border-radius: 50%;
        box-shadow: 0 0 6px #4ade80, 0 0 12px rgba(74, 222, 128, 0.6);
        opacity: 0;
      }

      .mt1 { left: 18%; bottom: 5%; animation: mote-rise 9s ease-in-out 0.5s infinite; }
      .mt2 { left: 32%; bottom: 5%; animation: mote-rise 11s ease-in-out 2.5s infinite; }
      .mt3 { left: 46%; bottom: 5%; animation: mote-rise 8s ease-in-out 4s   infinite; }
      .mt4 { left: 60%; bottom: 5%; animation: mote-rise 12s ease-in-out 1s  infinite; }
      .mt5 { left: 74%; bottom: 5%; animation: mote-rise 9s ease-in-out 5s   infinite; }
      .mt6 { left: 28%; bottom: 5%; animation: mote-rise 10s ease-in-out 3s  infinite; }
      .mt7 { left: 52%; bottom: 5%; animation: mote-rise 13s ease-in-out 7s  infinite; }
      .mt8 { left: 68%; bottom: 5%; animation: mote-rise 13s ease-in-out 6s  infinite; }

      @keyframes mote-rise {
        0%   { transform: translateY(0) translateX(0); opacity: 0; }
        15%  { opacity: 1; }
        50%  { transform: translateY(-50vh) translateX(15px); opacity: 0.9; }
        100% { transform: translateY(-100vh) translateX(-10px); opacity: 0; }
      }

      /* ============================================ */
      /* TERMINAL HUD                                 */
      /* ============================================ */
      .terminal-hud {
        position: fixed;
        top: 100px;
        left: 1.75rem;
        z-index: 1;
        padding: 0.7rem 0.95rem;
        background: rgba(0, 0, 0, 0.65);
        border: 1px solid rgba(74, 222, 128, 0.4);
        border-radius: 4px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 600;
        color: #4ade80;
        letter-spacing: 0.04em;
        line-height: 1.7;
        box-shadow: 0 0 16px rgba(74, 222, 128, 0.25), inset 0 0 8px rgba(74, 222, 128, 0.05);
        pointer-events: none;
        min-width: 220px;
      }

      .hud-line {
        white-space: nowrap;
      }

      .hud-prompt {
        color: #86efac;
        text-shadow: 0 0 4px rgba(134, 239, 172, 0.7);
      }

      .hud-status {
        color: rgba(74, 222, 128, 0.8);
      }

      .hud-blink {
        animation: hud-blink 1.4s steps(2) infinite;
      }

      @keyframes hud-blink {
        0%, 50%   { opacity: 1; }
        51%, 100% { opacity: 0.4; }
      }

      .hud-cursor {
        animation: cursor-blink 1s steps(2) infinite;
        font-weight: 900;
      }

      @keyframes cursor-blink {
        0%, 50%   { opacity: 1; }
        51%, 100% { opacity: 0; }
      }

      @media (max-width: 1100px) {
        .terminal-hud { display: none; }
      }

      /* ============================================ */
      /* NAVIGATION                                   */
      /* ============================================ */
      .exit-sign {
        position: fixed;
        bottom: 1.25rem;
        right: 1.25rem;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 1.1rem;
        background: rgba(0, 0, 0, 0.5);
        border: 2px solid #22c55e;
        border-radius: 4px;
        color: #4ade80;
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.25em;
        text-decoration: none;
        text-shadow: 0 0 6px rgba(74, 222, 128, 0.9), 0 0 14px rgba(74, 222, 128, 0.5);
        box-shadow: 0 0 0 1px rgba(74, 222, 128, 0.2), 0 0 18px rgba(74, 222, 128, 0.45), inset 0 0 12px rgba(74, 222, 128, 0.18);
        transition: transform 0.2s, box-shadow 0.2s;
        animation: exit-flicker 6s steps(60) infinite;
      }

      .exit-arrow { font-size: 1rem; font-weight: 800; }

      .exit-sign:hover, .exit-sign:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 0 0 1px rgba(74, 222, 128, 0.4), 0 0 30px rgba(74, 222, 128, 0.7), inset 0 0 16px rgba(74, 222, 128, 0.3);
        outline: none;
      }

      @keyframes exit-flicker {
        0%, 100% { opacity: 1; }
        96%, 96.5% { opacity: 0.4; }
        97%, 97.4% { opacity: 1; }
        97.5%, 97.8% { opacity: 0.5; }
        98% { opacity: 1; }
      }

      .back-to-lobby {
        position: fixed;
        top: 1.25rem;
        right: 1.25rem;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: rgba(0, 0, 0, 0.5);
        border: 1.5px solid rgba(74, 222, 128, 0.5);
        border-radius: 4px;
        color: var(--c-green-bright);
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-decoration: none;
        text-shadow: 0 0 6px var(--c-green-glow);
        box-shadow: 0 0 14px rgba(74, 222, 128, 0.3);
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      }

      .back-to-lobby:hover, .back-to-lobby:focus-visible {
        transform: translateY(-2px);
        border-color: var(--c-green-bright);
        box-shadow: 0 0 24px rgba(74, 222, 128, 0.6);
        outline: none;
      }

      .portal-return {
        position: fixed;
        top: 1.25rem;
        left: 1.25rem;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 0.95rem;
        background: rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(168, 85, 247, 0.4);
        border-radius: 999px;
        color: rgba(196, 181, 253, 0.85);
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-decoration: none;
        text-shadow: 0 0 6px rgba(168, 85, 247, 0.5);
        box-shadow: 0 0 12px rgba(168, 85, 247, 0.2);
        transition: color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }

      .portal-return-icon {
        font-size: 0.85rem;
        animation: portal-return-spin 6s linear infinite;
        display: inline-block;
      }

      @keyframes portal-return-spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
      }

      .portal-return:hover, .portal-return:focus-visible {
        color: #fff;
        border-color: rgba(168, 85, 247, 0.8);
        box-shadow: 0 0 20px rgba(168, 85, 247, 0.5);
        transform: translateY(-2px);
        outline: none;
      }

      /* ============================================ */
      /* WALL MARQUEE                                 */
      /* ============================================ */
      .bay-marquee {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 5rem 1rem 2.5rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .marquee-eyebrow {
        font-family: 'Orbitron', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.45em;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 1rem;
      }

      .marquee-title {
        font-family: 'Monoton', 'Orbitron', system-ui, sans-serif;
        font-size: clamp(2.5rem, 9vw, 6rem);
        font-weight: 400;
        line-height: 1;
        letter-spacing: 0.06em;
        color: #d1fae5;
        text-shadow:
          0 0 6px rgba(74, 222, 128, 1),
          0 0 14px rgba(74, 222, 128, 0.9),
          0 0 28px rgba(74, 222, 128, 0.7),
          0 0 56px rgba(74, 222, 128, 0.4);
        animation: marquee-flicker 8s steps(80) infinite;
      }

      @keyframes marquee-flicker {
        0%, 100% { opacity: 1; }
        45%, 45.4% { opacity: 0.6; }
        45.6%, 46% { opacity: 1; }
        78%, 78.3% { opacity: 0.45; }
        78.6%, 79% { opacity: 1; }
      }

      .marquee-tagline {
        margin-top: 1.5rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: rgba(74, 222, 128, 0.7);
        text-shadow: 0 0 4px rgba(74, 222, 128, 0.4);
      }

      /* ============================================ */
      /* WORKSHOP & CABINET                           */
      /* ============================================ */
      .workshop {
        position: relative;
        z-index: 2;
        max-width: 1400px;
        margin: 2rem auto 0;
      }

      .floor {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 35%;
        background:
          linear-gradient(180deg, transparent 0%, rgba(74, 222, 128, 0.06) 40%, rgba(74, 222, 128, 0.10) 100%);
        border-top: 1px solid rgba(74, 222, 128, 0.2);
        pointer-events: none;
      }

      .cabinets {
        position: relative;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
        align-items: end;
        justify-items: center;
      }

      .cabinet {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: #fff;
        max-width: 320px;
        width: 100%;
        opacity: 0;
        animation: cabinet-arrive 0.8s ease-out var(--cab-delay, 0.5s) forwards;
        transition: transform 0.3s;
      }

      @keyframes cabinet-arrive {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .cabinet:hover, .cabinet:focus-visible {
        transform: translateY(-8px);
        outline: none;
      }

      .cabinet-spotlight {
        position: absolute;
        top: -8%;
        left: 50%;
        transform: translateX(-50%);
        width: 140%;
        height: 110%;
        background: radial-gradient(ellipse at 50% 0%, rgba(74, 222, 128, 0.28) 0%, transparent 55%);
        pointer-events: none;
        z-index: 0;
      }

      .cab-marquee {
        position: relative;
        z-index: 2;
        width: 92%;
        padding: 0.85rem 1rem 0.7rem;
        background: linear-gradient(180deg, #166534 0%, #02100a 100%);
        border: 2px solid #166534;
        border-bottom: none;
        border-radius: 8px 8px 0 0;
        text-align: center;
        box-shadow:
          inset 0 0 14px rgba(74, 222, 128, 0.45),
          0 0 18px rgba(74, 222, 128, 0.45);
      }

      .cab-marquee-bulbs {
        display: flex;
        justify-content: center;
        gap: 0.35rem;
        margin-bottom: 0.4rem;
      }

      .cab-marquee-bulbs span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fbbf24;
        box-shadow: 0 0 4px #fbbf24, 0 0 8px rgba(251, 191, 36, 0.7);
        animation: bulb-blink 1.6s ease-in-out infinite;
      }

      .cab-marquee-bulbs span:nth-child(2n) { animation-delay: 0.3s; }
      .cab-marquee-bulbs span:nth-child(3n) { animation-delay: 0.6s; }

      @keyframes bulb-blink {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.4; transform: scale(0.85); }
      }

      .cab-marquee-title {
        font-family: 'Monoton', 'Orbitron', system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(1rem, 1.5vw, 1.3rem);
        letter-spacing: 0.08em;
        color: #d1fae5;
        text-shadow:
          0 0 4px rgba(74, 222, 128, 0.95),
          0 0 10px rgba(74, 222, 128, 0.6);
      }

      .cab-screen {
        position: relative;
        z-index: 2;
        width: 92%;
        aspect-ratio: 1.05;
        background: #02100a;
        border: 8px solid #1e293b;
        border-top: none;
        overflow: hidden;
        box-shadow:
          inset 0 0 0 2px #010805,
          inset 0 0 30px rgba(74, 222, 128, 0.3),
          0 0 24px rgba(74, 222, 128, 0.45);
      }

      .cab-screen-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at center, rgba(74, 222, 128, 0.22) 0%, transparent 60%);
        pointer-events: none;
      }

      .cab-screen-content {
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.85rem;
        padding: 1.25rem;
        background:
          repeating-linear-gradient(0deg, transparent 0, transparent 3px, rgba(0, 0, 0, 0.18) 3px, rgba(0, 0, 0, 0.18) 4px);
      }

      .cab-screen-icon {
        width: clamp(70px, 16vw, 120px);
        height: clamp(70px, 16vw, 120px);
        filter: drop-shadow(0 0 8px rgba(74, 222, 128, 0.7));
      }

      .cab-screen-icon svg { width: 100%; height: 100%; }

      .cab-screen-tagline {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(0.7rem, 1vw, 0.85rem);
        color: #86efac;
        text-align: center;
        line-height: 1.4;
        max-width: 240px;
        opacity: 0.9;
      }

      .cab-screen-press {
        font-family: 'Orbitron', system-ui, sans-serif;
        font-weight: 800;
        font-size: clamp(0.75rem, 1vw, 0.95rem);
        letter-spacing: 0.2em;
        color: #fbbf24;
        text-shadow: 0 0 6px rgba(251, 191, 36, 0.8);
        animation: press-blink 1.4s steps(2) infinite;
      }

      @keyframes press-blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0.35; }
      }

      .cab-controls {
        position: relative;
        z-index: 2;
        width: 92%;
        padding: 0.85rem 1.25rem;
        background: linear-gradient(180deg, #475569 0%, #334155 100%);
        border: 2px solid #1e293b;
        border-top: none;
        border-bottom: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: inset 0 4px 6px rgba(0, 0, 0, 0.3);
      }

      .cab-joystick {
        position: relative;
        width: 30px;
        height: 30px;
        flex-shrink: 0;
      }

      .cab-joystick-base {
        position: absolute;
        bottom: 0; left: 50%;
        transform: translateX(-50%);
        width: 22px;
        height: 8px;
        background: #0f172a;
        border-radius: 50%;
      }

      .cab-joystick-stick {
        position: absolute;
        bottom: 4px; left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 18px;
        background: linear-gradient(90deg, #1e293b, #475569, #1e293b);
        border-radius: 2px;
      }

      .cab-joystick-ball {
        position: absolute;
        top: 0; left: 50%;
        transform: translateX(-50%);
        width: 12px;
        height: 12px;
        background: radial-gradient(circle at 30% 30%, #4ade80, #166534);
        border-radius: 50%;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.5), 0 0 6px rgba(74, 222, 128, 0.5);
      }

      .cab-buttons {
        display: flex;
        gap: 0.4rem;
        align-items: center;
      }

      .cab-btn {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1.5px solid #0f172a;
        box-shadow:
          inset 0 -2px 3px rgba(0, 0, 0, 0.4),
          inset 0 1px 1px rgba(255, 255, 255, 0.3);
      }

      .cab-btn-green   { background: radial-gradient(circle at 30% 30%, #4ade80, #166534); }
      .cab-btn-green2  { background: radial-gradient(circle at 30% 30%, #86efac, #15803d); }
      .cab-btn-yellow  { background: radial-gradient(circle at 30% 30%, #fbbf24, #b45309); }

      .cab-coin {
        position: relative;
        z-index: 2;
        width: 92%;
        padding: 1rem 1rem 1.25rem;
        background: linear-gradient(180deg, #1e293b 0%, #02100a 100%);
        border: 2px solid #010805;
        border-top: none;
        border-radius: 0 0 6px 6px;
        text-align: center;
        box-shadow:
          inset 0 0 14px rgba(0, 0, 0, 0.6),
          0 6px 20px rgba(0, 0, 0, 0.5);
      }

      .cab-coin-slot {
        display: block;
        width: 50px;
        height: 4px;
        margin: 0 auto 0.5rem;
        background: #010805;
        border-radius: 1px;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.9);
      }

      .cab-coin-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        color: #a3b1c2;
      }

      .cab-shadow {
        position: absolute;
        bottom: -12px;
        left: 8%; right: 8%;
        height: 18px;
        background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7) 0%, transparent 70%);
        filter: blur(6px);
        z-index: 0;
      }

      /* ============================================ */
      /* RESPONSIVE                                   */
      /* ============================================ */
      @media (max-width: 900px) {
        .cabinets {
          grid-template-columns: 1fr;
          gap: 3rem;
          max-width: 360px;
        }
        .cabinet { max-width: 320px; }
      }

      @media (min-width: 901px) and (max-width: 1100px) {
        .cabinets { gap: 1.5rem; }
        .cabinet { max-width: 280px; }
      }

      @media (max-width: 600px) {
        .bay { padding: 0 1rem 4rem; }
        .bay-marquee { padding: 4rem 0.5rem 1.5rem; }

        .matrix-rain { width: 8%; opacity: 0.35; }

        .exit-sign, .back-to-lobby {
          padding: 0.5rem 0.75rem;
          font-size: 0.7rem;
          letter-spacing: 0.15em;
        }
        .exit-sign { bottom: 0.75rem; right: 0.75rem; }
        .back-to-lobby {
          top: 0.75rem;
          right: 0.75rem;
          max-width: calc(100vw - 1.5rem);
        }
        .portal-return {
          top: 0.6rem;
          left: 0.6rem;
          padding: 0.45rem 0.75rem;
          font-size: 0.7rem;
          letter-spacing: 0.12em;
          gap: 0.35rem;
          max-width: calc(100vw - 1.2rem);
        }
        .portal-return-icon { font-size: 0.7rem; }

        .cabinets { padding: 1rem 0 3rem; }
        .cabinet { max-width: 280px; }
      }

      @media (min-width: 1500px) {
        .cabinets { gap: 3rem; max-width: 1300px; }
        .cabinet { max-width: 360px; }
      }

      /* ============================================ */
      /* REDUCED MOTION                               */
      /* ============================================ */
      @media (prefers-reduced-motion: reduce) {
        .marquee-title, .exit-sign, .mote, .cab-marquee-bulbs span,
        .cab-screen-press, .portal-return-icon, .cabinet,
        .rain-col, .rain-col span, .terminal-grid,
        .hud-blink, .hud-cursor {
          animation: none !important;
        }
        .cabinet { opacity: 1; }
      }
    </style>
  </body>
</html>
