<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Loop Trap — Jake's Arcade</title>
    <meta name="description" content="Collect tickets and avoid the tracers in a circuit-board maze. Pac-Man with a Jake Fixes Tech twist." />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Loop Trap — Jake's Arcade" />
    <meta property="og:description" content="Collect tickets and avoid the tracers in a circuit-board maze." />
    <meta property="og:url" content="https://arcade.jakefixestech.com/loop-trap" />
    <meta property="og:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />
    <meta property="og:site_name" content="Jake's Arcade" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Loop Trap — Jake's Arcade" />
    <meta name="twitter:description" content="Collect tickets, dodge tracers." />
    <meta name="twitter:image" content="https://arcade.jakefixestech.com/og-arcade.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Monoton&display=swap"
      />
      <style>
        .noscript-warning {
          position: fixed; inset: 0; z-index: 9999;
          display: flex; align-items: center; justify-content: center;
          padding: 2rem; background: #050214; color: #fff;
          font-family: 'Inter Tight', system-ui, sans-serif; text-align: center;
        }
        .noscript-warning a { color: #67e8f9; }
      </style>
    </noscript>
  </head>

  <body>
    <noscript>
      <div class="noscript-warning" role="alert">
        <div>
          <h1 style="font-family: 'Monoton', sans-serif; font-size: 2rem; color: #fde68a; margin-bottom: 1rem;">JavaScript Required</h1>
          <p>This game needs JavaScript to run. Please enable it and refresh the page.</p>
          <p style="margin-top: 1rem;"><a href="https://jakefixestech.com">Return to Jake Fixes Tech</a></p>
        </div>
      </div>
    </noscript>
    <script src="/arcade-sound.js" is:inline></script>
    <script is:inline>
      // Arcade sound — universal hooks (toggle button, ambient hum, common events)
      window.addEventListener('DOMContentLoaded', () => {
        if (!window.ArcadeSound) return;
        window.ArcadeSound.injectToggleButton();

// Common UI sounds
        const startBtn = document.getElementById('start-btn');
        if (startBtn) startBtn.addEventListener('click', () => {
          window.ArcadeSound.play('insert_coin');
          window.ArcadeSound.startMusic('loop-trap');
        });

        const submitBtn = document.getElementById('submit-btn');
        if (submitBtn) submitBtn.addEventListener('click', () => window.ArcadeSound.play('button_click'));

        const playAgainBtn = document.getElementById('play-again-btn');
        if (playAgainBtn) playAgainBtn.addEventListener('click', () => {
          window.ArcadeSound.play('coin');
          window.ArcadeSound.startMusic('loop-trap');
        });
      });
    </script>
    <main class="page">

      <button id="exit-btn" type="button" class="exit-btn" aria-label="Back to Code Maze">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 9 6 L 4 12 L 9 18 M 4 12 L 19 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="exit-btn-label">CODE MAZE</span>
      </button>

