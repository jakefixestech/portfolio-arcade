        </div>

      </section>

      <div id="exit-dialog" class="dialog" role="dialog" aria-modal="true" aria-labelledby="exit-dialog-title" hidden>
        <div class="dialog-backdrop"></div>
        <div class="dialog-content">
          <h2 id="exit-dialog-title" class="dialog-title">Exit mid-game?</h2>
          <p class="dialog-text">Your score won't be saved if you leave now.</p>
          <div class="dialog-buttons">
            <button id="exit-cancel" type="button" class="ghost-btn">Keep playing</button>
            <button id="exit-confirm" type="button" class="danger-btn">Exit anyway</button>
          </div>
        </div>
      </div>
    </main>

    <script>
      // @ts-nocheck

      // ============================================================
      // LOOP TRAP — Pac-Man style
      // ============================================================
      // Maze is a fixed grid. # = wall, . = ticket (dot), o = power pellet,
      // ' ' = empty corridor, P = player spawn, T = tracer pen exit/spawn,
      // - = pen door (passable only by tracers leaving). 'a' = ambient empty
      // (no ticket spawned but walkable, used for the pen interior).
      // 21 cols x 23 rows feels good and divides nicely.
      // ============================================================

      const RAW_MAZE = [
        '#####################',
        '#.........#.........#',
        '#o###.###.#.###.###o#',
        '#.###.###.#.###.###.#',
        '#...................#',
        '#.###.#.#####.#.###.#',
        '#.....#...#...#.....#',
        '#####.### # ###.#####',
        '    #.#       #.#    ',
        '#####.# ##-## #.#####',
        'a   a.  #aaaaa#  .a   ',
        '#####.# #aaaaa# #.#####',
        '    #.# ####### #.#    ',
        '#####.#         #.#####',
        '#.........#.........#',
        '#.###.###.#.###.###.#',
        '#o..#.....P.....#..o#',
        '###.#.#.#####.#.#.###',
        '#.....#...#...#.....#',
        '#.#######.#.#######.#',
        '#...................#',
        '#####################',
      ];

      // Normalize widths (some rows are shorter for tunnels)
      const COLS = 21;
      const ROWS = RAW_MAZE.length;
      const MAZE = RAW_MAZE.map(row => {
        if (row.length < COLS) return row.padEnd(COLS, ' ');
        if (row.length > COLS) return row.substring(0, COLS);
        return row;
      });

      const CANVAS_W = 420;
      const CANVAS_H = 480;
      // Some vertical headroom for HUD-like spacing inside canvas
      const CELL = Math.floor(Math.min(CANVAS_W / COLS, CANVAS_H / ROWS));
      const OFFSET_X = Math.floor((CANVAS_W - CELL * COLS) / 2);
      const OFFSET_Y = Math.floor((CANVAS_H - CELL * ROWS) / 2);

      const GAME_SLUG = 'loop-trap';
      const GAME_NAME = 'Loop Trap';
      const EXIT_TO = '/code-maze';

      // Tracer (ghost) definitions
      const TRACERS = [
        { name: 'Spam',   color: '#ec4899', stroke: '#9d174d', personality: 'random'  },
        { name: 'Virus',  color: '#ef4444', stroke: '#7f1d1d', personality: 'chaser'  },
        { name: 'Crash',  color: '#f97316', stroke: '#9a3412', personality: 'flank'   },
        { name: '404',    color: '#22d3ee', stroke: '#0891b2', personality: 'patrol'  },
      ];

      const POWER_DURATION_MS = 6000; // tracers vulnerable
      const POWER_FLASH_MS = 2000;    // last 2s of power = flashing warning

      // === DOM refs ===
      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const stateLeaderboard = document.getElementById('state-leaderboard');
      const startBtn = document.getElementById('start-btn');
      const exitBtn = document.getElementById('exit-btn');
      const scoreDisplay = document.getElementById('score-display');
      const levelDisplay = document.getElementById('level-display');
      const livesDisplay = document.getElementById('lives-display');
      const canvas = document.getElementById('game-canvas');
      const ctx = canvas.getContext('2d');
      const boardOverlay = document.getElementById('board-overlay');
      const overlayText = document.getElementById('overlay-text');
      const resultScore = document.getElementById('result-score');
      const resultLevel = document.getElementById('result-level');
      const initBoxes = [
        document.getElementById('init-1'),
        document.getElementById('init-2'),
        document.getElementById('init-3'),
      ];
      const initialsError = document.getElementById('initials-error');
      const submitBtn = document.getElementById('submit-btn');
      const submitBtnText = document.getElementById('submit-btn-text');
      const skipBtn = document.getElementById('skip-btn');
      const rankNumber = document.getElementById('rank-number');
      const rankEyebrow = document.getElementById('rank-eyebrow');
      const rankDetail = document.getElementById('rank-detail');
      const leaderboardList = document.getElementById('leaderboard-list');
      const playAgainBtn = document.getElementById('play-again-btn');
      const exitDialog = document.getElementById('exit-dialog');
      const exitCancel = document.getElementById('exit-cancel');
      const exitConfirm = document.getElementById('exit-confirm');
      const shareFb = document.getElementById('share-fb');
      const shareX = document.getElementById('share-x');
      const shareNative = document.getElementById('share-native');
      const shareCopy = document.getElementById('share-copy');
      const copyToast = document.getElementById('copy-toast');

      // === Game state ===
      let board;        // 2D array of cells: { wall, ticket, pellet, door, pen }
      let player;       // { x, y, dir, nextDir, anim }
      let tracers;      // [{ x, y, dir, def, mode, scared, eaten }]
      let score = 0;
      let lives = 3;
      let level = 1;
      let ticketsRemaining = 0;
      let powerUntil = 0;
      let lastFrame = 0;
      let rafHandle = null;
      let gameRunning = false;
      let gameStarted = false;
      let levelTransition = false;
      let deathPause = 0;
      let finalScore = 0;
      let finalLevel = 1;
      let lastSubmittedRank = null;
      let lastSubmittedInitials = null;

      function showState(name) {
        [stateIntro, statePlaying, stateResult, stateLeaderboard].forEach(s => s.classList.remove('state--active'));
        if (name === 'intro')       stateIntro.classList.add('state--active');
        if (name === 'playing')     statePlaying.classList.add('state--active');
        if (name === 'result')      stateResult.classList.add('state--active');
        if (name === 'leaderboard') stateLeaderboard.classList.add('state--active');
      }

      function buildBoard() {
        const b = [];
        let playerSpawn = null;
        ticketsRemaining = 0;
        for (let r = 0; r < ROWS; r++) {
          const row = [];
          for (let c = 0; c < COLS; c++) {
            const ch = MAZE[r][c];
            const cell = { wall: false, ticket: false, pellet: false, door: false, pen: false };
            if (ch === '#') cell.wall = true;
            else if (ch === '.') { cell.ticket = true; ticketsRemaining++; }
            else if (ch === 'o') { cell.pellet = true; ticketsRemaining++; }
            else if (ch === '-') cell.door = true;
            else if (ch === 'a') cell.pen = true;
            else if (ch === 'P') playerSpawn = { x: c, y: r };
            row.push(cell);
          }
          b.push(row);
        }
        if (!playerSpawn) playerSpawn = { x: 10, y: 16 };
        return { board: b, playerSpawn };
      }

      function spawnPlayer(spawn) {
        return {
          x: spawn.x,
          y: spawn.y,
          subX: 0,        // sub-cell offset for smooth motion (-CELL/2..CELL/2 conceptually, here 0..CELL)
          subY: 0,
          dir: { x: 0, y: 0 },
          nextDir: { x: 0, y: 0 },
          anim: 0,
          spawn,
        };
      }

      function spawnTracers() {
        // Pen interior is around rows 10-11, cols 8-12. Tracers spawn from there
        // and exit through the door at row 9, col 10 area.
        const spawnPositions = [
          { x: 8,  y: 10 },
          { x: 10, y: 10 },
          { x: 12, y: 10 },
          { x: 10, y: 11 },
        ];
        return TRACERS.map((def, i) => ({
          x: spawnPositions[i].x,
          y: spawnPositions[i].y,
          subX: 0,
          subY: 0,
          dir: { x: 0, y: -1 }, // start moving up to leave pen
          def,
          mode: 'leaving',  // 'leaving' (in pen, heading out) | 'chase' | 'scared' | 'eaten' (back to pen)
          spawn: spawnPositions[i],
          releaseDelay: i * 0.8, // staggered release in seconds
          releasedAt: 0,
          flashWarn: false,
        }));
      }

      function isWalkableCell(x, y, isTracer = false) {
        if (y < 0 || y >= ROWS) return false;
        if (x < 0 || x >= COLS) {
          // wrap tunnels at row 10 (the corridor row)
          return false;
        }
        const cell = board[y][x];
        if (cell.wall) return false;
        if (cell.door && !isTracer) return false; // player can't enter pen door
        return true;
      }

      function wrapX(x) {
        // Tunnel wrap on row 10 (the pen corridor row that's empty on both ends)
        if (x < 0) return COLS - 1;
        if (x >= COLS) return 0;
        return x;
      }

      function startLevel(lvl) {
        const setup = buildBoard();
        board = setup.board;
        player = spawnPlayer(setup.playerSpawn);
        tracers = spawnTracers();
        levelTransition = false;
        powerUntil = 0;
        deathPause = 0;
        levelDisplay.textContent = String(lvl);
      }

      function startGame() {
        score = 0;
        lives = 3;
        level = 1;
        gameRunning = true;
        gameStarted = false;
        lastFrame = 0;

        scoreDisplay.textContent = '0';
        levelDisplay.textContent = '1';
        livesDisplay.textContent = String(lives);

        startLevel(level);
        showState('playing');
        boardOverlay.classList.remove('board-overlay--hidden');
        overlayText.textContent = 'Press a direction to start';

        draw();
        cancelAnimationFrame(rafHandle);
        rafHandle = requestAnimationFrame(loop);
      }

      function beginGameplay() {
        if (gameStarted || !gameRunning) return;
        gameStarted = true;
        boardOverlay.classList.add('board-overlay--hidden');
        // Tracer release timer starts now
        const now = performance.now();
        for (const t of tracers) t.releasedAt = now + t.releaseDelay * 1000;
      }

      function loseLife() {
        lives--;
        livesDisplay.textContent = String(lives);
        if (lives <= 0) {
          endGame();
          return;
        }
        // Mark not-started so loop returns early until player presses a direction
        gameStarted = false;
        // Reset frame timer so dt doesn't explode when player resumes
        lastFrame = 0;
        // Reset player
        player.x = player.spawn.x;
        player.y = player.spawn.y;
        player.px = player.spawn.x + 0.5;
        player.py = player.spawn.y + 0.5;
        player.subX = 0;
        player.subY = 0;
        player.dir = { x: 0, y: 0 };
        player.nextDir = { x: 0, y: 0 };
        // Reset tracers
        for (let i = 0; i < tracers.length; i++) {
          const t = tracers[i];
          t.x = t.spawn.x;
          t.y = t.spawn.y;
          t.px = t.spawn.x + 0.5;
          t.py = t.spawn.y + 0.5;
          t.subX = 0;
          t.subY = 0;
          t.dir = { x: 0, y: -1 };
          t.mode = 'leaving';
          // Each tracer's stagger relative to "now" — beginGameplay will
          // reset these again when the player presses a direction.
          t.releasedAt = performance.now() + 1500 + i * 800;
          t.releaseDelay = 1.5 + i * 0.8;
        }
        // Show overlay so player knows they need to start moving again
        boardOverlay.classList.remove('board-overlay--hidden');
        overlayText.textContent = 'Press a direction to continue';
        // Render the reset state once so player sees the new positions
        draw();
        // Restart the animation loop fresh to make sure no stale state lingers
        cancelAnimationFrame(rafHandle);
        rafHandle = requestAnimationFrame(loop);
      }

      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;
        if (window.ArcadeSound) {
          window.ArcadeSound.stopMusic();
          window.ArcadeSound.play('game_over');
        }
        gameStarted = false;
        cancelAnimationFrame(rafHandle);

        finalScore = score;
        finalLevel = level;
        resultScore.textContent = String(finalScore);
        resultLevel.textContent = `Level ${finalLevel}`;

        initBoxes.forEach(b => { b.value = ''; b.classList.remove('initial-box--filled'); });
        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMIT SCORE';
        initialsError.textContent = '';

        showState('result');
        setTimeout(() => initBoxes[0].focus(), 100);
      }

      // Movement: entities move continuously. They stop at the center of each cell
      // to make turn decisions. We track integer cell coords + sub-cell offsets.
      // For simplicity we use fractional position (px, py) in cell units.
      // Refactor: convert to fractional position
      function setupFractional() {
        // Add fractional pos to player and tracers
        player.px = player.x + 0.5;
        player.py = player.y + 0.5;
        for (const t of tracers) {
          t.px = t.x + 0.5;
          t.py = t.y + 0.5;
        }
      }

      function tickEntity(e, dt, speed, isTracer) {
        // Move smoothly. Detect crossing the center of a cell during this
        // frame's movement — at that crossing, queue direction changes and
        // wall checks. This prevents the "snap-back" glitch from a fixed
        // epsilon based atCenter check, which fails at low speeds when
        // movement-per-frame is larger than the epsilon.

        // If not moving, nothing to do beyond a possible nextDir kick-off
        if (e.dir.x === 0 && e.dir.y === 0) {
          // Stationary — try to start moving toward nextDir if possible
          if (!isTracer && e.nextDir && (e.nextDir.x !== 0 || e.nextDir.y !== 0)) {
            const cx = Math.floor(e.px);
            const cy = Math.floor(e.py);
            const tx = wrapX(cx + e.nextDir.x);
            const ty = cy + e.nextDir.y;
            if (isWalkableCell(tx, ty, false)) {
              e.dir = { ...e.nextDir };
            }
          } else if (isTracer) {
            chooseTracerDir(e);
          }
          if (e.dir.x === 0 && e.dir.y === 0) return;
        }

        const remaining = speed * dt;
        // Distance to next cell center along current direction
        let prevPx = e.px;
        let prevPy = e.py;

        // Try to move; if we cross a cell center, handle direction-change there.
        // For axis-aligned movement (always the case here), we can compute the
        // distance to the next center and either move that far + handle, or
        // move the full frame distance if center is further than `remaining`.
        const cxNow = Math.floor(e.px);
        const cyNow = Math.floor(e.py);
        const centerX = cxNow + 0.5;
        const centerY = cyNow + 0.5;

        let movedThisFrame = 0;
        const distToCenter = e.dir.x !== 0
          ? (e.dir.x > 0 ? centerX - e.px : e.px - centerX)
          : (e.dir.y > 0 ? centerY - e.py : e.py - centerY);

        if (distToCenter > 0 && distToCenter <= remaining) {
          // We will cross the center this frame. Snap to center first.
          if (e.dir.x !== 0) e.px = centerX;
          if (e.dir.y !== 0) e.py = centerY;
          movedThisFrame = distToCenter;

          // At center: handle direction changes and wall checks
          const cx = Math.floor(e.px);
          const cy = Math.floor(e.py);

          if (!isTracer) {
            if (e.nextDir && (e.nextDir.x !== 0 || e.nextDir.y !== 0)) {
              const tx = wrapX(cx + e.nextDir.x);
              const ty = cy + e.nextDir.y;
              if (isWalkableCell(tx, ty, false)) {
                e.dir = { ...e.nextDir };
              }
            }
          } else {
            chooseTracerDir(e);
          }

          // Confirm we can keep moving in (possibly new) direction
          const tx = wrapX(cx + e.dir.x);
          const ty = cy + e.dir.y;
          if (e.dir.x === 0 && e.dir.y === 0) {
            // Stopped at center
            e.x = cx;
            e.y = cy;
            return;
          }
          if (!isWalkableCell(tx, ty, isTracer)) {
            e.dir = { x: 0, y: 0 };
            e.x = cx;
            e.y = cy;
            return;
          }

          // Move the remainder of the frame in the (possibly new) direction
          const leftover = remaining - movedThisFrame;
          e.px += e.dir.x * leftover;
          e.py += e.dir.y * leftover;
        } else {
          // No center crossing this frame; move freely
          e.px += e.dir.x * remaining;
          e.py += e.dir.y * remaining;
        }

        // Tunnel wrap (row 10) — handled before clamping
        if (e.py >= 10 && e.py <= 11) {
          if (e.px < -0.3) e.px = COLS - 0.5;
          if (e.px > COLS + 0.3) e.px = 0.5;
        } else {
          if (e.px < 0.5) { e.px = 0.5; e.dir = { x: 0, y: 0 }; }
          if (e.px > COLS - 0.5) { e.px = COLS - 0.5; e.dir = { x: 0, y: 0 }; }
        }

        // Sync integer cell
        e.x = Math.floor(e.px);
        e.y = Math.floor(e.py);
      }

      function chooseTracerDir(t) {
        const cx = t.x;
        const cy = t.y;

        // If 'leaving' mode: move toward door (row 9 area) and once out switch to chase
        if (t.mode === 'leaving') {
          if (performance.now() < t.releasedAt) {
            // bobble in pen, move up/down
            t.dir = { x: 0, y: t.dir.y === -1 ? 1 : -1 };
            return;
          }
          // Move toward door at (10, 9) then up
          if (cy >= 10) {
            // move toward col 10 first
            if (cx < 10 && isWalkableCellOrPen(cx + 1, cy)) { t.dir = { x: 1, y: 0 }; return; }
            if (cx > 10 && isWalkableCellOrPen(cx - 1, cy)) { t.dir = { x: -1, y: 0 }; return; }
            // at col 10, try going up through door
            if (cx === 10 && (board[cy - 1][cx].door || isWalkableCell(cx, cy - 1, true))) {
              t.dir = { x: 0, y: -1 };
              return;
            }
          }
          if (cy === 9) {
            // exited the door
            t.mode = 'chase';
            t.dir = { x: 0, y: -1 };
            return;
          }
          // fallback
          t.dir = { x: 0, y: -1 };
          return;
        }

        // If 'eaten' mode: head back to pen
        if (t.mode === 'eaten') {
          // Simple: move toward pen entrance at (10, 9)
          const targetX = 10, targetY = 11;
          if (cx === targetX && cy === targetY) {
            // arrived in pen; reset to leaving mode
            t.mode = 'leaving';
            t.releasedAt = performance.now() + 1000;
            t.dir = { x: 0, y: -1 };
            return;
          }
          // BFS toward target — but cheaper heuristic: pick neighbor closest to target,
          // allowing pen/door cells.
          const opts = [
            { dir: { x: 1, y: 0 }, nx: cx + 1, ny: cy },
            { dir: { x: -1, y: 0 }, nx: cx - 1, ny: cy },
            { dir: { x: 0, y: 1 }, nx: cx, ny: cy + 1 },
            { dir: { x: 0, y: -1 }, nx: cx, ny: cy - 1 },
          ].filter(o => o.nx >= 0 && o.nx < COLS && o.ny >= 0 && o.ny < ROWS &&
                       (isWalkableCellOrPen(o.nx, o.ny) || board[o.ny][o.nx].door));
          if (opts.length === 0) { t.dir = { x: 0, y: 0 }; return; }
          opts.sort((a, b) => {
            const da = (a.nx - targetX) ** 2 + (a.ny - targetY) ** 2;
            const db = (b.nx - targetX) ** 2 + (b.ny - targetY) ** 2;
            return da - db;
          });
          t.dir = opts[0].dir;
          return;
        }

        // Normal chase/scared modes: at every intersection, pick a direction
        // that doesn't reverse and that's walkable.
        const validDirs = [];
        const dirs = [
          { x: 1, y: 0 }, { x: -1, y: 0 },
          { x: 0, y: 1 }, { x: 0, y: -1 },
        ];
        for (const d of dirs) {
          // No reversing unless dead-end
          if (d.x === -t.dir.x && d.y === -t.dir.y && t.dir.x + t.dir.y !== 0) continue;
          const nx = wrapX(cx + d.x);
          const ny = cy + d.y;
          if (isWalkableCell(nx, ny, true) && !(board[ny][nx] && board[ny][nx].door)) {
            validDirs.push(d);
          }
        }
        if (validDirs.length === 0) {
          // Allow reverse
          t.dir = { x: -t.dir.x, y: -t.dir.y };
          return;
        }

        // Pick based on personality
        let target;
        if (t.mode === 'scared') {
          // Run away from player
          target = { x: 2 * (player.x - 10) + 10, y: 2 * (player.y - 11) + 11 };
          // Actually: pick the dir that maximizes distance from player
          validDirs.sort((a, b) => {
            const da = (cx + a.x - player.x) ** 2 + (cy + a.y - player.y) ** 2;
            const db = (cx + b.x - player.x) ** 2 + (cy + b.y - player.y) ** 2;
            return db - da;
          });
          // Add randomness 30% of the time
          if (Math.random() < 0.3) {
            t.dir = validDirs[Math.floor(Math.random() * validDirs.length)];
          } else {
            t.dir = validDirs[0];
          }
          return;
        }

        switch (t.def.personality) {
          case 'random':
            t.dir = validDirs[Math.floor(Math.random() * validDirs.length)];
            return;
          case 'chaser':
            target = { x: player.x, y: player.y };
            break;
          case 'flank':
            // Aim ahead of player by 4 cells
            target = { x: player.x + player.dir.x * 4, y: player.y + player.dir.y * 4 };
            break;
          case 'patrol':
            // Patrol target rotates between corners
            const corners = [
              { x: 1, y: 1 }, { x: COLS - 2, y: 1 },
              { x: 1, y: ROWS - 2 }, { x: COLS - 2, y: ROWS - 2 },
            ];
            const idx = Math.floor((performance.now() / 4000) % corners.length);
            target = corners[idx];
            break;
          default:
            target = { x: player.x, y: player.y };
        }

        validDirs.sort((a, b) => {
          const da = (cx + a.x - target.x) ** 2 + (cy + a.y - target.y) ** 2;
          const db = (cx + b.x - target.x) ** 2 + (cy + b.y - target.y) ** 2;
          return da - db;
        });
        t.dir = validDirs[0];
      }

      function isWalkableCellOrPen(x, y) {
        if (y < 0 || y >= ROWS || x < 0 || x >= COLS) return false;
        const cell = board[y][x];
        return !cell.wall;
      }

      function loop(timestamp) {
        if (!gameRunning) return;
        if (!gameStarted) {
          rafHandle = requestAnimationFrame(loop);
          return;
        }
        if (lastFrame === 0) lastFrame = timestamp;
        const dt = Math.min(0.05, (timestamp - lastFrame) / 1000);
        lastFrame = timestamp;

        if (deathPause > 0) {
          deathPause -= dt;
          draw();
          rafHandle = requestAnimationFrame(loop);
          return;
        }

        if (levelTransition) {
          rafHandle = requestAnimationFrame(loop);
          return;
        }

        // Speed scales slightly with level (cells per second)
        const playerSpeed = 5.5 + (level - 1) * 0.3;
        const tracerSpeed = 5.0 + (level - 1) * 0.35;
        const scaredSpeed = 3.2;

        // Initialize fractional positions if needed
        if (typeof player.px === 'undefined') setupFractional();

        // Player tick
        tickEntity(player, dt, playerSpeed, false);
        if (player.dir.x !== 0 || player.dir.y !== 0) {
          player.anim += dt * 8;
        }

        // Eat ticket / pellet at player's current cell (when at center)
        const cx = Math.floor(player.px);
        const cy = Math.floor(player.py);
        if (cx >= 0 && cx < COLS && cy >= 0 && cy < ROWS) {
          const cell = board[cy][cx];
          if (cell.ticket) {
            cell.ticket = false;
            score += 10;
            ticketsRemaining--;
            scoreDisplay.textContent = String(score);
            if (window.ArcadeSound) window.ArcadeSound.play('loop_ticket');
          } else if (cell.pellet) {
            cell.pellet = false;
            score += 50;
            ticketsRemaining--;
            powerUntil = performance.now() + POWER_DURATION_MS;
            scoreDisplay.textContent = String(score);
            if (window.ArcadeSound) window.ArcadeSound.play('loop_pellet');
            // Set tracers to scared
            for (const t of tracers) {
              if (t.mode === 'chase') {
                t.mode = 'scared';
                // Reverse direction (classic Pac-Man)
                t.dir = { x: -t.dir.x, y: -t.dir.y };
              }
            }
          }
        }

        // Power-up management
        const now = performance.now();
        const powerActive = now < powerUntil;
        const flashWarn = powerActive && (powerUntil - now < POWER_FLASH_MS);
        if (!powerActive) {
          for (const t of tracers) {
            if (t.mode === 'scared') t.mode = 'chase';
            t.flashWarn = false;
          }
        } else {
          for (const t of tracers) t.flashWarn = flashWarn;
        }

        // Tracer ticks
        for (const t of tracers) {
          let speed = tracerSpeed;
          if (t.mode === 'scared') speed = scaredSpeed;
          if (t.mode === 'eaten') speed = tracerSpeed * 1.6;
          if (t.mode === 'leaving' && now < t.releasedAt) speed = 1.5;
          tickEntity(t, dt, speed, true);
        }

        // Collisions: any tracer overlapping player cell-distance
        for (const t of tracers) {
          const dx = t.px - player.px;
          const dy = t.py - player.py;
          if (dx * dx + dy * dy < 0.5) {
            if (t.mode === 'scared') {
              // Eat tracer!
              score += 200;
              scoreDisplay.textContent = String(score);
              t.mode = 'eaten';
              if (window.ArcadeSound) window.ArcadeSound.play('loop_eat_tracer');
            } else if (t.mode === 'chase' || t.mode === 'leaving') {
              if (window.ArcadeSound) window.ArcadeSound.play('loop_death');
              loseLife();
              return;
            }
          }
        }

        // Level clear?
        if (ticketsRemaining <= 0) {
          score += 100 + lives * 25;
          scoreDisplay.textContent = String(score);
          level++;
          levelTransition = true;
          if (window.ArcadeSound) window.ArcadeSound.play('level_up');
          setTimeout(() => {
            startLevel(level);
            // Reset fractional positions for new level
            setupFractional();
            levelTransition = false;
            // Brief pause overlay
            boardOverlay.classList.remove('board-overlay--hidden');
            overlayText.textContent = `LEVEL ${level} — GO!`;
            setTimeout(() => boardOverlay.classList.add('board-overlay--hidden'), 800);
            // re-stagger tracer release
            const t0 = performance.now() + 1000;
            for (let i = 0; i < tracers.length; i++) tracers[i].releasedAt = t0 + i * 600;
          }, 600);
        }

        draw();
        rafHandle = requestAnimationFrame(loop);
      }

      function setDirection(dx, dy) {
        if (!gameRunning) return;
        beginGameplay();
        player.nextDir = { x: dx, y: dy };
        // If we're not currently moving, try to apply immediately
        if (player.dir.x === 0 && player.dir.y === 0) {
          const cx = Math.floor(player.px);
          const cy = Math.floor(player.py);
          if (isWalkableCell(wrapX(cx + dx), cy + dy, false)) {
            player.dir = { x: dx, y: dy };
          }
        }
      }

      // === Drawing ===
      function draw() {
        // Background
        ctx.fillStyle = '#02100a';
        ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);

        // Draw maze cells
        for (let r = 0; r < ROWS; r++) {
          for (let c = 0; c < COLS; c++) {
            const cell = board[r][c];
            const x = OFFSET_X + c * CELL;
            const y = OFFSET_Y + r * CELL;
            if (cell.wall) {
              drawWall(x, y, c, r);
            } else if (cell.door) {
              ctx.fillStyle = '#fbbf24';
              ctx.fillRect(x + 1, y + CELL / 2 - 1, CELL - 2, 2);
            } else {
              if (cell.ticket) {
                ctx.fillStyle = '#fbbf24';
                ctx.beginPath();
                ctx.arc(x + CELL / 2, y + CELL / 2, 2, 0, Math.PI * 2);
                ctx.fill();
              } else if (cell.pellet) {
                ctx.fillStyle = '#fbbf24';
                const pulse = 0.85 + 0.15 * Math.sin(performance.now() / 180);
                ctx.beginPath();
                ctx.arc(x + CELL / 2, y + CELL / 2, 5 * pulse, 0, Math.PI * 2);
                ctx.fill();
              }
            }
          }
        }

        // Draw player (cursor arrow)
        if (player) {
          drawPlayer();
        }

        // Draw tracers
        for (const t of tracers) {
          drawTracer(t);
        }
      }

      function drawWall(x, y, c, r) {
        // Matrix-green walls with rounded look
        ctx.fillStyle = '#022c22';
        ctx.fillRect(x, y, CELL, CELL);
        // Inner glow line
        ctx.strokeStyle = '#4ade80';
        ctx.lineWidth = 1.5;
        // Find which sides have walls to draw connecting lines
        const top    = r > 0 && board[r - 1][c].wall;
        const bottom = r < ROWS - 1 && board[r + 1][c].wall;
        const left   = c > 0 && board[r][c - 1].wall;
        const right  = c < COLS - 1 && board[r][c + 1].wall;

        const cx = x + CELL / 2;
        const cy = y + CELL / 2;

        ctx.beginPath();
        if (left)   { ctx.moveTo(x, cy); ctx.lineTo(cx, cy); }
        if (right)  { ctx.moveTo(cx, cy); ctx.lineTo(x + CELL, cy); }
        if (top)    { ctx.moveTo(cx, y); ctx.lineTo(cx, cy); }
        if (bottom) { ctx.moveTo(cx, cy); ctx.lineTo(cx, y + CELL); }
        ctx.stroke();

        // Add subtle glow effect via a second darker line
        ctx.strokeStyle = 'rgba(74, 222, 128, 0.3)';
        ctx.lineWidth = 3.5;
        ctx.beginPath();
        if (left)   { ctx.moveTo(x, cy); ctx.lineTo(cx, cy); }
        if (right)  { ctx.moveTo(cx, cy); ctx.lineTo(x + CELL, cy); }
        if (top)    { ctx.moveTo(cx, y); ctx.lineTo(cx, cy); }
        if (bottom) { ctx.moveTo(cx, cy); ctx.lineTo(cx, y + CELL); }
        ctx.stroke();
      }

      function drawPlayer() {
        const px = OFFSET_X + player.px * CELL;
        const py = OFFSET_Y + player.py * CELL;
        const size = CELL * 0.7;

        ctx.save();
        ctx.translate(px, py);

        // Rotate based on direction
        let rot = 0;
        if (player.dir.x === 1) rot = Math.PI / 2;
        else if (player.dir.x === -1) rot = -Math.PI / 2;
        else if (player.dir.y === 1) rot = Math.PI;
        else if (player.dir.y === -1) rot = 0;
        else rot = 0;
        ctx.rotate(rot);

        // Cursor pointer scaled
        const s = size * 0.55;
        ctx.fillStyle = '#fbbf24';
        ctx.strokeStyle = '#92400e';
        ctx.lineWidth = 1.5;
        ctx.lineJoin = 'round';
        ctx.beginPath();
        ctx.moveTo(0, -s);
        ctx.lineTo(s * 0.7, s * 0.3);
        ctx.lineTo(s * 0.18, s * 0.3);
        ctx.lineTo(s * 0.4, s);
        ctx.lineTo(s * 0.05, s * 1.05);
        ctx.lineTo(-s * 0.18, s * 0.4);
        ctx.lineTo(-s * 0.7, s * 0.5);
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
        ctx.restore();
      }

      function drawTracer(t) {
        const px = OFFSET_X + t.px * CELL;
        const py = OFFSET_Y + t.py * CELL;
        const r = CELL * 0.4;

        let body = t.def.color;
        let outline = t.def.stroke;
        let eyeFill = '#fff';
        let pupilFill = '#0f172a';

        if (t.mode === 'scared') {
          body = t.flashWarn && Math.floor(performance.now() / 200) % 2 === 0
            ? '#fff' : '#1e3a8a';
          outline = '#1e40af';
          eyeFill = '#fbbf24';
          pupilFill = '#7f1d1d';
        } else if (t.mode === 'eaten') {
          // Eyes only
          ctx.save();
          ctx.fillStyle = '#fff';
          ctx.beginPath();
          ctx.arc(px - r * 0.3, py - r * 0.1, r * 0.3, 0, Math.PI * 2);
          ctx.arc(px + r * 0.3, py - r * 0.1, r * 0.3, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = '#0f172a';
          ctx.beginPath();
          ctx.arc(px - r * 0.3 + t.dir.x * 2, py - r * 0.1 + t.dir.y * 2, r * 0.15, 0, Math.PI * 2);
          ctx.arc(px + r * 0.3 + t.dir.x * 2, py - r * 0.1 + t.dir.y * 2, r * 0.15, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
          return;
        }

        ctx.save();
        // Body: rounded top + serrated bottom
        ctx.fillStyle = body;
        ctx.strokeStyle = outline;
        ctx.lineWidth = 1;
        ctx.beginPath();
        // Top semicircle
        ctx.arc(px, py, r, Math.PI, 0);
        // Right side down
        ctx.lineTo(px + r, py + r * 0.7);
        // Serrated bottom (3 zigzags)
        const teeth = 3;
        for (let i = 0; i < teeth; i++) {
          const xa = px + r - (i + 0.5) * (2 * r / teeth);
          const ya = py + r * 0.95;
          const xb = px + r - (i + 1) * (2 * r / teeth);
          const yb = py + r * 0.7;
          ctx.lineTo(xa, ya);
          ctx.lineTo(xb, yb);
        }
        ctx.closePath();
        ctx.fill();
        ctx.stroke();

        // Eyes
        ctx.fillStyle = eyeFill;
        ctx.beginPath();
        ctx.arc(px - r * 0.32, py - r * 0.1, r * 0.28, 0, Math.PI * 2);
        ctx.arc(px + r * 0.32, py - r * 0.1, r * 0.28, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = pupilFill;
        ctx.beginPath();
        ctx.arc(px - r * 0.32 + t.dir.x * 2.5, py - r * 0.1 + t.dir.y * 2.5, r * 0.14, 0, Math.PI * 2);
        ctx.arc(px + r * 0.32 + t.dir.x * 2.5, py - r * 0.1 + t.dir.y * 2.5, r * 0.14, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      // === Input ===
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !exitDialog.hidden) {
          hideExitDialog();
          return;
        }
        if (!statePlaying.classList.contains('state--active')) return;
        switch (e.key) {
          case 'ArrowUp': case 'w': case 'W':
            e.preventDefault(); setDirection(0, -1); break;
          case 'ArrowDown': case 's': case 'S':
            e.preventDefault(); setDirection(0, 1); break;
          case 'ArrowLeft': case 'a': case 'A':
            e.preventDefault(); setDirection(-1, 0); break;
          case 'ArrowRight': case 'd': case 'D':
            e.preventDefault(); setDirection(1, 0); break;
        }
      });

      // Touch swipe
      let touchStartX = 0, touchStartY = 0;
      let touchActive = false;

      canvas.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return;
        e.preventDefault();
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
      }, { passive: false });

      canvas.addEventListener('touchend', (e) => {
        if (!touchActive) return;
        touchActive = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        const absX = Math.abs(dx);
        const absY = Math.abs(dy);
        const MIN = 18;
        if (absX < MIN && absY < MIN) {
          beginGameplay();
          return;
        }
        if (absX > absY) setDirection(dx > 0 ? 1 : -1, 0);
        else setDirection(0, dy > 0 ? 1 : -1);
      }, { passive: false });

      canvas.addEventListener('touchmove', (e) => {
        if (touchActive) e.preventDefault();
      }, { passive: false });

      canvas.addEventListener('click', () => beginGameplay());

      // === Score submission ===
      initBoxes.forEach((box, idx) => {
        box.addEventListener('input', () => {
          let val = box.value.toUpperCase().replace(/[^A-Z]/g, '');
          box.value = val;
          if (val.length === 1) {
            box.classList.add('initial-box--filled');
            if (idx < initBoxes.length - 1) initBoxes[idx + 1].focus();
            else box.blur();
          } else {
            box.classList.remove('initial-box--filled');
          }
          updateSubmitState();
        });
        box.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && box.value === '' && idx > 0) {
            initBoxes[idx - 1].focus();
            initBoxes[idx - 1].value = '';
            initBoxes[idx - 1].classList.remove('initial-box--filled');
            updateSubmitState();
          }
          if (e.key === 'Enter' && !submitBtn.disabled) submitScore();
        });
        box.addEventListener('focus', () => box.select());
      });

      function getInitials() { return initBoxes.map(b => b.value).join('').toUpperCase(); }
      function updateSubmitState() {
        submitBtn.disabled = !/^[A-Z]{3}$/.test(getInitials());
      }

      async function submitScore() {
        const initials = getInitials();
        if (!/^[A-Z]{3}$/.test(initials)) return;

        submitBtn.disabled = true;
        submitBtnText.textContent = 'SUBMITTING...';
        initialsError.textContent = '';

        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initials, score: finalScore }),
          });
          const data = await res.json();
          if (!res.ok) {
            initialsError.textContent = data.error || 'Could not save score. Try different initials.';
            submitBtn.disabled = false;
            submitBtnText.textContent = 'SUBMIT SCORE';
            return;
          }
          lastSubmittedInitials = initials;
          lastSubmittedRank = data.madeLeaderboard ? data.rank : null;
          renderLeaderboard(data.scores || []);
        } catch (err) {
          initialsError.textContent = 'Network error. Try again in a sec.';
          submitBtn.disabled = false;
          submitBtnText.textContent = 'SUBMIT SCORE';
        }
      }

      submitBtn.addEventListener('click', submitScore);

      skipBtn.addEventListener('click', async () => {
        try {
          const res = await fetch(`/api/scores/${GAME_SLUG}`);
          const data = await res.json();
          lastSubmittedRank = null;
          lastSubmittedInitials = null;
          renderLeaderboard(data.scores || []);
        } catch {
          renderLeaderboard([]);
        }
      });

      function renderLeaderboard(scores) {
        if (lastSubmittedRank) {
          const ord = ordinalSuffix(lastSubmittedRank);
          rankEyebrow.textContent = 'YOU RANKED';
          rankNumber.textContent = `#${lastSubmittedRank}`;
          rankDetail.textContent = lastSubmittedRank === 1 ? '🏆 First place!' : `${ord} place on the leaderboard`;
          document.getElementById('rank-reveal').style.display = '';
        } else if (lastSubmittedInitials) {
          rankEyebrow.textContent = 'SCORE SUBMITTED';
          rankNumber.textContent = String(finalScore);
          rankDetail.textContent = "Didn't crack the top 10 — keep practicing!";
          document.getElementById('rank-reveal').style.display = '';
        } else {
          document.getElementById('rank-reveal').style.display = 'none';
        }

        leaderboardList.innerHTML = '';
        if (scores.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'leaderboard-empty';
          empty.textContent = 'No scores yet. Be the first.';
          leaderboardList.appendChild(empty);
        } else {
          scores.slice(0, 10).forEach((entry, idx) => {
            const li = document.createElement('li');
            const rank = idx + 1;
            const isMe = lastSubmittedRank === rank && lastSubmittedInitials === entry.initials;
            li.className = `leaderboard-row leaderboard-row--${rank} ${isMe ? 'leaderboard-row--me' : ''}`;
            li.innerHTML = `
              <span class="rank-num">${rank}</span>
              <span class="rank-initials">${escapeHtml(entry.initials)}</span>
              <span class="rank-score">${entry.score}</span>
              ${isMe ? '<span class="rank-you">← YOU</span>' : ''}
            `;
            leaderboardList.appendChild(li);
          });
        }
        configureShare();
        showState('leaderboard');
      }

      function ordinalSuffix(n) {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      }

      function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function configureShare() {
        const url = window.location.href;
        const text = `I scored ${finalScore} on ${GAME_NAME} at Jake's Arcade. Beat me?`;
        const fullShare = `${text} ${url}`;

        shareFb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`;
        shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;

        if (navigator.share) {
          shareNative.style.display = '';
          shareNative.onclick = async () => {
            try { await navigator.share({ title: GAME_NAME + " — Jake's Arcade", text, url }); } catch (e) { }
          };
        }

        shareCopy.onclick = async () => {
          try {
            await navigator.clipboard.writeText(fullShare);
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = fullShare;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
            copyToast.classList.add('copy-toast--show');
            setTimeout(() => copyToast.classList.remove('copy-toast--show'), 2000);
          }
        };
      }

      playAgainBtn.addEventListener('click', () => startGame());

      function showExitDialog() {
        exitDialog.hidden = false;
        setTimeout(() => exitCancel.focus(), 50);
      }
      function hideExitDialog() { exitDialog.hidden = true; }

      exitBtn.addEventListener('click', () => {
        if (gameRunning) showExitDialog();
        else window.location.href = EXIT_TO;
      });

      exitCancel.addEventListener('click', hideExitDialog);
      exitConfirm.addEventListener('click', () => {
        gameRunning = false;
        cancelAnimationFrame(rafHandle);
        window.location.href = EXIT_TO;
      });

      startBtn.addEventListener('click', startGame);
    </script>

